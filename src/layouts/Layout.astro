---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title?: string;
  currentPath?: string;
}
const { title = 'EHS信息站', currentPath = '' } = Astro.props;

const navItems = [
  { label: 'AI应用', href: '/ai-apps/' },
  { label: '法律法规', href: '/regulations/' },
  { label: '规范文件', href: '/standards/' },
  { label: '事故报告', href: '/accidents/' },
  { label: '视频课堂', href: '/videos/' },
  { label: '资料中心', href: '/documents/' },
  { label: '留言板', href: '/messages/' },
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - EHS信息站</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">🛡</span>
        <span>EHS信息站</span>
      </a>
      <nav>
        <ul class="nav-links">
          {navItems.map(item => (
            <li>
              <a
                href={item.href}
                class:list={['', { active: currentPath === item.href || (currentPath !== '/' && item.href !== '/' && currentPath.startsWith(item.href.replace(/\/$/, ''))) }]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <!-- Mobile menu button -->
      <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="菜单">☰</button>
    </div>
    <!-- Mobile nav -->
    <div class="mobile-nav" id="mobile-nav">
      <ul class="mobile-nav-links">
        {navItems.map(item => (
          <li>
            <a href={item.href} class:list={['', { active: currentPath === item.href }]}>
