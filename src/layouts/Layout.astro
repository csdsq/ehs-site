---
interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = "/" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EHS安全合规知识平台" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | EHS经验分享</title>
  </head>
  <body>
    <!-- Navigation -->
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-logo">
          <span class="logo-icon">🛡</span>
          <span class="logo-text">EHS经验分享</span>
        </a>
        <nav class="site-nav" id="siteNav">
          <a href="/ai-apps/" class={currentPath === '/ai-apps/' ? 'nav-link active' : 'nav-link'}>AI应用</a>
          <a href="/standards/" class={currentPath === '/standards/' ? 'nav-link active' : 'nav-link'}>国标地标</a>
          <a href="/regulations/" class={currentPath === '/regulations/' ? 'nav-link active' : 'nav-link'}>法规文件</a>
          <a href="/accidents/" class={currentPath === '/accidents/' ? 'nav-link active' : 'nav-link'}>事故报告</a>
          <a href="/documents/" class={currentPath === '/documents/' ? 'nav-link active' : 'nav-link'}>资料文档</a>
          <a href="/submit/" class={currentPath === '/submit/' ? 'nav-link active' : 'nav-link'}>同行投稿</a>
        </nav>
        <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="菜单">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <h4>栏目导航</h4>
            <a href="/ai-apps/">AI应用</a>
            <a href="/standards/">国标地标</a>
            <a href="/regulations/">法规文件</a>
            <a href="/accidents/">事故报告</a>
          </div>
          <div class="footer-col">
            <h4>更多</h4>
            <a href="/documents/">资料文档</a>
            <a href="/submit/">同行投稿</a>
            <a href="/messages/">留言板</a>
          </div>
          <div class="footer-col">
            <h4>关于</h4>
            <p class="footer-desc">EHS安全合规知识平台，汇聚行业同仁，共建安全知识库。</p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} EHS经验分享. All rights reserved.</p>
          <p class="footer-icp">
            <span id="busuanzi_container_site_pv">
              本站总访问量 <span id="busuanzi_value_site_pv"></span> 次
            </span>
            &nbsp;|&nbsp;
            <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">浙ICP备2026033883号-2</a>
          </p>
        </div>
      </div>
    </footer>

    <!-- Feedback Widget -->
    <div class="feedback-fab" id="feedbackFab" role="button" tabindex="0" aria-label="反馈问题">⚠ 反馈</div>
    <div class="feedback-panel" id="feedbackPanel" hidden>
      <div class="fb-header">
        <span class="fb-title">这条内容有问题？</span>
        <button class="fb-close" id="fbClose" type="button" aria-label="关闭">⛕</button>
      </div>
      <div class="fb-sub">选择问题类型，点击即可提交（也可顺便补充说明）：</div>
      <div class="fb-types" id="fbTypes">
        <button type="button" class="fb-type" data-type="link_broken">链接失效</button>
        <button type="button" class="fb-type" data-type="content_error">内容错误</button>
        <button type="button" class="fb-type" data-type="wrong_category">分类/标签不对</button>
        <button type="button" class="fb-type" data-type="duplicate">重复/多余</button>
        <button type="button" class="fb-type" data-type="other">其他</button>
      </div>
      <textarea class="fb-detail" id="fbDetail" placeholder="补充说明（可选）：比如哪个链接打不开、哪里写错了..." rows="3"></textarea>
      <button class="fb-submit" id="fbSubmit" type="button">提交反馈</button>
      <div class="fb-status" id="fbStatus"></div>
    </div>

    <script is:inline>
      // Mobile menu toggle
      var mBtn = document.getElementById('mobileMenuBtn');
      var sNav = document.getElementById('siteNav');
      if (mBtn && sNav) {
        mBtn.addEventListener('click', function() {
          sNav.classList.toggle('mobile-open');
          mBtn.classList.toggle('open');
        });
      }
    </script>

    <script is:inline>
      // Feedback widget
      (function() {
        var fab = document.getElementById('feedbackFab');
        var panel = document.getElementById('feedbackPanel');
        var close = document.getElementById('fbClose');
        var types = document.getElementById('fbTypes');
        var detail = document.getElementById('fbDetail');
        var submit = document.getElementById('fbSubmit');
        var status = document.getElementById('fbStatus');
        var selectedType = null;

        fab.addEventListener('click', function() { panel.hidden = !panel.hidden; });
        close.addEventListener('click', function() { panel.hidden = true; });

        types.addEventListener('click', function(e) {
          var btn = e.target.closest('.fb-type');
          if (!btn) return;
          var allBtns = types.querySelectorAll('.fb-type');
          for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
          btn.classList.add('active');
          selectedType = btn.dataset.type;
          status.textContent = '';
          status.className = 'fb-status';
        });

        submit.addEventListener('click', async function() {
          if (!selectedType) {
            status.textContent = '请先选择一个问题类型';
            status.className = 'fb-status err';
            return;
          }
          submit.disabled = true;
          submit.textContent = '提交中...';
          try {
            var res = await fetch('/feedback', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                type: selectedType,
                detail: detail.value.trim(),
                pageUrl: location.href,
                pageTitle: document.title
              })
            });
            var data = await res.json();
            if (res.ok && data.success) {
              status.textContent = '✓ 已收到，感谢你的反馈！';
              status.className = 'fb-status ok';
              detail.value = '';
              selectedType = null;
              var allBtns = types.querySelectorAll('.fb-type');
              for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
              setTimeout(function() {
                panel.hidden = true;
                status.textContent = '';
                status.className = 'fb-status';
                submit.disabled = false;
                submit.textContent = '提交反馈';
              }, 2500);
            } else {
              throw new Error((data && data.error) || '提交失败');
            }
          } catch (err) {
            status.textContent = '提交失败，请稍后重试';
            status.className = 'fb-status err';
            submit.disabled = false;
            submit.textContent = '提交反馈';
          }
        });
      })();
    </script>

    <!-- 不蒜子统计延迟加载 -->
    <script is:inline>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
          document.body.appendChild(s);
        }, 500);
      });
    </script>
  </body>
</html>

<style is:global>
:root {
    --primary: #0f4c75;
    --primary-light: #3282b8;
    --primary-lighter: #bbe1fa;
    --primary-dark: #0a2647;
    --accent-red: #e63946;
    --accent-orange: #f4a261;
    --accent-green: #2a9d8f;
    --accent-purple: #7c3aed;
    --accent-blue: #2563eb;
    --bg: #f0f4f8;
    --bg-white: #ffffff;
    --card: #ffffff;
    --text: #1e293b;
    --text-secondary: #64748b;
    --text-light: #94a3b8;
    --border: #e2e8f0;
    --border-light: #f1f5f9;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.06);
    --shadow-md: 0 4px 6px rgba(0,0,0,0.04), 0 10px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 16px rgba(0,0,0,0.06), 0 16px 40px rgba(0,0,0,0.1);
    --radius-sm: 6px;
    --radius: 10px;
    --radius-lg: 14px;
    --container: 1200px;
    --header-h: 60px;
    --transition: all 0.2s cubic-bezier(0.4,0,0.2,1);
    --tag-safety-bg: #dbeafe;
    --tag-safety-color: #1e40af;
    --tag-environment-bg: #d1fae5;
    --tag-environment-color: #065f46;
    --tag-occupational_health-bg: #fef3c7;
    --tag-occupational_health-color: #92400e;
    --tag-region-bg: #f3f4f6;
    --tag-region-color: #374151;
    --sev-general: #3b82f6;
    --sev-larger: #f59e0b;
    --sev-major: #ef4444;
    --sev-special: #7f1d1d;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: -apple-system, BlinkMacSystemFont, "SF Pro SC", "PingFang SC", "Microsoft YaHei UI", "Microsoft YaHei", "Noto Sans SC", sans-serif; color: var(--text); background: var(--bg); line-height: 1.75; -webkit-font-smoothing: antialiased; }
a { color: var(--primary-light); text-decoration: none; transition: var(--transition); }
a:hover { color: var(--primary); }
img { max-width: 100%; height: auto; }
.container { max-width: var(--container); margin: 0 auto; padding: 0 24px; }
.site-header { background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%); color: #fff; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 8px rgba(0,0,0,0.15); height: var(--header-h); }
.header-inner { max-width: var(--container); margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; height: var(--header-h); }
.site-logo { display: flex; align-items: center; gap: 10px; color: #fff; font-size: 18px; font-weight: 700; letter-spacing: -0.3px; flex-shrink: 0; }
.logo-icon { width: 34px; height: 34px; background: linear-gradient(135deg, var(--accent-red), var(--accent-orange)); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.site-nav { display: flex; gap: 2px; align-items: center; }
.nav-link { color: rgba(255,255,255,0.8); padding: 7px 12px; border-radius: var(--radius-sm); font-size: 13.5px; font-weight: 500; transition: var(--transition); white-space: nowrap; }
.nav-link:hover, .nav-link.active { color: #fff; background: rgba(255,255,255,0.15); }
.mobile-menu-btn { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; }
.mobile-menu-btn span { display: block; width: 20px; height: 2px; background: #fff; border-radius: 1px; transition: var(--transition); }
.stats-bar { background: var(--primary); padding: 24px 0; }
.stats-grid { display: grid; gap: 20px; max-width: var(--container); margin: 0 auto; padding: 0 24px; }
.stats-grid-6 { grid-template-columns: repeat(6, 1fr); }
.stat-item { display: flex; flex-direction: column; align-items: center; color: #fff; text-align: center; padding: 8px 4px; border-radius: var(--radius); transition: background var(--transition); }
.stat-item:hover { background: rgba(255,255,255,0.1); }
.stat-value { font-size: 22px; font-weight: 700; }
.stat-label { font-size: 12px; opacity: 0.85; margin-top: 2px; }
.section { padding: 40px 0; }
.section-alt { background: var(--bg); }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.section-title { font-size: 20px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; }
.section-title:hover { color: var(--primary); }
.section-icon { width: 22px; height: 22px; color: var(--primary); }
.section-more { font-size: 14px; font-weight: 500; white-space: nowrap; }
.list-grid { display: flex; flex-direction: column; gap: 12px; }
.list-item { display: flex; align-items: center; padding: 16px 20px; background: var(--bg-white); border: 1px solid var(--border); border-radius: var(--radius-lg); transition: box-shadow var(--transition), border-color var(--transition); color: inherit; }
.list-item:hover { box-shadow: var(--shadow-md); border-color: var(--primary); }
.list-item-body { flex: 1; min-width: 0; }
.list-item-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
.list-item-no { font-weight: 400; color: var(--text-secondary); font-size: 13px; }
.list-item-meta-row { display: flex; flex-wrap: wrap; gap: 12px; font-size: 12px; color: var(--text-secondary); }
.list-item-meta-row span { white-space: nowrap; }
.list-item-arrow { color: var(--text-light); font-size: 18px; margin-left: 12px; }
.std-tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
.std-tag-safety { background: var(--tag-safety-bg); color: var(--tag-safety-color); }
.std-tag-environment { background: var(--tag-environment-bg); color: var(--tag-environment-color); }
.std-tag-occupational_health { background: var(--tag-occupational_health-bg); color: var(--tag-occupational_health-color); }
.std-tag-region { background: var(--tag-region-bg); color: var(--tag-region-color); }
.std-tag-type-gb { background: #dbeafe; color: #1e40af; }
.std-tag-type-industry { background: #e0e7ff; color: #3730a3; }
.std-tag-type-local { background: #fce7f3; color: #9d174d; }
.acc-tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
.acc-sev-general { background: #dbeafe; color: #1e40af; }
.acc-sev-larger { background: #fef3c7; color: #92400e; }
.acc-sev-major { background: #fee2e2; color: #dc2626; }
.acc-sev-special { background: #fecaca; color: #7f1d1d; }
.acc-tag-cat { background: #f3f4f6; color: #374151; }
.acc-tag-prov { background: #e0e7ff; color: #3730a3; }
.filter-bar { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
.filter-row { display: flex; gap: 24px; flex-wrap: wrap; }
.filter-group { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.filter-label { font-size: 13px; font-weight: 600; color: var(--text-secondary); white-space: nowrap; }
.filter-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.filter-tag { padding: 4px 12px; border: 1px solid var(--border); border-radius: 16px; background: var(--bg-white); font-size: 13px; color: var(--text); cursor: pointer; transition: var(--transition); }
.filter-tag:hover { border-color: var(--primary); color: var(--primary); }
.filter-tag.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.search-box { display: flex; gap: 8px; }
.search-box input { flex: 1; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 14px; outline: none; transition: border-color var(--transition); }
.search-box input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,76,117,0.1); }
.search-box button { padding: 10px 20px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 500; cursor: pointer; transition: background var(--transition); }
.search-box button:hover { background: var(--primary-dark); }
.pagination-bar { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 16px 0; font-size: 13px; color: var(--text-secondary); flex-wrap: wrap; }
.pagination-controls { display: flex; gap: 4px; align-items: center; }
.pagination-controls button { padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-white); cursor: pointer; font-size: 13px; transition: var(--transition); }
.pagination-controls button.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.pagination-controls button:hover:not(.active) { border-color: var(--primary); }
.pagination-controls button:disabled { opacity: 0.5; cursor: not-allowed; }
.page-ellipsis { padding: 0 4px; }
.detail-breadcrumb-flat { font-size: 13px; color: var(--text-secondary); margin-bottom: 16px; }
.detail-breadcrumb-flat a { color: var(--text-secondary); }
.detail-breadcrumb-flat a:hover { color: var(--primary); }
.detail-title-flat { font-size: 24px; font-weight: 700; margin-bottom: 16px; line-height: 1.4; }
.detail-body { min-height: 200px; }
.detail-section { margin-bottom: 32px; }
.detail-section-title { font-size: 18px; font-weight: 700; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border); color: var(--text); }
.detail-text { font-size: 15px; line-height: 1.8; color: var(--text); }
.detail-text p { margin-bottom: 12px; }
.detail-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.detail-action-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 500; cursor: pointer; transition: background var(--transition); }
.detail-action-btn:hover { background: var(--primary-dark); color: #fff; }
.detail-empty { color: var(--text-light); font-size: 14px; }
.loading, .empty { color: var(--text-light); font-size: 14px; padding: 40px 0; text-align: center; }
.info-card-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
.info-card-item { display: flex; flex-direction: column; padding: 12px 16px; background: var(--bg-white); border-radius: var(--radius); border: 1px solid var(--border-light); }
.info-card-label { font-size: 12px; color: var(--text-light); margin-bottom: 4px; }
.info-card-value { font-size: 14px; font-weight: 500; color: var(--text); }
.detail-info-table { width: 100%; border-collapse: collapse; }
.detail-info-table td { padding: 10px 16px; border-bottom: 1px solid var(--border-light); font-size: 14px; }
.detail-info-table .info-label { font-weight: 600; color: var(--text-secondary); width: 120px; white-space: nowrap; }
.detail-info-table .info-value { color: var(--text); }
.regulation-full-text { font-size: 15px; line-height: 1.8; white-space: pre-wrap; word-break: break-word; }
.detail-video-wrap { position: relative; width: 100%; padding-bottom: 56.25%; border-radius: var(--radius-lg); overflow: hidden; }
.detail-video-wrap iframe, .detail-video-wrap video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.page-comment { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border); }
.site-footer { background: var(--bg-white); border-top: 1px solid var(--border); padding: 40px 0 24px; margin-top: 40px; }
.footer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-bottom: 32px; }
.footer-col h4 { font-size: 14px; font-weight: 600; margin-bottom: 12px; color: var(--text); }
.footer-col a { display: block; font-size: 13px; color: var(--text-secondary); padding: 4px 0; transition: color var(--transition); }
.footer-col a:hover { color: var(--primary); }
.footer-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.6; }
.footer-bottom { text-align: center; font-size: 12px; color: var(--text-light); padding-top: 20px; border-top: 1px solid var(--border-light); }
.footer-icp { margin-top: 8px; font-size: 12px; color: var(--text-light); }
.footer-icp a { color: var(--text-light); }
.footer-icp a:hover { color: var(--primary); }
.feedback-fab { position: fixed; right: 24px; bottom: 24px; z-index: 200; display: inline-flex; align-items: center; gap: 6px; padding: 12px 20px; background: var(--primary); color: #fff; font-size: 14px; font-weight: 600; border-radius: 999px; box-shadow: 0 6px 20px rgba(15,76,117,0.35); cursor: pointer; transition: transform var(--transition), box-shadow var(--transition), background var(--transition); user-select: none; }
.feedback-fab:hover { background: var(--primary-dark); transform: translateY(-2px); box-shadow: 0 10px 26px rgba(15,76,117,0.45); }
.feedback-fab:active { transform: translateY(0); }
.feedback-panel { position: fixed; right: 24px; bottom: 84px; z-index: 200; width: 340px; max-width: calc(100vw - 32px); background: #fff; border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: 0 12px 40px rgba(0,0,0,0.18); padding: 18px 18px 16px; animation: fbPop 0.18s ease; }
@keyframes fbPop { from { opacity: 0; transform: translateY(8px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
.fb-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
.fb-title { font-size: 15px; font-weight: 700; color: var(--text); }
.fb-close { border: none; background: none; font-size: 22px; line-height: 1; color: var(--text-light); cursor: pointer; padding: 0 4px; transition: color var(--transition); }
.fb-close:hover { color: var(--text); }
.fb-sub { font-size: 12px; color: var(--text-secondary); margin-bottom: 12px; line-height: 1.5; }
.fb-types { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
.fb-type { padding: 6px 14px; border: 1px solid var(--border); border-radius: 16px; background: var(--bg-white); font-size: 13px; color: var(--text); cursor: pointer; transition: var(--transition); }
.fb-type:hover { border-color: var(--primary); color: var(--primary); }
.fb-type.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.fb-detail { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; font-family: inherit; line-height: 1.5; color: var(--text); outline: none; resize: vertical; margin-bottom: 12px; transition: border-color var(--transition); }
.fb-detail:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(15,76,117,0.1); }
.fb-submit { width: 100%; padding: 11px 20px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 600; cursor: pointer; transition: background var(--transition); }
.fb-submit:hover:not(:disabled) { background: var(--primary-dark); }
.fb-submit:disabled { opacity: 0.6; cursor: not-allowed; }
.fb-status { font-size: 13px; margin-top: 10px; min-height: 18px; text-align: center; }
.fb-status.ok { color: #16a34a; }
.fb-status.err { color: #dc2626; }
