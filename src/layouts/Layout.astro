---
interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = "/" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="EHS安全合规知识平台" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | EHS WiKi知识库</title>
  </head>
  <body>
    <!-- Navigation -->
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-logo">
          <span class="logo-icon">🛡</span>
          <span class="logo-text">EHS WiKi知识库</span>
        </a>
        <nav class="site-nav" id="siteNav">
          <a href="/ai-apps/" class={currentPath === '/ai-apps/' ? 'nav-link active' : 'nav-link'}>AI应用</a>
          <a href="/standards/" class={currentPath === '/standards/' ? 'nav-link active' : 'nav-link'}>国标地标</a>
          <a href="/regulations/" class={currentPath === '/regulations/' ? 'nav-link active' : 'nav-link'}>法规文件</a>
          <a href="/accidents/" class={currentPath === '/accidents/' ? 'nav-link active' : 'nav-link'}>事故报告</a>
          <a href="/documents/" class={currentPath === '/documents/' ? 'nav-link active' : 'nav-link'}>资料文档</a>
          <a href="/submit/" class={currentPath === '/submit/' ? 'nav-link active' : 'nav-link'}>同行投稿</a>
        </nav>
        <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="菜单">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-bottom">
          <p>EHS安全合规知识平台 · 汇聚行业同仁，共建安全知识库</p>
          <p class="footer-icp">
            <span id="busuanzi_container_site_pv">
              本站总访问量 <span id="busuanzi_value_site_pv"></span> 次
            </span>
            &nbsp;|&nbsp;
            <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">浙ICP备2026033883号-2</a>
          </p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Mobile menu toggle
      var mBtn = document.getElementById('mobileMenuBtn');
      var sNav = document.getElementById('siteNav');
      if (mBtn && sNav) {
        mBtn.addEventListener('click', function() {
          sNav.classList.toggle('mobile-open');
          mBtn.classList.toggle('open');
        });
      }
    </script>

    <script is:inline>
      // Page feedback
      (function() {
        var types = document.getElementById('fbTypes');
        var detail = document.getElementById('fbDetail');
        var submit = document.getElementById('fbSubmit');
        var status = document.getElementById('fbStatus');
        var selectedType = null;

        if (!types) return;

        types.addEventListener('click', function(e) {
          var btn = e.target.closest('.fb-type');
          if (!btn) return;
          var allBtns = types.querySelectorAll('.fb-type');
          for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
          btn.classList.add('active');
          selectedType = btn.dataset.type;
          status.textContent = '';
          status.className = 'fb-status';
        });

        submit.addEventListener('click', async function() {
          if (!selectedType) {
            status.textContent = '请先选择一个问题类型';
            status.className = 'fb-status err';
            return;
          }
          submit.disabled = true;
          submit.textContent = '提交中...';
          try {
            var res = await fetch('/feedback', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                type: selectedType,
                detail: detail.value.trim(),
                pageUrl: location.href,
                pageTitle: document.title
              })
            });
            var data = await res.json();
            if (res.ok && data.success) {
              status.textContent = '✓ 已收到，感谢你的反馈！';
              status.className = 'fb-status ok';
              detail.value = '';
              selectedType = null;
              var allBtns = types.querySelectorAll('.fb-type');
              for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
              setTimeout(function() {
                status.textContent = '';
                status.className = 'fb-status';
                submit.disabled = false;
                submit.textContent = '提交反馈';
              }, 2500);
            } else {
              throw new Error((data && data.error) || '提交失败');
            }
          } catch (err) {
            status.textContent = '提交失败，请稍后重试';
            status.className = 'fb-status err';
            submit.disabled = false;
            submit.textContent = '提交反馈';
          }
        });
      })();
    </script>

    <!-- 不蒜子统计延迟加载 -->
    <script is:inline>
      window.addEventListener('load', function() {
        setTimeout(function() {
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
          document.body.appendChild(s);
        }, 500);
      });
    </script>
  </body>
</html>

<style is:global>
:root {
    --primary: #1d4ed8;
    --primary-light: #3b82f6;
    --primary-lighter: #dbeafe;
    --primary-dark: #1e3a8a;
    --accent-red: #e63946;
    --accent-orange: #f59e0b;
    --accent-green: #16a34a;
    --accent-purple: #7c3aed;
    --accent-blue: #2563eb;
    --bg: #f1f5f9;
    --bg-white: #f8fafb;
    --card: #ffffff;
    --text: #1e293b;
    --text-secondary: #64748b;
    --text-light: #94a3b8;
    --border: #e2e8f0;
    --border-light: #f1f5f9;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.06);
    --shadow-md: 0 4px 6px rgba(0,0,0,0.04), 0 10px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 16px rgba(0,0,0,0.06), 0 16px 40px rgba(0,0,0,0.1);
    --radius-sm: 6px;
    --radius: 10px;
    --radius-lg: 14px;
    --container: 1200px;
    --header-h: 60px;
    --transition: all 0.2s ease;
    --tag-safety-bg: #dbeafe;
    --tag-safety-color: #1e40af;
    --tag-environment-bg: #d1fae5;
    --tag-environment-color: #065f46;
    --tag-occupational_health-bg: #fef3c7;
    --tag-occupational_health-color: #92400e;
    --tag-region-bg: #f3f4f6;
    --tag-region-color: #374151;
    --sev-general: #3b82f6;
    --sev-larger: #f59e0b;
    --sev-major: #ef4444;
    --sev-special: #7f1d1d;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: -apple-system, BlinkMacSystemFont, "SF Pro SC", "PingFang SC", "Microsoft YaHei UI", "Microsoft YaHei", "Noto Sans SC", sans-serif; color: var(--text); background: var(--bg); line-height: 1.75; -webkit-font-smoothing: antialiased; }
a { color: var(--primary); text-decoration: none; transition: var(--transition); }
a:hover { color: var(--primary-dark); }
img { max-width: 100%; height: auto; }
.container { max-width: var(--container); margin: 0 auto; padding: 0 24px; }

/* ── Header ── */
.site-header { max-width: var(--container); margin: 0 auto; background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%); color: #fff; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 8px rgba(0,0,0,0.15); height: var(--header-h); border-radius: 0 0 var(--radius-lg) var(--radius-lg); }
.header-inner { display: flex; align-items: center; justify-content: space-between; height: var(--header-h); padding: 0 24px; }
.site-logo { display: flex; align-items: center; gap: 10px; color: #fff; font-size: 18px; font-weight: 700; letter-spacing: -0.3px; flex-shrink: 0; }
.logo-icon { width: 34px; height: 34px; background: linear-gradient(135deg, var(--accent-red), var(--accent-orange)); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.site-nav { display: flex; gap: 4px; align-items: center; }
.nav-link { color: rgba(255,255,255,0.8); padding: 7px 14px; font-size: 13.5px; font-weight: 500; white-space: nowrap; position: relative; }
.nav-link::after { content: ''; position: absolute; bottom: 2px; left: 14px; right: 14px; height: 2px; background: #fff; border-radius: 1px; transform: scaleX(0); transition: transform 0.2s ease; }
.nav-link:hover { color: #fff; }
.nav-link:hover::after { transform: scaleX(1); }
.nav-link.active { color: #fff; }
.nav-link.active::after { transform: scaleX(1); }
.mobile-menu-btn { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; }
.mobile-menu-btn span { display: block; width: 20px; height: 2px; background: #fff; border-radius: 1px; transition: var(--transition); }

/* ── Stats Bar ── */
.stats-bar { background: var(--bg-white); max-width: var(--container); margin: 16px auto 0; padding: 16px; border-radius: var(--radius-lg); }
.stats-grid { display: grid; gap: 12px; }
.stats-grid-6 { grid-template-columns: repeat(6, 1fr); }
.stat-item { display: flex; flex-direction: column; align-items: center; color: var(--text); text-align: center; padding: 12px 8px; border-radius: var(--radius); transition: all var(--transition); background: var(--bg); }
.stat-item:hover { background: var(--primary-lighter); }
.stat-value { font-size: 16px; font-weight: 700; color: var(--primary); }
.stat-label { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }

/* ── Section ── */
.section { padding: 32px 0; }
.section-alt { background: var(--bg); }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.section-title { font-size: 18px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; }
.section-title:hover { color: var(--primary); }
.section-icon { width: 20px; height: 20px; color: var(--primary); }
.section-more { font-size: 13px; font-weight: 500; white-space: nowrap; color: var(--text-secondary); }
.section-more:hover { color: var(--primary); }

/* ── List Grid (2-column on homepage) ── */
.list-grid { display: flex; flex-direction: column; gap: 10px; }
.list-grid-2col { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.list-grid-3col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }

/* ── List Item (Card) ── */
.list-item { display: flex; align-items: center; padding: 14px 16px; background: var(--bg-white); border: 1px solid var(--border); border-radius: var(--radius); transition: box-shadow var(--transition), border-color var(--transition); color: inherit; border-left: 3px solid transparent; }
.list-item:hover { box-shadow: var(--shadow-md); border-color: var(--primary); border-left-color: var(--primary); }
.list-item-body { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.list-item-title { font-size: 15px; font-weight: 600; color: var(--text); line-height: 1.5; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; }
.list-item-no { font-weight: 400; color: var(--text-secondary); font-size: 12px; }
.list-item-meta-row { display: flex; flex-wrap: wrap; gap: 8px; font-size: 12px; color: var(--text-secondary); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.list-item-arrow { display: none; }

/* ── AI 卡片（首页最新 AI 应用专用）── */
.ai-card { display: flex; flex-direction: column; background: var(--bg-white); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; border-left: 3px solid transparent; transition: box-shadow var(--transition), border-color var(--transition); text-decoration: none; color: inherit; }
.ai-card:hover { box-shadow: var(--shadow-md); border-color: var(--primary); border-left-color: var(--primary); }
.ai-card .list-item-title { font-size: 14px; -webkit-line-clamp: 2; }
.ai-card .ai-desc { font-size: 12px; color: var(--text-light); margin-top: 6px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.std-tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
.std-tag-safety { background: #f3e8ff; color: #6b21a8; }
.std-tag-environment { background: var(--tag-environment-bg); color: var(--tag-environment-color); }
.std-tag-occupational_health { background: var(--tag-occupational_health-bg); color: var(--tag-occupational_health-color); }
.std-tag-region { background: var(--tag-region-bg); color: var(--tag-region-color); }
.std-tag-type-gb { background: #dbeafe; color: #1e40af; }
.std-tag-type-industry { background: #e0e7ff; color: #3730a3; }
.std-tag-type-local { background: #fce7f3; color: #9d174d; }
.acc-tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 12px; font-weight: 500; }
.acc-sev-general { background: #dbeafe; color: #1e40af; }
.acc-sev-larger { background: #fef3c7; color: #92400e; }
.acc-sev-major { background: #fee2e2; color: #dc2626; }
.acc-sev-special { background: #fecaca; color: #7f1d1d; }
.acc-tag-cat { background: #f3f4f6; color: #374151; }
.acc-tag-prov { background: #e0e7ff; color: #3730a3; }
.filter-bar { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
.filter-row { display: flex; gap: 72px; flex-wrap: wrap; }
.filter-group { display: flex; align-items: flex-start; gap: 8px; flex-wrap: nowrap; }
.filter-label { font-size: 13px; font-weight: 600; color: var(--text-secondary); white-space: nowrap; flex-shrink: 0; margin-top: 5px; }
.filter-tags { display: flex; gap: 6px; flex-wrap: wrap; flex: 1; min-width: 0; }
.filter-tag { padding: 4px 12px; border: 1px solid var(--border); border-radius: 16px; background: var(--bg-white); font-size: 13px; color: var(--text); cursor: pointer; transition: var(--transition); }
.filter-tag:hover { border-color: var(--primary); color: var(--primary); }
.filter-tag.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.search-box { display: flex; gap: 8px; }
.search-box input { flex: 1; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 14px; outline: none; transition: border-color var(--transition); }
.search-box input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
.search-box button { padding: 10px 20px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 500; cursor: pointer; transition: background var(--transition); }
.search-box button:hover { background: var(--primary-dark); }
.pagination-bar { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 16px 0; font-size: 13px; color: var(--text-secondary); flex-wrap: wrap; }
.pagination-controls { display: flex; gap: 4px; align-items: center; }
.pagination-controls button { padding: 6px 12px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg-white); cursor: pointer; font-size: 13px; transition: var(--transition); }
.pagination-controls button.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.pagination-controls button:hover:not(.active) { border-color: var(--primary); }
.pagination-controls button:disabled { opacity: 0.5; cursor: not-allowed; }
.page-ellipsis { padding: 0 4px; }

/* ── Detail Page ── */
.detail-breadcrumb-flat { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; padding-top: 20px; }
.detail-container { max-width: var(--container); }
@media (max-width: 1024px) { .detail-container { max-width: var(--container); } }

/* ── List Page ── */
.page-layout { padding: 24px 0 60px; }
.page-title { font-size: 22px; font-weight: 700; margin-bottom: 20px; }
.detail-breadcrumb-flat a { color: var(--text-secondary); }
.detail-breadcrumb-flat a:hover { color: var(--primary); }
.detail-title-flat { font-size: 24px; font-weight: 700; margin-bottom: 20px; line-height: 1.4; text-align: center; }
.detail-body { min-height: 200px; display: flex; flex-direction: column; align-items: center; }
.detail-section { margin-bottom: 24px; width: 100%; background: var(--bg-white); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; box-shadow: var(--shadow-sm); box-sizing: border-box; }
.detail-section-title { font-size: 16px; font-weight: 700; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 2px solid var(--border); color: var(--text); display: flex; align-items: center; gap: 8px; }
.detail-section-content { text-align: left; }
.detail-text { font-size: 15px; line-height: 1.8; color: var(--text); }
.detail-text p { margin-bottom: 12px; }
.detail-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.detail-action-btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 500; cursor: pointer; transition: background var(--transition); }
.detail-action-btn:hover { background: var(--primary-dark); color: #fff; }
.detail-empty { color: var(--text-light); font-size: 14px; }
.detail-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.loading, .empty { color: var(--text-light); font-size: 14px; padding: 40px 0; text-align: center; }
.info-card-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
.info-card-item { display: flex; flex-direction: column; padding: 12px 16px; background: var(--bg-white); border-radius: var(--radius); border: 1px solid var(--border-light); }
.info-card-label { font-size: 12px; color: var(--text-light); margin-bottom: 4px; }
.info-card-value { font-size: 14px; font-weight: 500; color: var(--text); }
.detail-info-table { width: 100%; border-collapse: collapse; }
.detail-info-table td { padding: 10px 16px; border-bottom: 1px solid var(--border-light); font-size: 14px; }
.detail-info-table .info-label { font-weight: 600; color: var(--text-secondary); width: 120px; white-space: nowrap; }
.detail-info-table .info-value { color: var(--text); }
.regulation-full-text { font-size: 15px; line-height: 1.8; white-space: pre-wrap; word-break: break-word; max-width: 800px; }
.detail-video-wrap { position: relative; width: 100%; padding-bottom: 56.25%; border-radius: var(--radius-lg); overflow: hidden; }
.detail-video-wrap iframe, .detail-video-wrap video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.page-comment { margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--border); }

/* ── Footer ── */
.site-footer { background: var(--bg-white); border-top: 1px solid var(--border); padding: 20px 0; margin-top: 48px; }
.footer-bottom { display: flex; align-items: center; justify-content: center; gap: 16px; flex-wrap: wrap; font-size: 12px; color: var(--text-light); }
.footer-icp { font-size: 12px; color: var(--text-light); }
.footer-icp a { color: var(--text-light); }
.footer-icp a:hover { color: var(--primary); }

/* ── Feedback (matches section card style) ── */
.fb-box { margin-top: 24px; padding: 24px; background: var(--bg-white); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); width: 100%; box-sizing: border-box; }
.fb-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
.fb-sub { font-size: 12px; color: var(--text-secondary); margin-bottom: 12px; line-height: 1.5; }
.fb-types { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
.fb-type { padding: 6px 14px; border: 1px solid var(--border); border-radius: 16px; background: var(--bg-white); font-size: 13px; color: var(--text); cursor: pointer; transition: var(--transition); }
.fb-type:hover { border-color: var(--primary); color: var(--primary); }
.fb-type.active { background: var(--primary); color: #fff; border-color: var(--primary); }
.fb-detail { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; font-family: inherit; line-height: 1.5; color: var(--text); outline: none; resize: vertical; margin-bottom: 12px; transition: border-color var(--transition); box-sizing: border-box; }
.fb-detail:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
.fb-submit { width: 100%; padding: 11px 20px; background: var(--primary); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 600; cursor: pointer; transition: background var(--transition); }
.fb-submit:hover:not(:disabled) { background: var(--primary-dark); }
.fb-submit:disabled { opacity: 0.6; cursor: not-allowed; }
.fb-status { font-size: 13px; margin-top: 10px; min-height: 18px; text-align: center; }
.fb-status.ok { color: #16a34a; }
.fb-status.err { color: #dc2626; }

@media (max-width: 768px) {
.container { padding: 0 16px; }
.page-feedback { padding: 0 16px; }
.site-nav { display: none; position: absolute; top: var(--header-h); left: 0; right: 0; background: var(--primary-dark); flex-direction: column; padding: 16px; border-bottom: 1px solid rgba(255,255,255,0.1); box-shadow: var(--shadow-md); }
.site-nav.mobile-open { display: flex; }
.mobile-menu-btn { display: flex; }
.stats-grid-6 { grid-template-columns: repeat(3, 1fr); }
.list-grid-2col { grid-template-columns: 1fr; }
.list-grid-3col { grid-template-columns: 1fr; }
.list-item { padding: 12px 16px; }
.list-item-title { font-size: 14px; }
.detail-title-flat { font-size: 20px; }
.info-card-list { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
.stats-grid-6 { grid-template-columns: repeat(2, 1fr); }
}
</style>