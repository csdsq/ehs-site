---
import Layout from '../layouts/Layout.astro';
---
<Layout title="首页" currentPath="/">

  <!-- Stats Bar -->
  <div class="stats-bar">
    <div class="stats-grid stats-grid-6">
      <div class="stat-item"><span class="stat-value" id="stat-ai">--</span><span class="stat-label">AI应用</span></div>
      <div class="stat-item"><span class="stat-value" id="stat-laws">--</span><span class="stat-label">法律法规</span></div>
      <div class="stat-item"><span class="stat-value" id="stat-standards">--</span><span class="stat-label">规范文件</span></div>
      <div class="stat-item"><span class="stat-value" id="stat-accs">--</span><span class="stat-label">事故报告</span></div>
      <div class="stat-item"><span class="stat-value" id="stat-videos">--</span><span class="stat-label">视频课堂</span></div>
      <div class="stat-item"><span class="stat-value" id="stat-docs">--</span><span class="stat-label">资料中心</span></div>
    </div>
  </div>

  <!-- Latest AI Apps -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">🤖 最新AI应用</h2>
        <a href="/ai-apps/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid" id="home-ai-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Regulations -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">⚖️ 最新法律法规</h2>
        <a href="/regulations/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid" id="home-laws-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Standards -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">📋 最新规范文件</h2>
        <a href="/standards/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid" id="home-standards-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Accidents -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">⚠️ 最新事故报告</h2>
        <a href="/accidents/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid" id="home-accs-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Videos -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">🎬 最新视频课堂</h2>
        <a href="/videos/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid" id="home-videos-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Documents -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">📁 最新资料中心</h2>
        <a href="/documents/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid" id="home-docs-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <script>
    const API = '/api';

    async function safeFetch(url) {
      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return await res.json();
      } catch (e) {
        console.warn('Fetch failed:', url, e);
        return null;
      }
    }

    function renderListItem(item, iconClass, defaultIcon, hrefPrefix) {
      const desc = item.description || item.summary || item.content?.slice(0, 60) || '';
      return `
        <a href="${hrefPrefix}${item.slug || item.id}" class="list-item">
          <div class="list-item-icon ${iconClass}">${item.icon || defaultIcon}</div>
          <div class="list-item-body">
            <div class="list-item-title">${item.title || item.question || ''}</div>
            <div class="list-item-desc">${desc}</div>
          </div>
          <div class="list-item-arrow">&rarr;</div>
        </a>`;
    }

    async function loadAll() {
      const [aiApps, regs, standards, accs, videos, docs] = await Promise.all([
        safeFetch(`${API}/ai-apps?pagination[pageSize]=5&sort=createdAt:desc`),
        safeFetch(`${API}/regulations?pagination[pageSize]=5&sort=publishDate:desc`),
        safeFetch(`${API}/standards?pagination[pageSize]=5&sort=publishDate:desc`),
        safeFetch(`${API}/accidents?pagination[pageSize]=5&sort=date:desc`),
        safeFetch(`${API}/videos?pagination[pageSize]=5&sort=createdAt:desc`),
        safeFetch(`${API}/documents?pagination[pageSize]=5&sort=createdAt:desc`),
      ]);

      // Stats
      const s = (el, data) => { const e = document.getElementById(el); if (e) e.textContent = data?.meta?.pagination?.total ?? '0'; };
      s('stat-ai', aiApps);
      s('stat-laws', regs);
      s('stat-standards', standards);
      s('stat-accs', accs);
      s('stat-videos', videos);
      s('stat-docs', docs);

      // Render lists
      const render = (elId, data, iconClass, icon, href) => {
        const el = document.getElementById(elId);
        if (!el) return;
        const items = data?.data ?? [];
        el.innerHTML = items.length === 0
          ? '<div class="empty">暂无数据</div>'
          : items.map(item => renderListItem(item, iconClass, icon, href)).join('');
      };

      render('home-ai-list', aiApps, 'icon-ai', '🤖', '/ai-apps/');
      render('home-laws-list', regs, 'icon-law', '⚖️', '/regulations/');
      render('home-standards-list', standards, 'icon-standard', '📋', '/standards/');
      render('home-accs-list', accs, 'icon-accident', '⚠️', '/accidents/');
      render('home-videos-list', videos, 'icon-video', '🎬', '/videos/');
      render('home-docs-list', docs, 'icon-doc', '📁', '/documents/');
    }

    loadAll();
  </script>
</Layout>
