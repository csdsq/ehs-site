---
import Layout from '../layouts/Layout.astro';
---
<Layout title="首页" currentPath="/">

  <!-- Stats Bar -->
  <div class="stats-bar">
    <div class="stats-grid stats-grid-6">
      <a href="/ai-apps/" class="stat-item"><span class="stat-value" id="stat-ai">--</span><span class="stat-label">AI应用</span></a>
      <a href="/regulations/" class="stat-item"><span class="stat-value" id="stat-laws">--</span><span class="stat-label">法律法规</span></a>
      <a href="/standards/" class="stat-item"><span class="stat-value" id="stat-standards">--</span><span class="stat-label">规范文件</span></a>
      <a href="/accidents/" class="stat-item"><span class="stat-value" id="stat-accs">--</span><span class="stat-label">事故报告</span></a>
      <a href="/videos/" class="stat-item"><span class="stat-value" id="stat-videos">--</span><span class="stat-label">视频课堂</span></a>
      <a href="/documents/" class="stat-item"><span class="stat-value" id="stat-docs">--</span><span class="stat-label">资料中心</span></a>
    </div>
  </div>

  <!-- Latest AI Apps -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新AI应用</h2>
        <a href="/ai-apps/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid list-grid-2col" id="home-ai-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Regulations -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新法律法规</h2>
        <a href="/regulations/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid list-grid-2col" id="home-laws-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Standards -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新规范文件</h2>
        <a href="/standards/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid list-grid-2col" id="home-standards-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Accidents -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新事故报告</h2>
        <a href="/accidents/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid list-grid-2col" id="home-accs-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Videos -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新视频课堂</h2>
        <a href="/videos/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="video-grid video-grid-3col" id="home-videos-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <!-- Latest Documents -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">最新资料中心</h2>
        <a href="/documents/" class="section-more">查看全部 &rarr;</a>
      </div>
      <div class="list-grid list-grid-2col" id="home-docs-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </section>

  <script>
    const API = 'https://api.hser.ren';

    async function safeFetch(url) {
      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return await res.json();
      } catch (e) {
        console.warn('Fetch failed:', url, e);
        return null;
      }
    }

    function renderListItem(item, hrefPrefix, type) {
      const title = item.title || '';
      const desc = item.description || item.summary || '';
      const standardNo = item.standardNo || '';
      const publishDate = item.publishDate || '';
      const effectiveDate = item.effectiveDate || '';

      // 法规类型：标题后加标准号，小字显示日期
      if (type === 'regulation') {
        return `
          <a href="${hrefPrefix}${item.slug || item.id}" class="list-item">
            <div class="list-item-body">
              <div class="list-item-title">${title}${standardNo ? ` <span class="list-item-no">${standardNo}</span>` : ''}</div>
              <div class="list-item-meta-row">
                ${publishDate ? `<span>发布：${publishDate}</span>` : ''}
                ${effectiveDate ? `<span>实施：${effectiveDate}</span>` : ''}
              </div>
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }

      // 规范文件类型：标题下小字显示发文机构、发文号、实施/发文日期
      if (type === 'standard') {
        const source = item.source || '';
        const stdNo = item.standardNo || '';
        const dateLabel = item.effectiveDate ? '实施日期' : '发文日期';
        const dateValue = item.effectiveDate || item.publishDate || '';
        return `
          <a href="${hrefPrefix}${item.slug || item.id}" class="list-item">
            <div class="list-item-body">
              <div class="list-item-title">${title}</div>
              <div class="list-item-meta-row">
                ${source ? `<span>发文机构：${source}</span>` : ''}
                ${stdNo ? `<span>发文号：${stdNo}</span>` : ''}
                ${dateValue ? `<span>${dateLabel}：${dateValue}</span>` : ''}
              </div>
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }

      // 事故类型：标题下小字显示发生日期、事故类型、事故等级
      if (type === 'accident') {
        const category = item.category || '';
        const severity = item.severity || '';
        const date = item.date || '';
        return `
          <a href="${hrefPrefix}${item.slug || item.id}" class="list-item">
            <div class="list-item-body">
              <div class="list-item-title">${title}</div>
              <div class="list-item-meta-row">
                ${date ? `<span>发生日期：${date}</span>` : ''}
                ${category ? `<span>事故类型：${category}</span>` : ''}
                ${severity ? `<span>事故等级：${severity}</span>` : ''}
              </div>
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }

      return `
        <a href="${hrefPrefix}${item.slug || item.id}" class="list-item">
          <div class="list-item-body">
            <div class="list-item-title">${title}</div>
            ${desc ? `<div class="list-item-desc">${desc.length > 80 ? desc.slice(0,80) + '...' : desc}</div>` : ''}
          </div>
          <div class="list-item-arrow">&rarr;</div>
        </a>`;
    }

    function renderVideoCard(item) {
      const title = item.title || '';
      const desc = item.description || '';
      const videoUrl = item.videoUrl || item.url || '';
      const duration = item.duration || '';
      
      // Extract YouTube/Bilibili thumbnail or use placeholder
      let thumbSrc = '';
      if (videoUrl.includes('bilibili.com/video/')) {
        const bv = videoUrl.match(/BV[a-zA-Z0-9]+/);
        thumbSrc = bv ? `https://i0.hdslb.com/bfs/archive/${bv[0]}s.jpg` : '';
      } else if (videoUrl.includes('youtube.com/watch')) {
        const vid = new URL(videoUrl).searchParams.get('v');
        thumbSrc = vid ? `https://img.youtube.com/vi/${vid}/mqdefault.jpg` : '';
      }

      return `
        <a href="/videos/${item.slug || item.id}" class="video-card">
          <div class="video-card-thumb">
            ${thumbSrc 
              ? `<img src="${thumbSrc}" alt="${title}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                 <div class="video-card-placeholder" style="display:none"><svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>`
              : `<div class="video-card-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>`
            }
            ${duration ? `<span class="video-card-duration">${duration}</span>` : ''}
            <div class="video-card-play">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="video-card-info">
            <div class="video-card-title">${title}</div>
            ${desc ? `<div class="video-card-desc">${desc.length > 60 ? desc.slice(0,60) + '...' : desc}</div>` : ''}
          </div>
        </a>`;
    }

    async function loadAll() {
      const [aiApps, regs, standards, accs, videos, docs] = await Promise.all([
        safeFetch(`${API}/ai-apps?pagination[pageSize]=6&sort=createdAt:desc`),
        safeFetch(`${API}/regulations?pagination[pageSize]=6&sort=publishDate:desc`),
        safeFetch(`${API}/standards?pagination[pageSize]=6&sort=publishDate:desc`),
        safeFetch(`${API}/accidents?pagination[pageSize]=6&sort=date:desc`),
        safeFetch(`${API}/videos?pagination[pageSize]=3&sort=createdAt:desc`),
        safeFetch(`${API}/documents?pagination[pageSize]=6&sort=createdAt:desc`),
      ]);

      // Stats
      const s = (el, data) => { const e = document.getElementById(el); if (e) e.textContent = data?.meta?.pagination?.total ?? '0'; };
      s('stat-ai', aiApps);
      s('stat-laws', regs);
      s('stat-standards', standards);
      s('stat-accs', accs);
      s('stat-videos', videos);
      s('stat-docs', docs);

      // Render lists (non-video modules)
      const renderList = (elId, data, href, type) => {
        const el = document.getElementById(elId);
        if (!el) return;
        const items = data?.data ?? [];
        el.innerHTML = items.length === 0
          ? '<div class="empty">暂无数据</div>'
          : items.map(item => renderListItem(item, href, type)).join('');
      };

      renderList('home-ai-list', aiApps, '/ai-apps/');
      renderList('home-laws-list', regs, '/regulations/', 'regulation');
      renderList('home-standards-list', standards, '/standards/', 'standard');
      renderList('home-accs-list', accs, '/accidents/', 'accident');
      renderList('home-docs-list', docs, '/documents/');

      // Render video cards
      const videoEl = document.getElementById('home-videos-list');
      if (videoEl) {
        const videoItems = videos?.data ?? [];
        videoEl.innerHTML = videoItems.length === 0
          ? '<div class="empty">暂无视频</div>'
          : videoItems.map(item => renderVideoCard(item)).join('');
      }
    }

    loadAll();
  </script>
</Layout>
