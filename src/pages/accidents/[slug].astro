---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const dataPath = path.join(process.cwd(), 'public/data/accidents.json');
  let items = [];
  try {
    items = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  } catch (e) {
    console.warn('⚠️ accidents.json not found for getStaticPaths');
  }
  return items.map(item => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;
---
<Layout title="事故报告详情" currentPath="/accidents/">
  <div class="container detail-container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/accidents/">事故报告</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    </div>

  <script is:inline define:vars={{ slug }}>
    const STRAPI_PROXY = '/sapi';
    const STATIC_DATA_URL = '/data/accidents.json';
    const CACHE_KEY = 'acc_detail_' + slug;
    const CACHE_TTL = 30 * 60 * 1000;

    function proxyFileUrl(url) {
      if (!url) return '';
      return url.replace('https://api.hser.ren/uploads/', '/suploads/');
    }

    async function fetchBySlugApi(collection, slug) {
      var params = new URLSearchParams();
      params.set('filters[slug][$eq]', slug);
      params.set('populate', '*');
      var url = STRAPI_PROXY + '/' + collection + '?' + params.toString();
      var controller = new AbortController();
      var timer = setTimeout(function() { controller.abort(); }, 5000);
      try {
        var res = await fetch(url, { signal: controller.signal });
        if (!res.ok) return null;
        var json = await res.json();
        return json.data && json.data.length > 0 ? json.data[0] : null;
      } catch(e) {
        return null;
      } finally {
        clearTimeout(timer);
      }
    }

    async function findInFullJson(url, slug) {
      try {
        var res = await fetch(url);
        if (!res.ok) return null;
        var all = await res.json();
        return all.find(function(i) { return i.slug === slug; }) || null;
      } catch(e) {
        return null;
      }
    }

    async function loadDetail() {
      var cached = localStorage.getItem(CACHE_KEY);
      var cachedAt = localStorage.getItem(CACHE_KEY + '_ts');
      if (cached && cachedAt && Date.now() - parseInt(cachedAt) < CACHE_TTL) {
        renderItem(JSON.parse(cached));
        return;
      }
      try {
        var item = await fetchBySlugApi('accidents', slug);
        if (!item) {
          item = await findInFullJson(STATIC_DATA_URL, slug);
        }
        if (item) {
          localStorage.setItem(CACHE_KEY, JSON.stringify(item));
          localStorage.setItem(CACHE_KEY + '_ts', String(Date.now()));
          renderItem(item);
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该事故报告</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function cleanCasualties(c) {
      if (!c || c === '-' || ['待官方公布','未知','待确认','待从完整报告获取'].indexOf(c.trim()) >= 0) return c;
      if (/(无人员伤亡|无人员死亡|0人死亡|未造成人员伤亡)/.test(c)) return c.trim();
      var parts = [];
      var deathMatch = c.match(/(\d+)人死亡/);
      if (deathMatch) parts.push(deathMatch[1] + '人死亡');
      var injuryMatch = c.match(/(\d+)人[受重轻]伤/);
      if (injuryMatch) parts.push(injuryMatch[1] + '人受伤');
      return parts.length > 0 ? parts.join('，') : c;
    }

    /**
     * 格式化详情文本内容：
     * - 如果包含 HTML 标签，直接返回原内容（用于 innerHTML）
     * - 如果是纯文本，按空行分段并包裹 <p> 标签
     * - 子标题自动加粗（如 "事故经过："、"直接原因：" 等）
     */
    function formatDetailText(text) {
      if (!text) return '';
      // 含 HTML 标签 → 直接返回
      if (/<[^>]+>/.test(text)) return text;
      // 纯文本 → 按段落拆分
      var paragraphs = text.split(/\n\s*\n/);
      var result = '';
      for (var i = 0; i < paragraphs.length; i++) {
        var p = paragraphs[i].trim();
        if (!p) continue;
        // 子标题加粗
        p = p.replace(/^(事故经过|事故直接原因|应急处置|直接原因|间接原因|事故原因)[：:]/, '<strong>$1：</strong>');
        result += '<p>' + p + '</p>';
      }
      return result;
    }

    /**
     * 清洗事故经过（content 字段）：
     * - 去掉"事故直接原因"和"应急处置"开头的段落（已在其他模块中）
     * - 去掉"事故经过："前缀（模块标题已体现）
     * - 只保留事故经过的叙事内容
     * - 适用于所有事故详情页
     */
    function cleanAccidentContent(text) {
      if (!text) return '';
      if (/<[^>]+>/.test(text)) return text;
      // 按段落拆分
      var paragraphs = text.split(/\n\s*\n/);
      var result = '';
      for (var i = 0; i < paragraphs.length; i++) {
        var p = paragraphs[i].trim();
        if (!p) continue;
        // 跳过"事故直接原因"和"应急处置"段落（已在其他模块中）
        if (/^事故直接原因[：:]/.test(p)) continue;
        if (/^应急处置[：:]/.test(p)) continue;
        // 去掉"事故经过："前缀（模块标题已有）
        p = p.replace(/^事故经过[：:]/, '');
        p = p.trim();
        if (!p) continue;
        result += '<p>' + p + '</p>';
      }
      return result;
    }

    function normalizeProvince(item) {
      var p = item.province;
      var provinceNormalize = {
        '北京市': '北京', '上海市': '上海', '天津市': '天津', '重庆市': '重庆',
        '广西壮族自治区': '广西', '昆明市': '云南'
      };
      if (!p) {
        var inferred = inferProvinceFromLocation(item.location, item.title);
        return inferred || p;
      }
      if (provinceNormalize[p]) return provinceNormalize[p];
      if (p.endsWith('省')) return p.slice(0, -1);
      if (p.endsWith('市') && !provinceNormalize[p]) return p.slice(0, -1);
      return p;
    }

    function inferProvinceFromLocation(location, title) {
      var text = (location || title || '');
      if (!text) return null;
      var cityToProvince = {
        '深圳':'广东','广州':'广东','保定':'河北','唐山':'河北','秦皇岛':'河北',
        '石家庄':'河北','廊坊':'河北','沧州':'河北','张家口':'河北','邯郸':'河北',
        '邢台':'河北','衡水':'河北','承德':'河北',
        '福州':'福建','厦门':'福建','泉州':'福建','长乐':'福建',
        '杭州':'浙江','宁波':'浙江','温州':'浙江','长沙':'湖南',
        '海口':'海南','沈阳':'辽宁','大连':'辽宁','济南':'山东',
        '太原':'山西','南昌':'江西','成都':'四川','贵阳':'贵州',
        '郑州':'河南','武汉':'湖北','合肥':'安徽','昆明':'云南',
        '南京':'江苏','南宁':'广西','桂林':'广西'
      };
      var m = text.match(/([^\s，,\d]+?)市/);
      if (m && cityToProvince[m[1]]) return cityToProvince[m[1]];
      var provinceNames = ['河北','福建','广东','浙江','湖南','海南','辽宁','山东',
        '山西','江西','四川','贵州','河南','湖北','安徽','云南','江苏','广西'];
      for (var i = 0; i < provinceNames.length; i++) {
        if (text.indexOf(provinceNames[i]) !== -1) return provinceNames[i];
      }
      return null;
    }

    function renderItem(item) {
      // 省份归一化
      var normalizedProvince = normalizeProvince(item);
      if (normalizedProvince !== item.province) {
        item = { ...item, province: normalizedProvince };
      }

      var severityMap = { general: '一般', minor: '一般', larger: '较大', major: '重大', special: '特别重大' };
      var categoryMap = {
        suffocation: '窒息', fall: '高处坠落', gas_leak: '燃气泄漏',
        traffic: '交通', poisoning_suffocation: '中毒窒息',
        falling_object: '物体打击', collapse: '坍塌', crane: '起重伤害',
        other_injury: '其他伤害', fire: '火灾', explosion: '爆炸',
        electric_shock: '触电', mechanical: '机械伤害', drowning: '淹溺'
      };
      var sevClassMap = { general: 'acc-sev-general', minor: 'acc-sev-general', larger: 'acc-sev-larger', major: 'acc-sev-major', special: 'acc-sev-special' };
      var sevLabel = severityMap[item.severity] || item.severity || '';
      var catLabel = categoryMap[item.category] || item.category || '';
      var provLabel = item.province || '';

      document.getElementById('detail-title').textContent = item.title || '';

      var infoRows = [
        ['事故名称', item.title],
        ['事故类型', catLabel || item.category],
        ['事故等级', sevLabel || item.severity],
        ['发生省份', provLabel || '-'],
        ['发生地点', item.location],
        ['发生时间', item.date],
        ['伤亡情况', cleanCasualties(item.casualties)],
        ['涉及企业', item.company],
        ['直接经济损失', item.economicLoss],
      ].filter(function(pair) { return pair[1] && pair[1] !== '-'; });

      var sectionsHtml = '';
      if (infoRows.length > 0) {
        sectionsHtml += '<section class="detail-section">' +
          '<h2 class="detail-section-title">基本信息</h2>' +
          '<div class="detail-section-content">' +
            '<table class="detail-info-table">' +
              infoRows.map(function(kv) { return '<tr><td class="info-label">' + kv[0] + '</td><td class="info-value">' + kv[1] + '</td></tr>'; }).join('') +
            '</table>' +
          '</div>' +
        '</section>';
      } else {
        sectionsHtml += '<section class="detail-section">' +
          '<h2 class="detail-section-title">基本信息</h2>' +
          '<div class="detail-section-content"><p class="detail-empty">暂无基本信息</p></div>' +
        '</section>';
      }
      sectionsHtml += '<section class="detail-section"><h2 class="detail-section-title">事故经过</h2><div class="detail-section-content">' +
        (item.content ? '<div class="detail-text">' + cleanAccidentContent(item.content) + '</div>' : '<p class="detail-empty">暂无事故经过</p>') +
      '</div></section>';
      sectionsHtml += '<section class="detail-section"><h2 class="detail-section-title">事故原因</h2><div class="detail-section-content">' +
        (item.causes ? '<div class="detail-text">' + formatDetailText(item.causes) + '</div>' : '<p class="detail-empty">暂无原因分析</p>') +
      '</div></section>';
      sectionsHtml += '<section class="detail-section"><h2 class="detail-section-title">改善措施</h2><div class="detail-section-content">' +
        (item.suggestions ? '<div class="detail-text">' + formatDetailText(item.suggestions) + '</div>' : '<p class="detail-empty">暂无改善措施</p>') +
      '</div></section>';
      sectionsHtml += '<section class="detail-section"><h2 class="detail-section-title">处理结果</h2><div class="detail-section-content">' +
        (item.personnelHandling ? '<div class="detail-text">' + formatDetailText(item.personnelHandling) + '</div>' : '<p class="detail-empty">暂无处理结果</p>') +
      '</div></section>';
      sectionsHtml += '<section class="detail-section"><h2 class="detail-section-title">报告原文</h2><div class="detail-section-content"><div class="detail-actions">';
      if (item.reportUrl || item.downloadUrl) {
        sectionsHtml += '<a href="' + proxyFileUrl(item.reportUrl || item.downloadUrl) + '" target="_blank" rel="noopener" class="detail-action-btn btn-preview">' +
          '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
          ' 查看原文</a>';
      } else if (item.content) {
        sectionsHtml += '<details class="detail-expand" open><summary>展开/收起报告全文</summary><div class="detail-expand-body">' + item.content + '</div></details>';
      } else {
        sectionsHtml += '<p class="detail-empty">暂无报告原文</p>';
      }
      sectionsHtml += '</div></div></section>';

      // 底部反馈面板（默认展开，在"查看原文"下方、评论区上方）
      sectionsHtml += '<div class="fb-box">' +
        '<div class="fb-title">📢 这条内容有问题？</div>' +
        '<div class="fb-sub">选择问题类型，点击即可提交（也可顺便补充说明）：</div>' +
        '<div class="fb-types" id="fbTypes">' +
          '<button type="button" class="fb-type" data-type="link_broken">链接失效</button>' +
          '<button type="button" class="fb-type" data-type="content_error">内容错误</button>' +
          '<button type="button" class="fb-type" data-type="wrong_category">分类/标签不对</button>' +
          '<button type="button" class="fb-type" data-type="duplicate">重复/多余</button>' +
          '<button type="button" class="fb-type" data-type="other">其他</button>' +
        '</div>' +
        '<textarea class="fb-detail" id="fbDetail" placeholder="补充说明（可选）：比如哪个链接打不开、哪里写错了..." rows="3"></textarea>' +
        '<button class="fb-submit" id="fbSubmit" type="button">提交反馈</button>' +
        '<div class="fb-status" id="fbStatus"></div>' +
      '</div>';

      document.getElementById('detail-body').innerHTML = sectionsHtml;
    }

    loadDetail();
  </script>

  <script is:inline>
    // 反馈面板交互（在 renderItem 动态渲染后绑定）
    (function() {
      function bindFeedback() {
        var types = document.getElementById('fbTypes');
        var detail = document.getElementById('fbDetail');
        var submit = document.getElementById('fbSubmit');
        var status = document.getElementById('fbStatus');
        if (!types || !submit) { setTimeout(bindFeedback, 200); return; }
        var selectedType = null;

        types.addEventListener('click', function(e) {
          var btn = e.target.closest('.fb-type');
          if (!btn) return;
          var allBtns = types.querySelectorAll('.fb-type');
          for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
          btn.classList.add('active');
          selectedType = btn.dataset.type;
          status.textContent = '';
          status.className = 'fb-status';
        });

        submit.addEventListener('click', async function() {
          if (!selectedType) {
            status.textContent = '请先选择一个问题类型';
            status.className = 'fb-status err';
            return;
          }
          submit.disabled = true;
          submit.textContent = '提交中...';
          try {
            var res = await fetch('/feedback', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                type: selectedType,
                detail: detail.value.trim(),
                pageUrl: location.href,
                pageTitle: document.title
              })
            });
            var data = await res.json();
            if (res.ok && data.success) {
              status.textContent = '✓ 已收到，感谢你的反馈！';
              status.className = 'fb-status ok';
              detail.value = '';
              selectedType = null;
              var allBtns = types.querySelectorAll('.fb-type');
              for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
              setTimeout(function() {
                status.textContent = '';
                status.className = 'fb-status';
                submit.disabled = false;
                submit.textContent = '提交反馈';
              }, 2500);
            } else {
              throw new Error((data && data.error) || '提交失败');
            }
          } catch (err) {
            status.textContent = '提交失败，请稍后重试';
            status.className = 'fb-status err';
            submit.disabled = false;
            submit.textContent = '提交反馈';
          }
        });
      }
      bindFeedback();
    })();
  </script>
</Layout>
