---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="事故报告" currentPath="/accidents/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">事故报告</h1>

      <!-- 筛选区 -->
      <div class="filter-bar" id="acc-filter-row1">
        <!-- 事故等级 -->
        <div class="filter-group">
          <span class="filter-label">等级</span>
          <div class="filter-tags" id="severity-tags"></div>
        </div>
        <!-- 事故类型 -->
        <div class="filter-group">
          <span class="filter-label">类型</span>
          <div class="filter-tags" id="category-tags"></div>
        </div>
      </div>

      <div class="search-box" style="margin-bottom: 24px; max-width: 100%;">
        <input type="text" id="acc-search" placeholder="搜索事故名称、地点..." />
        <button id="acc-search-btn">搜索</button>
      </div>

      <div id="acc-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="acc-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="acc-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script is:inline>
    var PREVIEW_URL = '/data/accidents-preview.json';
    var SUMMARY_FIELDS = ['title','slug','severity','category','province','date','casualties','location','company'];

    var SEVERITY_MAP = { general: '一般', minor: '一般', larger: '较大', major: '重大', special: '特别重大' };
    var SEVERITY_CLASS = { general: 'acc-sev-general', minor: 'acc-sev-general', larger: 'acc-sev-larger', major: 'acc-sev-major', special: 'acc-sev-special' };
    var CATEGORY_MAP = { suffocation: '窒息', fall: '高处坠落', gas_leak: '燃气泄漏', traffic: '交通', poisoning_suffocation: '中毒窒息', falling_object: '物体打击', collapse: '坍塌', crane: '起重伤害', other_injury: '其他伤害', fire: '火灾', explosion: '爆炸', electric_shock: '触电', mechanical: '机械伤害', drowning: '淹溺' };
    var SEVERITY_FILTERS = [
      { value: '', label: '全部' },
      { value: 'general', label: '一般' },
      { value: 'larger', label: '较大' },
      { value: 'major', label: '重大' },
      { value: 'special', label: '特别重大' },
    ];

    var allItems = [];
    var filteredItems = [];
    var currentPage = 1;
    var pageSize = 10;
    var activeSeverity = '';
    var activeCategory = '';

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function getSeverityClass(sev) {
      return SEVERITY_CLASS[sev] || 'acc-sev-general';
    }

    function getDetailLink(item) {
      return '/accidents/' + item.slug;
    }

    function renderItems(items) {
      var el = document.getElementById('acc-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      var html = '';
      for (var i = 0; i < items.length; i++) {
        var item = items[i];
        var sevLabel = SEVERITY_MAP[item.severity] || '';
        var catLabel = CATEGORY_MAP[item.category] || item.category || '';
        var provLabel = item.province || '';
        var metaItems = [];
        if (provLabel) metaItems.push('<span class="acc-tag acc-tag-prov">' + provLabel + '</span>');
        if (sevLabel) metaItems.push('<span class="acc-tag ' + getSeverityClass(item.severity) + '">' + sevLabel + '</span>');
        if (catLabel) metaItems.push('<span class="acc-tag acc-tag-cat">' + catLabel + '</span>');
        if (item.date) metaItems.push('<span>发生日期：' + item.date + '</span>');
        if (item.casualties) metaItems.push('<span>伤亡：' + item.casualties + '</span>');

        var detailUrl = getDetailLink(item);
        html += '<a href="' + detailUrl + '" class="list-item">'
          + '<div class="list-item-body">'
          + '<div class="list-item-title">' + (item.title || '') + '</div>'
          + '<div class="list-item-meta-row">' + metaItems.join('') + '</div>'
          + '</div>'
          + '</a>';
      }
      el.innerHTML = html;
    }

    function renderPagination() {
      var el = document.getElementById('acc-pagination');
      var total = filteredItems.length;
      var totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      var start = (currentPage - 1) * pageSize + 1;
      var end = Math.min(currentPage * pageSize, total);

      var pagesHtml = '';
      var range = [];
      if (totalPages <= 7) {
        for (var i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        var s = Math.max(2, currentPage - 2);
        var e = Math.min(totalPages - 1, currentPage + 2);
        for (var j = s; j <= e; j++) range.push(j);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (var k = 0; k < range.length; k++) {
        var p = range[k];
        if (p < 0) { pagesHtml += '<span class="page-ellipsis">…</span>'; }
        else { pagesHtml += '<button class="' + (p === currentPage ? 'active' : '') + '" data-page="' + p + '">' + p + '</button>'; }
      }

      el.innerHTML =
        '<div class="pagination-info">显示 ' + start + '-' + end + '，共 ' + total + ' 项</div>'
        + '<div class="pagination-controls">'
        + '<button data-action="prev"' + (currentPage === 1 ? ' disabled' : '') + '>上一页</button>'
        + pagesHtml
        + '<button data-action="next"' + (currentPage === totalPages ? ' disabled' : '') + '>下一页</button>'
        + '</div>'
        + '<div class="page-size-select">每页'
        + '<select id="acc-page-size">'
        + '<option value="10"' + (pageSize===10?' selected':'') + '>10</option>'
        + '<option value="20"' + (pageSize===20?' selected':'') + '>20</option>'
        + '<option value="50"' + (pageSize===50?' selected':'') + '>50</option>'
        + '<option value="100"' + (pageSize===100?' selected':'') + '>100</option>'
        + '</select>条</div>';

      el.querySelector('#acc-page-size').addEventListener('change', function(e) {
        pageSize = parseInt(e.target.value); currentPage = 1; updateView();
      });
      el.querySelectorAll('[data-page]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          currentPage = parseInt(btn.dataset.page);
          updateView();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
      el.querySelector('[data-action="prev"]').addEventListener('click', function() {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]').addEventListener('click', function() {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }

    function applyFilters() {
      var q = document.getElementById('acc-search').value.trim().toLowerCase();
      filteredItems = [];
      for (var fi = 0; fi < allItems.length; fi++) {
        var item = allItems[fi];
        if (activeSeverity && item.severity !== activeSeverity) continue;
        if (activeCategory && item.category !== activeCategory) continue;
        if (q) {
          var text = ((item.title || '') + ' ' + (item.location || '') + ' ' + (item.province || '') + ' ' + (item.casualties || '')).toLowerCase();
          if (text.indexOf(q) < 0) continue;
        }
        filteredItems.push(item);
      }
      currentPage = 1;
      updateView();
    }

    function updateView() {
      var start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('acc-count').textContent = '共 ' + filteredItems.length + ' 项'
        + (filteredItems.length !== allItems.length ? '（筛选自 ' + allItems.length + ' 项）' : '');
    }

    function normalizeProvince(item) {
      var provinceNormalize = {
        '北京市': '北京', '上海市': '上海', '天津市': '天津', '重庆市': '重庆'
      };
      if (item.province && provinceNormalize[item.province]) {
        return { ...item, province: provinceNormalize[item.province] };
      }
      return item;
    }

    // 从构建时生成的预览 JSON 加载数据（已含 YYMM-NNN 新 slug）
    function fetchPreview(url) {
      return fetch(url).then(function(res) { return res.json(); });
    }

    async function loadItems() {
      var listEl = document.getElementById('acc-list');
      try {
        allItems = (await fetchPreview(PREVIEW_URL)).map(normalizeProvince);
        filteredItems = allItems.slice();
        document.getElementById('acc-count').textContent = '共 ' + allItems.length + ' 项';
        buildSeverityFilters();
        buildCategoryFilters();
        updateView();
      } catch (e) {
        if (listEl) listEl.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function buildSeverityFilters() {
      var container = document.getElementById('severity-tags');
      container.innerHTML = '';
      for (var i = 0; i < SEVERITY_FILTERS.length; i++) {
        var opt = SEVERITY_FILTERS[i];
        var btn = document.createElement('button');
        btn.className = 'filter-tag' + (opt.value === activeSeverity || (!opt.value && !activeSeverity) ? ' active' : '');
        btn.textContent = opt.label;
        btn.addEventListener('click', function(val) {
          return function() {
            activeSeverity = val;
            container.querySelectorAll('.filter-tag').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            applyFilters();
          };
        }(opt.value));
        container.appendChild(btn);
      }
    }

    function buildCategoryFilters() {
      var container = document.getElementById('category-tags');
      container.innerHTML = '';
      var allBtn = document.createElement('button');
      allBtn.className = 'filter-tag active';
      allBtn.textContent = '全部';
      allBtn.addEventListener('click', function() {
        activeCategory = '';
        container.querySelectorAll('.filter-tag').forEach(function(b) { b.classList.remove('active'); });
        allBtn.classList.add('active');
        applyFilters();
      });
      container.appendChild(allBtn);
      for (var val in CATEGORY_MAP) {
        if (!CATEGORY_MAP.hasOwnProperty(val)) continue;
        var b = document.createElement('button');
        b.className = 'filter-tag';
        b.textContent = CATEGORY_MAP[val];
        b.addEventListener('click', function(v) {
          return function() {
            activeCategory = v;
            container.querySelectorAll('.filter-tag').forEach(function(bb) { bb.classList.remove('active'); });
            b.classList.add('active');
            applyFilters();
          };
        }(val));
        container.appendChild(b);
      }
    }

    document.getElementById('acc-search').addEventListener('input', applyFilters);
    document.getElementById('acc-search-btn').addEventListener('click', applyFilters);

    loadItems();
  </script>
</Layout>
