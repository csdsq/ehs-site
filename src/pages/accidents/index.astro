---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="事故报告" currentPath="/accidents/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">事故报告</h1>

      <!-- 筛选区 -->
      <div class="filter-bar filter-bar-row" id="acc-filter-row1">
        <!-- 事故等级 -->
        <div class="filter-group">
          <span class="filter-label">等级</span>
          <div class="filter-tags" id="severity-tags"></div>
        </div>
        <!-- 省份 -->
        <div class="filter-group" id="province-group">
          <span class="filter-label">省份</span>
          <div class="filter-tags" id="province-tags"></div>
        </div>
      </div>
      <div class="filter-bar" id="acc-filter-row2">
        <!-- 事故类型 -->
        <div class="filter-group">
          <span class="filter-label">类型</span>
          <div class="filter-tags" id="category-tags"></div>
        </div>
      </div>

      <div class="search-box" style="margin-bottom: 24px; max-width: 100%;">
        <input type="text" id="acc-search" placeholder="搜索事故名称、地点..." />
        <button id="acc-search-btn">搜索</button>
      </div>

      <div id="acc-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="acc-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="acc-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script>
    const API = 'https://api.hser.ren';
    const severityMap: Record<string,string> = { major: '特大', larger: '重大', general: '较大', minor: '一般' };
    const categoryMap: Record<string,string> = {
      suffocation: '窒息', fall: '高处坠落', gas_leak: '燃气泄漏',
      traffic: '交通', poisoning_suffocation: '中毒窒息',
      falling_object: '物体打击', collapse: '坍塌', crane: '起重伤害',
      fire: '火灾', explosion: '爆炸',
      electric_shock: '触电', mechanical: '机械伤害', drowning: '淹溺',
      other_injury: '其他伤害'
    };

    let allItems: any[] = [];
    let filteredItems: any[] = [];
    let currentPage = 1;
    let pageSize = 10;
    let activeSeverity = '';
    let activeCategory = '';
    let activeProvince = '';

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function getSeverityClass(sev: string): string {
      const map: Record<string,string> = { major: 'acc-sev-major', larger: 'acc-sev-larger', general: 'acc-sev-general', minor: 'acc-sev-minor' };
      return map[sev] || 'acc-sev-general';
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('acc-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => {
        const sevLabel = severityMap[item.severity] || '';
        const catLabel = categoryMap[item.category] || item.category || '';
        const provLabel = item.province || '';
        const metaItems = [];
        if (item.date) metaItems.push(`<span>发生日期：${item.date}</span>`);
        if (item.casualties) metaItems.push(`<span>伤亡：${item.casualties}</span>`);
        if (provLabel) metaItems.push(`<span class="acc-tag acc-tag-prov">${provLabel}</span>`);
        if (sevLabel) metaItems.push(`<span class="acc-tag ${getSeverityClass(item.severity)}">${sevLabel}</span>`);
        if (catLabel) metaItems.push(`<span class="acc-tag acc-tag-cat">${catLabel}</span>`);
        return `
          <a href="/accidents/${item.slug || item.id}" class="list-item">
            <div class="list-item-body">
              <div class="list-item-title">${item.title}</div>
              <div class="list-item-meta-row">
                ${metaItems.join('')}
              </div>
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }).join('');
    }

    function renderPagination() {
      const el = document.getElementById('acc-pagination')!;
      const total = filteredItems.length;
      const totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      const start = (currentPage - 1) * pageSize + 1;
      const end = Math.min(currentPage * pageSize, total);

      let pagesHtml = '';
      const range: number[] = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        const s = Math.max(2, currentPage - 2);
        const e = Math.min(totalPages - 1, currentPage + 2);
        for (let i = s; i <= e; i++) range.push(i);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (const p of range) {
        if (p < 0) { pagesHtml += `<span class="page-ellipsis">…</span>`; }
        else { pagesHtml += `<button class="${p === currentPage ? 'active' : ''}" data-page="${p}">${p}</button>`; }
      }

      el.innerHTML = `
        <div class="pagination-info">显示 ${start}-${end}，共 ${total} 项</div>
        <div class="pagination-controls">
          <button data-action="prev" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>
          ${pagesHtml}
          <button data-action="next" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>
        </div>
        <div class="page-size-select">
          每页
          <select id="acc-page-size">
            <option value="10" ${pageSize===10?'selected':''}>10</option>
            <option value="20" ${pageSize===20?'selected':''}>20</option>
            <option value="50" ${pageSize===50?'selected':''}>50</option>
            <option value="100" ${pageSize===100?'selected':''}>100</option>
          </select>
          条
        </div>`;

      el.querySelector('#acc-page-size')!.addEventListener('change', (e: any) => {
        pageSize = parseInt(e.target.value); currentPage = 1; updateView();
      });
      el.querySelectorAll('[data-page]').forEach(btn => {
        btn.addEventListener('click', () => { currentPage = parseInt((btn as HTMLElement).dataset.page!); updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
      });
      el.querySelector('[data-action="prev"]')!.addEventListener('click', () => {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]')!.addEventListener('click', () => {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }



    function applyFilters() {
      const q = (document.getElementById('acc-search') as HTMLInputElement).value.trim().toLowerCase();
      filteredItems = allItems.filter(item => {
        if (activeSeverity && item.severity !== activeSeverity) return false;
        if (activeCategory && item.category !== activeCategory) return false;
        if (activeProvince && item.province !== activeProvince) return false;
        if (q) {
          const text = `${item.title ?? ''} ${item.location ?? ''} ${item.province ?? ''} ${item.casualties ?? ''}`.toLowerCase();
          if (!text.includes(q)) return false;
        }
        return true;
      });
      currentPage = 1;
      updateView();
    }

    function updateView() {
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('acc-count')!.textContent = `共 ${filteredItems.length} 项${filteredItems.length !== allItems.length ? `（筛选自 ${allItems.length} 项）` : ''}`;
    }

    async function loadItems() {
      try {
        const res = await fetch(`${API}/accidents?pagination[pageSize]=200&sort=date:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        filteredItems = [...allItems];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('acc-count')!.textContent = `共 ${total} 项`;
        buildSeverityFilters();
        buildCategoryFilters();
        buildProvinceFilters();
        updateView();
      } catch (e) {
        document.getElementById('acc-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }


    function buildSeverityFilters() {
      const container = document.getElementById('severity-tags')!;
      container.innerHTML = '';
      const levels = [
        { value: 'major', label: '特大' },
        { value: 'larger', label: '重大' },
        { value: 'general', label: '较大' },
        { value: 'minor', label: '一般' },
      ];
      // "全部" button
      const allBtn = document.createElement('button');
      allBtn.className = 'filter-tag active';
      allBtn.textContent = '全部';
      allBtn.addEventListener('click', () => {
        activeSeverity = '';
        container.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
        allBtn.classList.add('active');
        applyFilters();
      });
      container.appendChild(allBtn);
      for (const lv of levels) {
        const btn = document.createElement('button');
        btn.className = 'filter-tag';
        btn.textContent = lv.label;
        btn.addEventListener('click', () => {
          activeSeverity = lv.value;
          container.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          applyFilters();
        });
        container.appendChild(btn);
      }
    }

    function buildCategoryFilters() {
      const container = document.getElementById('category-tags')!;
      container.innerHTML = '';
      container.classList.add('filter-tags-collapsible');
      const types = Object.entries(categoryMap) as [string, string][];
      // "全部" button
      const allBtn = document.createElement('button');
      allBtn.className = 'filter-tag active';
      allBtn.textContent = '全部';
      allBtn.addEventListener('click', () => {
        activeCategory = '';
        container.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
        allBtn.classList.add('active');
        applyFilters();
      });
      container.appendChild(allBtn);
      for (const [val, label] of types) {
        const btn = document.createElement('button');
        btn.className = 'filter-tag';
        btn.textContent = label;
        btn.addEventListener('click', () => {
          activeCategory = val;
          container.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          applyFilters();
        });
        container.appendChild(btn);
      }
      // "更多" toggle - check if content overflows
      requestAnimationFrame(() => {
        if (container.scrollHeight > container.clientHeight + 2) {
          const moreBtn = document.createElement('button');
          moreBtn.className = 'filter-tag filter-more-btn';
          moreBtn.textContent = '更多 ▼';
          let expanded = false;
          moreBtn.addEventListener('click', () => {
            expanded = !expanded;
            if (expanded) {
              container.classList.add('expanded');
              moreBtn.textContent = '收起 ▲';
            } else {
              container.classList.remove('expanded');
              moreBtn.textContent = '更多 ▼';
            }
          });
          container.appendChild(moreBtn);
        }
      });
    }

    function buildProvinceFilters() {
      const container = document.getElementById('province-tags')!;
      container.innerHTML = '';
      container.classList.add('filter-tags-collapsible');
      const provinces = [...new Set(allItems.map(i => i.province).filter(Boolean))].sort() as string[];
      // "全部" button
      const allBtn = document.createElement('button');
      allBtn.className = 'filter-tag active';
      allBtn.textContent = '全部';
      allBtn.addEventListener('click', () => {
        activeProvince = '';
        container.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
        allBtn.classList.add('active');
        applyFilters();
      });
      container.appendChild(allBtn);
      for (const prov of provinces) {
        const btn = document.createElement('button');
        btn.className = 'filter-tag';
        btn.textContent = prov;
        btn.addEventListener('click', () => {
          activeProvince = prov;
          container.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          applyFilters();
        });
        container.appendChild(btn);
      }
      // "更多" toggle - check if content overflows
      requestAnimationFrame(() => {
        if (container.scrollHeight > container.clientHeight + 2) {
          const moreBtn = document.createElement('button');
          moreBtn.className = 'filter-tag filter-more-btn';
          moreBtn.textContent = '更多 ▼';
          let expanded = false;
          moreBtn.addEventListener('click', () => {
            expanded = !expanded;
            if (expanded) {
              container.classList.add('expanded');
              moreBtn.textContent = '收起 ▲';
            } else {
              container.classList.remove('expanded');
              moreBtn.textContent = '更多 ▼';
            }
          });
          container.appendChild(moreBtn);
        }
      });
    }

    document.getElementById('acc-search')!.addEventListener('input', applyFilters);
    document.getElementById('acc-search-btn')!.addEventListener('click', applyFilters);

    loadItems();
  </script>
</Layout>
