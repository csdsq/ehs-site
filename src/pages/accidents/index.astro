---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="事故报告" currentPath="/accidents/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">事故报告</h1>
      <p class="page-description">收录各类生产安全事故调查报告，分析事故原因，总结经验教训，预防同类事故。</p>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="acc-search" placeholder="搜索事故名称、地点..." />
        <button id="acc-search-btn">搜索</button>
      </div>

      <div id="acc-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="acc-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </div>

  <script>
    const API = 'https://api.hser.ren';
    let allItems: any[] = [];

    async function loadItems() {
      try {
        const res = await fetch(`${API}/accidents?pagination[pageSize]=100&sort=date:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('acc-count')!.textContent = `共 ${total} 项`;
        renderItems(allItems);
      } catch (e) {
        document.getElementById('acc-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('acc-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => `
        <a href="/accidents/${item.slug || item.id}" class="list-item">
          <div class="list-item-body">
            <div class="list-item-title">${item.title}</div>
            ${item.description || `${item.severity || ""} ${item.location || ""} ${item.date || ""}`.trim() ? `<div class="list-item-desc">${item.description || `${item.severity || ""} ${item.location || ""} ${item.date || ""}`.trim()}</div>` : ""}
          </div>
          <div class="list-item-arrow">&rarr;</div>
        </a>`).join('');
    }

    function doSearch() {
      const q = (document.getElementById('acc-search') as HTMLInputElement).value.trim().toLowerCase();
      if (!q) { renderItems(allItems); return; }
      renderItems(allItems.filter(item =>
        (item.title ?? '').toLowerCase().includes(q) ||
        (item.location ?? '').toLowerCase().includes(q) ||
        (item.severity ?? '').toLowerCase().includes(q)
      ));
    }

    document.getElementById('acc-search')!.addEventListener('input', doSearch);
    document.getElementById('acc-search-btn')!.addEventListener('click', doSearch);

    loadItems();
  </script>
</Layout>
