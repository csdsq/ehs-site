---
import Layout from '../../../layouts/Layout.astro';
import PageComment from '../../../components/PageComment.astro';

export async function getStaticPaths() {
  try {
    const pageSize = 100;
    let allItems = [];
    let page = 1;
    while (true) {
      const res = await fetch(`https://api.hser.ren/accidents?pagination[pageSize]=${pageSize}&pagination[page]=${page}&fields[0]=slug`);
      const json = await res.json();
      const items = json.data || [];
      allItems = allItems.concat(items);
      if (items.length < pageSize) break;
      page++;
    }
    return allItems.map(item => ({ params: { slug: item.slug || String(item.id) } }));
  } catch (e) { return []; }
}
}

const { slug } = Astro.params;
---
<Layout title="事故报告详情" currentPath="/accidents/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/accidents/">事故报告</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div id="detail-tags" style="margin-bottom: 16px;"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    <PageComment pageUrl={`/accidents/${slug}`} />
  </div>

  <script define:vars={{ slug }}>
    const API = 'https://api.hser.ren';
    async function loadDetail() {
      try {
        let res = await fetch(`${API}/accidents?filters[slug][$eq]=${slug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/accidents/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          document.getElementById('detail-title').textContent = item.title || '';

          // 映射标签
          const severityMap = { major: '特大', larger: '重大', general: '较大', minor: '一般' };
          const categoryMap = {
            suffocation: '窒息', fall: '高处坠落', gas_leak: '燃气泄漏',
            traffic: '交通', poisoning_suffocation: '中毒窒息',
            falling_object: '物体打击', collapse: '坍塌', crane: '起重伤害',
            other_injury: '其他伤害', fire: '火灾', explosion: '爆炸',
            electric_shock: '触电', mechanical: '机械伤害', drowning: '淹溺'
          };
          const sevClassMap = { major: 'acc-sev-major', larger: 'acc-sev-larger', general: 'acc-sev-general', minor: 'acc-sev-minor' };
          const sevLabel = severityMap[item.severity] || item.severity || '';
          const catLabel = categoryMap[item.category] || item.category || '';
          const provLabel = item.province || '';
          const tags = [];
          if (sevLabel) tags.push(`<span class="acc-tag ${sevClassMap[item.severity] || 'acc-sev-general'}">${sevLabel}</span>`);
          if (catLabel) tags.push(`<span class="acc-tag acc-tag-cat">${catLabel}</span>`);
          if (provLabel) tags.push(`<span class="acc-tag acc-tag-prov">${provLabel}</span>`);
          document.getElementById('detail-tags').innerHTML = tags.join(' ');

          // 基本信息表格
          const infoRows = [
            ['事故名称', item.title],
            ['事故类型', catLabel || item.category],
            ['事故等级', sevLabel || item.severity],
            ['发生省份', provLabel || '-'],
            ['发生地点', item.location],
            ['发生时间', item.date],
            ['伤亡情况', item.casualties],
            ['涉及企业', item.company],
            ['直接经济损失', item.economicLoss],
          ].filter(([,v]) => v && v !== '-');

          document.getElementById('detail-body').innerHTML = `
            <!-- 基本信息 -->
            <section class="detail-section">
              <h2 class="detail-section-title">基本信息</h2>
              <div class="detail-section-content">
                ${infoRows.length > 0
                  ? `<table class="detail-info-table">
                       ${infoRows.map(([k,v]) => `<tr><td class="info-label">${k}</td><td class="info-value">${v}</td></tr>`).join('')}
                     </table>`
                  : '<p class="detail-empty">暂无基本信息</p>'}
              </div>
            </section>

            <!-- 事故经过 -->
            <section class="detail-section">
              <h2 class="detail-section-title">事故经过</h2>
              <div class="detail-section-content">
                ${item.content
                  ? `<div class="detail-text">${item.content}</div>`
                  : '<p class="detail-empty">暂无事故经过</p>'}
              </div>
            </section>

            <!-- 事故原因 -->
            <section class="detail-section">
              <h2 class="detail-section-title">事故原因</h2>
              <div class="detail-section-content">
                ${item.causes
                  ? `<div class="detail-text">${item.causes}</div>`
                  : '<p class="detail-empty">暂无原因分析</p>'}
              </div>
            </section>

            <!-- 改善措施 -->
            <section class="detail-section">
              <h2 class="detail-section-title">改善措施</h2>
              <div class="detail-section-content">
                ${item.suggestions
                  ? `<div class="detail-text">${item.suggestions}</div>`
                  : '<p class="detail-empty">暂无改善措施</p>'}
              </div>
            </section>

            <!-- 处理结果 -->
            <section class="detail-section">
              <h2 class="detail-section-title">处理结果</h2>
              <div class="detail-section-content">
                ${item.personnelHandling
                  ? `<div class="detail-text">${item.personnelHandling}</div>`
                  : '<p class="detail-empty">暂无处理结果</p>'}
              </div>
            </section>

            <!-- 报告原文 -->
            <section class="detail-section">
              <h2 class="detail-section-title">报告原文</h2>
              <div class="detail-section-content">
                ${item.reportUrl || item.downloadUrl
                  ? `<a href="${item.reportUrl || item.downloadUrl}" target="_blank" rel="noopener" class="detail-action-btn">查看报告原文 &rarr;</a>`
                  : item.content
                    ? `<details class="detail-expand" open><summary>展开/收起报告全文</summary><div class="detail-expand-body">${item.content}</div></details>`
                    : '<p class="detail-empty">暂无报告原文</p>'}
              </div>
            </section>
          `;
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该事故报告</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    loadDetail();
  </script>
</Layout>
