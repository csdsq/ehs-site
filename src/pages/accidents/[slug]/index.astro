---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import PageComment from '../../../components/PageComment.astro';

const { slug } = Astro.params;
---
<Layout title="事故报告详情" currentPath="/accidents/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/accidents/">事故报告</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div id="detail-tags" style="margin-bottom: 16px;"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    <PageComment pageUrl={`/accidents/${slug}`} />
  </div>

  <script define:vars={{ slug }}>
    const API = '/api/strapi';
    const CACHE_KEY = 'acc_detail_' + slug;
    const CACHE_TTL = 30 * 60 * 1000;

    async function loadDetail() {
      const cached = localStorage.getItem(CACHE_KEY);
      const cachedAt = localStorage.getItem(CACHE_KEY + '_ts');
      if (cached && cachedAt && Date.now() - parseInt(cachedAt) < CACHE_TTL) {
        renderItem(JSON.parse(cached));
        return;
      }
      try {
        // 尝试加载 slug 映射表（新格式 → 原始 slug）
        let querySlug = slug;
        const slugRes = await fetch('/data/slug-mapping.json');
        if (slugRes.ok) {
          const slugMap = await slugRes.json();
          if (slugMap[slug]) querySlug = slugMap[slug].originalSlug;
        }
        let res = await fetch(`${API}/accidents?filters[slug][$eq]=${querySlug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/accidents/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          localStorage.setItem(CACHE_KEY, JSON.stringify(item));
          localStorage.setItem(CACHE_KEY + '_ts', String(Date.now()));
          renderItem(item);
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该事故报告</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    /** 清洗标题：去掉 .pdf/.docx 后缀 */
    function cleanTitle(t) { return t ? t.replace(/\.(pdf|docx|doc|txt)$/i, '') : t; }

    /** 清洗伤亡：只保留人数统计，去除括号内的人名和伤情细节 */
    function cleanCasualties(c) {
      if (!c || c === '-' || ['待官方公布','未知','待确认','待从完整报告获取'].includes(c.trim())) return c;
      if (/(无人员伤亡|无人员死亡|0人死亡|未造成人员伤亡)/.test(c)) return c.trim();
      const parts = [];
      const deathMatch = c.match(/(\d+)人死亡/);
      if (deathMatch) parts.push(deathMatch[1] + '人死亡');
      const injuryMatch = c.match(/(\d+)人[受重轻]伤/);
      if (injuryMatch) parts.push(injuryMatch[1] + '人受伤');
      return parts.length > 0 ? parts.join('，') : c;
    }

    function renderItem(item) {
      const severityMap = { major: '特大', larger: '重大', general: '较大', minor: '一般' };
      const categoryMap = {
        suffocation: '窒息', fall: '高处坠落', gas_leak: '燃气泄漏',
        traffic: '交通', poisoning_suffocation: '中毒窒息',
        falling_object: '物体打击', collapse: '坍塌', crane: '起重伤害',
        other_injury: '其他伤害', fire: '火灾', explosion: '爆炸',
        electric_shock: '触电', mechanical: '机械伤害', drowning: '淹溺'
      };
      const sevClassMap = { major: 'acc-sev-major', larger: 'acc-sev-larger', general: 'acc-sev-general', minor: 'acc-sev-minor' };
      const sevLabel = severityMap[item.severity] || item.severity || '';
      const catLabel = categoryMap[item.category] || item.category || '';
      const provLabel = item.province || '';

      document.getElementById('detail-title').textContent = cleanTitle(item.title) || '';

      const tags = [];
      if (sevLabel) tags.push(`<span class="acc-tag ${sevClassMap[item.severity] || 'acc-sev-general'}">${sevLabel}</span>`);
      if (catLabel) tags.push(`<span class="acc-tag acc-tag-cat">${catLabel}</span>`);
      if (provLabel) tags.push(`<span class="acc-tag acc-tag-prov">${provLabel}</span>`);
      document.getElementById('detail-tags').innerHTML = tags.join(' ');

      const infoRows = [
        ['事故名称', cleanTitle(item.title)],
        ['事故类型', catLabel || item.category],
        ['事故等级', sevLabel || item.severity],
        ['发生省份', provLabel || '-'],
        ['发生地点', item.location],
        ['发生时间', item.date],
        ['伤亡情况', cleanCasualties(item.casualties)],
        ['涉及企业', item.company],
        ['直接经济损失', item.economicLoss],
      ].filter(([,v]) => v && v !== '-');

      document.getElementById('detail-body').innerHTML = `
        <section class="detail-section">
          <h2 class="detail-section-title">基本信息</h2>
          <div class="detail-section-content">
            ${infoRows.length > 0
              ? `<table class="detail-info-table">
                   ${infoRows.map(([k,v]) => `<tr><td class="info-label">${k}</td><td class="info-value">${v}</td></tr>`).join('')}
                 </table>`
              : '<p class="detail-empty">暂无基本信息</p>'}
          </div>
        </section>
        <section class="detail-section">
          <h2 class="detail-section-title">事故经过</h2>
          <div class="detail-section-content">
            ${item.content ? `<div class="detail-text">${item.content}</div>` : '<p class="detail-empty">暂无事故经过</p>'}
          </div>
        </section>
        <section class="detail-section">
          <h2 class="detail-section-title">事故原因</h2>
          <div class="detail-section-content">
            ${item.causes ? `<div class="detail-text">${item.causes}</div>` : '<p class="detail-empty">暂无原因分析</p>'}
          </div>
        </section>
        <section class="detail-section">
          <h2 class="detail-section-title">改善措施</h2>
          <div class="detail-section-content">
            ${item.suggestions ? `<div class="detail-text">${item.suggestions}</div>` : '<p class="detail-empty">暂无改善措施</p>'}
          </div>
        </section>
        <section class="detail-section">
          <h2 class="detail-section-title">处理结果</h2>
          <div class="detail-section-content">
            ${item.personnelHandling ? `<div class="detail-text">${item.personnelHandling}</div>` : '<p class="detail-empty">暂无处理结果</p>'}
          </div>
        </section>
        <section class="detail-section">
          <h2 class="detail-section-title">报告原文</h2>
          <div class="detail-section-content">
            <div class="detail-actions">
              ${item.reportUrl || item.downloadUrl
                ? `<a href="${item.reportUrl || item.downloadUrl}" target="_blank" rel="noopener" class="detail-action-btn btn-preview">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    查看原文
                  </a>`
                : item.content
                  ? `<details class="detail-expand" open><summary>展开/收起报告全文</summary><div class="detail-expand-body">${item.content}</div></details>`
                  : '<p class="detail-empty">暂无报告原文</p>'}
            </div>
          </div>
        </section>
      `;
    }

    loadDetail();
  </script>
</Layout>