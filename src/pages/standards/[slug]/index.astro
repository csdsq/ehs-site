---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import PageComment from '../../../components/PageComment.astro';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const filePath = path.join(process.cwd(), 'public', 'data', 'standards-full.json');
  let items: any[] = [];
  try {
    const data = JSON.parse(fs.readFileSync(filePath, 'utf8'));
    items = Array.isArray(data) ? data : [];
  } catch {
    console.warn('standards-full.json not found, falling back to empty');
  }
  return items.map((item: any) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const content = (item.content || '').trim();
const hasFullText = content && !content.startsWith('{');
const categoryMap: Record<string,string> = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
const catLabel = categoryMap[item.category] || '';
const infoRows = [
  ['标准编号', item.standardNo],
  ['发布机构', item.source],
  item.publishDate ? ['发布日期', item.publishDate] : null,
  item.effectiveDate ? ['实施日期', item.effectiveDate] : null,
  ['标准类别', catLabel || item.category],
].filter(Boolean).filter(([,v]: [string,any]) => v && v !== '-');
---
<Layout title={`${item.title || '国标地标详情'}`} currentPath="/standards/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/standards/">国标地标</a> / 详情
    </div>
    <h1 class="detail-title-flat">{item.title || '无标题'}</h1>
    <div id="detail-tags" style="margin-bottom: 16px;">
      {catLabel ? `<span class="std-tag std-tag-${item.category}">${catLabel}</span>` : ''}
    </div>
    <div class="detail-body">
      <!-- 基本信息 -->
      <section class="detail-section">
        <h2 class="detail-section-title">基本信息</h2>
        <div class="detail-section-content">
          {infoRows.length > 0
            ? `<div class="info-card-list">
                 ${infoRows.map(([k,v]) => `
                   <div class="info-card-item">
                     <span class="info-card-label">${k}</span>
                     <span class="info-card-value">${v}</span>
                   </div>`).join('')}
               </div>`
            : '<p class="detail-empty">暂无基本信息</p>'}
        </div>
      </section>

      <!-- 标准全文 -->
      {hasFullText ? `
      <section class="detail-section">
        <h2 class="detail-section-title">标准全文</h2>
        <div class="detail-section-content">
          <div class="regulation-full-text">${content}</div>
        </div>
      </section>` : ''}

      <!-- 查看原文 -->
      <section class="detail-section">
        <h2 class="detail-section-title">查看原文</h2>
        <div class="detail-section-content">
          <div class="detail-actions">
            ${item.downloadUrl
              ? `<a href="${item.downloadUrl}" target="_blank" rel="noopener" class="detail-action-btn btn-preview">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  查看原文
                </a>`
              : '<p class="detail-empty">暂无原文链接</p>'}
          </div>
        </div>
      </section>
    </div>
    <PageComment pageUrl={`/standards/${item.slug}`} pageTitle={item.title} />
  </div>
</Layout>