---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const dataPath = path.join(process.cwd(), 'public/data/standards.json');
  let items = [];
  try {
    items = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  } catch (e) {
    console.warn('⚠️ standards.json not found for getStaticPaths');
  }
  return items.map(item => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;

// 构建期读取已下载标准的本地文件映射（下载脚本 scripts/download_standards.cjs 生成）
// 仅收录下载成功的标准：slug -> /sstd/<slug>.<ext>
const fileMap: Record<string, string> = {};
try {
  const mf = path.join(process.cwd(), 'public/standards/_manifest.json');
  if (fs.existsSync(mf)) {
    const m = JSON.parse(fs.readFileSync(mf, 'utf-8'));
    for (const [s, v] of Object.entries(m)) {
      if (v && v.status === 'downloaded' && v.localFile) fileMap[s] = v.localFile;
    }
  }
} catch (e) {
  console.warn('⚠️ standards file manifest not found, preview/download will fall back to external link');
}
---
<Layout title="国标地标详情" currentPath="/standards/">
  <div class="container detail-container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/standards/">国标地标</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div id="detail-tags" style="margin-bottom: 16px;"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
  </div>

  <script is:inline define:vars={{ slug, fileMap }}>
    const STRAPI_PROXY = '/sapi';
    const STATIC_DATA_URL = '/data/standards.json';
    const CACHE_KEY = 'std_detail_' + slug;
    const CACHE_TTL = 30 * 60 * 1000;

    async function fetchBySlugApi(collection, slug) {
      var params = new URLSearchParams();
      params.set('filters[slug][$eq]', slug);
      params.set('populate', '*');
      var url = STRAPI_PROXY + '/' + collection + '?' + params.toString();
      var controller = new AbortController();
      var timer = setTimeout(function() { controller.abort(); }, 5000);
      try {
        var res = await fetch(url, { signal: controller.signal });
        if (!res.ok) return null;
        var json = await res.json();
        return json.data && json.data.length > 0 ? json.data[0] : null;
      } catch(e) {
        return null;
      } finally {
        clearTimeout(timer);
      }
    }

    async function findInFullJson(url, slug) {
      try {
        var res = await fetch(url);
        if (!res.ok) return null;
        var all = await res.json();
        return all.find(function(i) { return i.slug === slug; }) || null;
      } catch(e) {
        return null;
      }
    }

    async function loadDetail() {
      var cached = localStorage.getItem(CACHE_KEY);
      var cachedAt = localStorage.getItem(CACHE_KEY + '_ts');
      if (cached && cachedAt && Date.now() - parseInt(cachedAt) < CACHE_TTL) {
        renderItem(JSON.parse(cached));
        return;
      }
      try {
        var item = await fetchBySlugApi('standards', slug);
        if (!item) {
          item = await findInFullJson(STATIC_DATA_URL, slug);
        }
        if (item) {
          localStorage.setItem(CACHE_KEY, JSON.stringify(item));
          localStorage.setItem(CACHE_KEY + '_ts', String(Date.now()));
          renderItem(item);
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该标准</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function renderItem(item) {
      var content = (item.content || '').trim();
      var categoryMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
      var catLabel = categoryMap[item.category] || '';
      // 优先用同步脚本写入的 downloadUrl（Strapi 实际地址）→ 归一化为 /sstd/ 代理在线预览；
      // 否则回退构建期注入的本地 fileMap；externalUrl 作为无本地文件时的官方来源兜底。
      var rawFile = item.downloadUrl || '';
      var fileUrl = '';
      if (rawFile.indexOf('/uploads/') >= 0 || rawFile.indexOf('api.hser.ren/uploads') >= 0) {
        fileUrl = rawFile.replace('https://api.hser.ren/uploads/', '/sstd/').replace('/uploads/', '/sstd/');
      } else if (typeof fileMap !== 'undefined' && fileMap[slug]) {
        fileUrl = fileMap[slug];
      }
      var externalUrl = item.downloadUrl || '';

      // 基本信息：标准类别置顶（安全/环保/职业健康）
      var infoRows = [
        ['标准类别', catLabel || item.category],
        ['标准编号', item.standardNo],
        ['发布机构', item.source],
        item.publishDate ? ['发布日期', item.publishDate] : null,
        item.effectiveDate ? ['实施日期', item.effectiveDate] : null,
      ].filter(Boolean).filter(function(pair) { return pair[1] && pair[1] !== '-'; });

      document.getElementById('detail-title').textContent = item.title || '';
      if (catLabel) {
        document.getElementById('detail-tags').innerHTML = '<span class="std-tag std-tag-' + item.category + '">' + catLabel + '</span>';
      }

      var html = '<section class="detail-section">' +
        '<h2 class="detail-section-title">基本信息</h2>' +
        '<div class="detail-section-content">' +
          (infoRows.length > 0
            ? '<div class="info-card-list">' +
                infoRows.map(function(kv) {
                  return '<div class="info-card-item">' +
                    '<span class="info-card-label">' + kv[0] + '</span>' +
                    '<span class="info-card-value">' + kv[1] + '</span>' +
                  '</div>';
                }).join('') +
              '</div>'
            : '<p class="detail-empty">暂无基本信息</p>') +
        '</div>' +
      '</section>';

      // 标准全文：在线预览（本地文件）；未收录则提示并给出官方来源
      html += '<section class="detail-section">' +
        '<h2 class="detail-section-title">标准全文</h2>' +
        '<div class="detail-section-content">';
      if (fileUrl) {
        // 使用自定义 PDF.js 查看器（无下载/打印按钮，仅翻页+缩放）
        var pdfViewUrl = '/view-pdf/?file=' + encodeURIComponent(fileUrl);
        html += '<div class="detail-iframe-wrap">' +
          '<iframe src="' + pdfViewUrl + '" style="width:100%;height:820px;border:none;border-radius:12px;background:#525659;" title="标准全文预览"></iframe>' +
          '</div>';
      } else {
        html += '<p class="detail-empty">该标准全文暂未收录到本站。' +
          (externalUrl ? '可前往官方来源查看：<a href="' + externalUrl + '" target="_blank" rel="noopener">打开官方页面</a>' : '') +
          '</p>';
      }
      html += '</div></section>';

      // 查看原文：有本地文件则点击弹出验证码验证后下载；否则跳转官方页面
      html += '<section class="detail-section">' +
        '<h2 class="detail-section-title">查看原文</h2>' +
        '<div class="detail-section-content"><div class="detail-actions">';
      if (fileUrl) {
        html += '<button type="button" class="detail-action-btn btn-preview" id="btnDownload" data-fileurl="' + fileUrl + '">' +
          '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>' +
          ' 下载标准文件（PDF）</button>';
      } else if (externalUrl) {
        html += '<a href="' + externalUrl + '" target="_blank" rel="noopener" class="detail-action-btn btn-preview">' +
          '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
          ' 查看原文（官方来源）</a>';
      } else {
        html += '<p class="detail-empty">暂无原文链接</p>';
      }
      html += '</div></div></section>';

      // 底部反馈面板
      html += '<div class="fb-box">' +
        '<div class="fb-title">📢 这条内容有问题？</div>' +
        '<div class="fb-sub">选择问题类型，点击即可提交（也可顺便补充说明）：</div>' +
        '<div class="fb-types" id="fbTypes">' +
          '<button type="button" class="fb-type" data-type="link_broken">链接失效</button>' +
          '<button type="button" class="fb-type" data-type="content_error">内容错误</button>' +
          '<button type="button" class="fb-type" data-type="wrong_category">分类/标签不对</button>' +
          '<button type="button" class="fb-type" data-type="duplicate">重复/多余</button>' +
          '<button type="button" class="fb-type" data-type="other">其他</button>' +
        '</div>' +
        '<textarea class="fb-detail" id="fbDetail" placeholder="补充说明（可选）：比如哪个链接打不开、哪里写错了..." rows="3"></textarea>' +
        '<button class="fb-submit" id="fbSubmit" type="button">提交反馈</button>' +
        '<div class="fb-status" id="fbStatus"></div>' +
      '</div>';

      document.getElementById('detail-body').innerHTML = html;
    }

    loadDetail();
  </script>

  <script is:inline>
    // 反馈面板交互（在 renderItem 动态渲染后绑定）
    (function() {
      function bindFeedback() {
        var types = document.getElementById('fbTypes');
        var detail = document.getElementById('fbDetail');
        var submit = document.getElementById('fbSubmit');
        var status = document.getElementById('fbStatus');
        if (!types || !submit) { setTimeout(bindFeedback, 200); return; }
        var selectedType = null;

        types.addEventListener('click', function(e) {
          var btn = e.target.closest('.fb-type');
          if (!btn) return;
          var allBtns = types.querySelectorAll('.fb-type');
          for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
          btn.classList.add('active');
          selectedType = btn.dataset.type;
          status.textContent = '';
          status.className = 'fb-status';
        });

        submit.addEventListener('click', async function() {
          if (!selectedType) {
            status.textContent = '请先选择一个问题类型';
            status.className = 'fb-status err';
            return;
          }
          submit.disabled = true;
          submit.textContent = '提交中...';
          try {
            var res = await fetch('/feedback', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                type: selectedType,
                detail: detail.value.trim(),
                pageUrl: location.href,
                pageTitle: document.title
              })
            });
            var data = await res.json();
            if (res.ok && data.success) {
              status.textContent = '✓ 已收到，感谢你的反馈！';
              status.className = 'fb-status ok';
              detail.value = '';
              selectedType = null;
              var allBtns = types.querySelectorAll('.fb-type');
              for (var i = 0; i < allBtns.length; i++) { allBtns[i].classList.remove('active'); }
              setTimeout(function() {
                status.textContent = '';
                status.className = 'fb-status';
                submit.disabled = false;
                submit.textContent = '提交反馈';
              }, 2500);
            } else {
              throw new Error((data && data.error) || '提交失败');
            }
          } catch (err) {
            status.textContent = '提交失败，请稍后重试';
            status.className = 'fb-status err';
            submit.disabled = false;
            submit.textContent = '提交反馈';
          }
        });
      }
      bindFeedback();
    })();
  </script>

  <script is:inline>
    // 下载验证码弹窗
    (function() {
      function bindDownloadCaptcha() {
        var btn = document.getElementById('btnDownload');
        if (!btn) { setTimeout(bindDownloadCaptcha, 200); return; }

        function generateCaptcha() {
          var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
          var code = '';
          for (var i = 0; i < 4; i++) {
            code += chars.charAt(Math.floor(Math.random() * chars.length));
          }
          return code;
        }

        var captchaCode = '';
        function drawCaptcha(canvas, code) {
          captchaCode = code;
          var ctx = canvas.getContext('2d');
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.fillStyle = '#f0f0f0';
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          for (var i = 0; i < 3; i++) {
            ctx.strokeStyle = 'rgba(150,150,150,0.3)';
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(Math.random() * canvas.width, Math.random() * canvas.height);
            ctx.lineTo(Math.random() * canvas.width, Math.random() * canvas.height);
            ctx.stroke();
          }
          for (var i = 0; i < 20; i++) {
            ctx.fillStyle = 'rgba(100,100,100,0.4)';
            ctx.beginPath();
            ctx.arc(Math.random() * canvas.width, Math.random() * canvas.height, 1, 0, Math.PI * 2);
            ctx.fill();
          }
          var colors = ['#2563eb', '#7c3aed', '#059669', '#dc2626'];
          for (var i = 0; i < code.length; i++) {
            ctx.font = 'bold 24px Arial';
            ctx.fillStyle = colors[i % colors.length];
            ctx.save();
            ctx.translate(20 + i * 22, 22);
            ctx.rotate((Math.random() - 0.5) * 0.3);
            ctx.fillText(code[i], 0, 0);
            ctx.restore();
          }
        }

        var overlay = document.createElement('div');
        overlay.id = 'captchaOverlay';
        overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;display:none;align-items:center;justify-content:center;';
        overlay.innerHTML =
          '<div id="captchaModal" style="background:#fff;border-radius:16px;padding:24px;width:320px;box-shadow:0 20px 40px rgba(0,0,0,0.3);">' +
            '<h3 style="margin:0 0 16px 0;font-size:18px;color:#111;text-align:center;">下载验证</h3>' +
            '<div style="display:flex;gap:8px;margin-bottom:16px;align-items:center;">' +
              '<canvas id="captchaCanvas" width="100" height="36" style="border-radius:8px;border:1px solid #ddd;"></canvas>' +
              '<button type="button" id="btnRefresh" style="padding:4px 8px;border:1px solid #ddd;border-radius:6px;background:#f5f5f5;cursor:pointer;font-size:14px;">刷新</button>' +
            '</div>' +
            '<input type="text" id="captchaInput" placeholder="请输入验证码" maxlength="4" style="width:100%;padding:10px 12px;border:1px solid #ddd;border-radius:8px;font-size:15px;box-sizing:border-box;margin-bottom:12px;outline:none;" />' +
            '<div id="captchaError" style="color:#dc2626;font-size:13px;margin-bottom:8px;display:none;">验证码错误，请重新输入</div>' +
            '<div style="display:flex;gap:8px;">' +
              '<button type="button" id="btnCaptchaCancel" style="flex:1;padding:10px;border:1px solid #ddd;border-radius:8px;background:#f5f5f5;cursor:pointer;font-size:14px;">取消</button>' +
              '<button type="button" id="btnCaptchaConfirm" style="flex:1;padding:10px;border:none;border-radius:8px;background:#2563eb;color:#fff;cursor:pointer;font-size:14px;font-weight:500;">确认下载</button>' +
            '</div>' +
          '</div>';

        document.body.appendChild(overlay);

        var input = overlay.querySelector('#captchaInput');
        var canvas = overlay.querySelector('#captchaCanvas');
        var refreshBtn = overlay.querySelector('#btnRefresh');
        var cancelBtn = overlay.querySelector('#btnCaptchaCancel');
        var confirmBtn = overlay.querySelector('#btnCaptchaConfirm');
        var errorDiv = overlay.querySelector('#captchaError');

        function showCaptcha() {
          overlay.style.display = 'flex';
          input.value = '';
          errorDiv.style.display = 'none';
          var code = generateCaptcha();
          drawCaptcha(canvas, code);
          input.focus();
        }

        function hideCaptcha() {
          overlay.style.display = 'none';
        }

        btn.addEventListener('click', showCaptcha);
        cancelBtn.addEventListener('click', hideCaptcha);
        refreshBtn.addEventListener('click', function() {
          var code = generateCaptcha();
          drawCaptcha(canvas, code);
          input.value = '';
          errorDiv.style.display = 'none';
          input.focus();
        });

        overlay.addEventListener('click', function(e) {
          if (e.target === overlay) hideCaptcha();
        });

        confirmBtn.addEventListener('click', function() {
          if (input.value.toUpperCase() === captchaCode) {
            hideCaptcha();
            var url = btn.dataset.fileurl;
            var a = document.createElement('a');
            a.href = url;
            a.download = '';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          } else {
            errorDiv.style.display = 'block';
            input.value = '';
            input.focus();
            var code = generateCaptcha();
            drawCaptcha(canvas, code);
          }
        });

        input.addEventListener('keypress', function(e) {
          if (e.key === 'Enter') confirmBtn.click();
        });
      }
      bindDownloadCaptcha();
    })();
  </script>
</Layout>