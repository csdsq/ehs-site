---
import Layout from '../../layouts/Layout.astro';
import PageComment from '../../components/PageComment.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const dataPath = path.join(process.cwd(), 'public/data/standards.json');
  let items = [];
  try {
    items = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  } catch (e) {
    console.warn('⚠️ standards.json not found for getStaticPaths');
  }
  return items.map(item => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;
---
<Layout title="国标地标详情" currentPath="/standards/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/standards/">国标地标</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div id="detail-tags" style="margin-bottom: 16px;"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    <PageComment pageUrl={`/standards/${slug}`} />
  </div>

  <script is:inline define:vars={{ slug }}>
    const STRAPI_PROXY = '/sapi';
    const STATIC_DATA_URL = '/data/standards.json';
    const CACHE_KEY = 'std_detail_' + slug;
    const CACHE_TTL = 30 * 60 * 1000;

    async function fetchBySlugApi(collection, slug) {
      var params = new URLSearchParams();
      params.set('filters[slug][$eq]', slug);
      params.set('populate', '*');
      var url = STRAPI_PROXY + '/' + collection + '?' + params.toString();
      var controller = new AbortController();
      var timer = setTimeout(function() { controller.abort(); }, 5000);
      try {
        var res = await fetch(url, { signal: controller.signal });
        if (!res.ok) return null;
        var json = await res.json();
        return json.data && json.data.length > 0 ? json.data[0] : null;
      } catch(e) {
        return null;
      } finally {
        clearTimeout(timer);
      }
    }

    async function findInFullJson(url, slug) {
      try {
        var res = await fetch(url);
        if (!res.ok) return null;
        var all = await res.json();
        return all.find(function(i) { return i.slug === slug; }) || null;
      } catch(e) {
        return null;
      }
    }

    async function loadDetail() {
      var cached = localStorage.getItem(CACHE_KEY);
      var cachedAt = localStorage.getItem(CACHE_KEY + '_ts');
      if (cached && cachedAt && Date.now() - parseInt(cachedAt) < CACHE_TTL) {
        renderItem(JSON.parse(cached));
        return;
      }
      try {
        var item = await fetchBySlugApi('standards', slug);
        if (!item) {
          item = await findInFullJson(STATIC_DATA_URL, slug);
        }
        if (item) {
          localStorage.setItem(CACHE_KEY, JSON.stringify(item));
          localStorage.setItem(CACHE_KEY + '_ts', String(Date.now()));
          renderItem(item);
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该标准</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function renderItem(item) {
      var content = (item.content || '').trim();
      var hasFullText = content && content.indexOf('{') !== 0;
      var categoryMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
      var catLabel = categoryMap[item.category] || '';
      var infoRows = [
        ['标准编号', item.standardNo],
        ['发布机构', item.source],
        item.publishDate ? ['发布日期', item.publishDate] : null,
        item.effectiveDate ? ['实施日期', item.effectiveDate] : null,
        ['标准类别', catLabel || item.category],
      ].filter(Boolean).filter(function(pair) { return pair[1] && pair[1] !== '-'; });

      document.getElementById('detail-title').textContent = item.title || '';
      if (catLabel) {
        document.getElementById('detail-tags').innerHTML = '<span class="std-tag std-tag-' + item.category + '">' + catLabel + '</span>';
      }

      var html = '<section class="detail-section">' +
        '<h2 class="detail-section-title">基本信息</h2>' +
        '<div class="detail-section-content">' +
          (infoRows.length > 0
            ? '<div class="info-card-list">' +
                infoRows.map(function(kv) {
                  return '<div class="info-card-item">' +
                    '<span class="info-card-label">' + kv[0] + '</span>' +
                    '<span class="info-card-value">' + kv[1] + '</span>' +
                  '</div>';
                }).join('') +
              '</div>'
            : '<p class="detail-empty">暂无基本信息</p>') +
        '</div>' +
      '</section>';
      if (hasFullText) {
        html += '<section class="detail-section">' +
          '<h2 class="detail-section-title">标准全文</h2>' +
          '<div class="detail-section-content">' +
            '<div class="regulation-full-text">' + content + '</div>' +
          '</div>' +
        '</section>';
      }
      html += '<section class="detail-section">' +
        '<h2 class="detail-section-title">查看原文</h2>' +
        '<div class="detail-section-content">' +
          '<div class="detail-actions">' +
            (item.downloadUrl
              ? '<a href="' + item.downloadUrl + '" target="_blank" rel="noopener" class="detail-action-btn btn-preview">' +
                  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
                  ' 查看原文</a>'
              : '<p class="detail-empty">暂无原文链接</p>') +
          '</div>' +
        '</div>' +
      '</section>';

      document.getElementById('detail-body').innerHTML = html;
    }

    loadDetail();
  </script>
</Layout>
