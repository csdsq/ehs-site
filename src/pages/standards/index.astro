---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="国标地标" currentPath="/standards/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">国标地标</h1>

      <!-- ICS分类筛选 + 地区筛选 -->
      <div class="filter-bar" id="reg-filter-bar">
        <!-- 动态生成 -->
      </div>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="reg-search" placeholder="搜索国标地标名称、来源..." />
        <button id="reg-search-btn">搜索</button>
      </div>

      <div id="reg-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="reg-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="reg-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script>
    const API = 'https://api.hser.ren';
    let allItems: any[] = [];
    let filteredItems: any[] = [];
    let currentPage = 1;
    let pageSize = 10;
    let activeCategory = '';
    let activeRegion = '';

    // 地方标准编号前缀→省份映射 (DB## = 地方标准)
    const dbCodeProvinceMap: Record<string, string> = {
      '11': '北京', '12': '天津', '13': '河北', '14': '山西', '15': '内蒙古',
      '21': '辽宁', '22': '吉林', '23': '黑龙江',
      '31': '上海', '32': '江苏', '33': '浙江', '34': '安徽', '35': '福建', '36': '江西', '37': '山东',
      '41': '河南', '42': '湖北', '43': '湖南', '44': '广东', '45': '广西', '46': '海南',
      '50': '重庆', '51': '四川', '52': '贵州', '53': '云南', '54': '西藏',
      '61': '陕西', '62': '甘肃', '63': '青海', '64': '宁夏', '65': '新疆',
    };

    // 直辖市/城市→省份映射
    const cityProvinceMap: Record<string, string> = {
      '深圳': '广东', '广州': '广东', '珠海': '广东', '佛山': '广东', '东莞': '广东',
      '南京': '江苏', '苏州': '江苏', '无锡': '江苏', '常州': '江苏', '南通': '江苏',
      '成都': '四川', '绵阳': '四川', '德阳': '四川',
      '杭州': '浙江', '宁波': '浙江', '温州': '浙江',
      '济南': '山东', '青岛': '山东', '烟台': '山东',
    };

    // 判断是否为国标（非地方标准）
    function isNational(item: any): boolean {
      const no = (item.standardNo || '').toUpperCase().trim();
      // GB, GB/T, GB/Z, JT, HJ, AQ, WS, MT, YB, SL, DL, HG, SH 等均为国标/行业标准
      if (/^(GB|JT|HJ|AQ|WS|MT|YB|SL|DL|HG|SH|CJ|JB|TB|NB|DL|EJ|GY|YS|SY|QX|LD|JG|HY|CH|ZY|GH|BB|DA|DZ|GJB)/.test(no)) return true;
      // DB## 为地方标准
      if (/^DB/.test(no)) return false;
      // 默认当国标
      return true;
    }

    // 从标准编号或标题中提取地区
    function extractRegion(item: any): string {
      // 优先从标准编号提取（DB##格式）
      const no = (item.standardNo || '').toUpperCase().trim();
      const dbMatch = no.match(/^DB(\d{2})/);
      if (dbMatch && dbCodeProvinceMap[dbMatch[1]]) {
        return dbCodeProvinceMap[dbMatch[1]];
      }
      // 其次从标题提取
      const title = item.title || '';
      for (const [city, prov] of Object.entries(cityProvinceMap)) {
        if (title.includes(city)) return prov;
      }
      const provinces = ['北京','天津','上海','重庆','河北','山西','辽宁','吉林','黑龙江',
        '江苏','浙江','安徽','福建','江西','山东','河南','湖北','湖南','广东','海南',
        '四川','贵州','云南','陕西','内蒙古','广西','西藏','宁夏','新疆','甘肃','青海'];
      for (const p of provinces) {
        if (title.includes(p)) return p;
      }
      return '';
    }

    function getRegionLabel(item: any): string {
      if (isNational(item)) return '全国';
      const region = extractRegion(item);
      return region ? `地标·${region}` : '地标';
    }

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function renderItems(items: any[]) {
      const el = document.getElementById('reg-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => {
        const regLabel = getRegionLabel(item);
        const tagParts = [];
        if (item.category) tagParts.push(`<span class="std-tag std-tag-category">${item.category}</span>`);
        if (regLabel) tagParts.push(`<span class="std-tag std-tag-region">${regLabel}</span>`);
        return `
        <a href="/standards/${item.slug || item.id}" class="list-item">
          <div class="list-item-body">
            <div class="list-item-title">${item.title}${item.standardNo ? ` <span class="list-item-no">${item.standardNo}</span>` : ''}</div>
            <div class="list-item-meta-row">
              ${tagParts.join('')}
              ${item.publishDate ? `<span>发布：${item.publishDate}</span>` : ''}
              ${item.effectiveDate ? `<span>实施：${item.effectiveDate}</span>` : ''}
            </div>
          </div>
          <div class="list-item-arrow">&rarr;</div>
        </a>`;
      }).join('');
    }

    function renderPagination() {
      const el = document.getElementById('reg-pagination')!;
      const total = filteredItems.length;
      const totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      const start = (currentPage - 1) * pageSize + 1;
      const end = Math.min(currentPage * pageSize, total);

      let pagesHtml = '';
      const range: number[] = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        const s = Math.max(2, currentPage - 2);
        const e = Math.min(totalPages - 1, currentPage + 2);
        for (let i = s; i <= e; i++) range.push(i);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (const p of range) {
        if (p < 0) {
          pagesHtml += `<span class="page-ellipsis">…</span>`;
        } else {
          pagesHtml += `<button class="${p === currentPage ? 'active' : ''}" data-page="${p}">${p}</button>`;
        }
      }

      el.innerHTML = `
        <div class="pagination-info">显示 ${start}-${end}，共 ${total} 项</div>
        <div class="pagination-controls">
          <button data-action="prev" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>
          ${pagesHtml}
          <button data-action="next" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>
        </div>
        <div class="page-size-select">
          每页
          <select id="reg-page-size">
            <option value="10" ${pageSize===10?'selected':''}>10</option>
            <option value="20" ${pageSize===20?'selected':''}>20</option>
            <option value="50" ${pageSize===50?'selected':''}>50</option>
            <option value="100" ${pageSize===100?'selected':''}>100</option>
          </select>
          条
        </div>`;

      el.querySelector('#reg-page-size')!.addEventListener('change', (e: any) => {
        pageSize = parseInt(e.target.value);
        currentPage = 1;
        updateView();
      });
      el.querySelectorAll('[data-page]').forEach(btn => {
        btn.addEventListener('click', () => {
          currentPage = parseInt((btn as HTMLElement).dataset.page!);
          updateView();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
      el.querySelector('[data-action="prev"]')!.addEventListener('click', () => {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]')!.addEventListener('click', () => {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }

    function updateView() {
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('reg-count')!.textContent = `共 ${filteredItems.length} 项${filteredItems.length !== allItems.length ? `（筛选自 ${allItems.length} 项）` : ''}`;
    }

    function buildFilters() {
      const categories = [...new Set(allItems.map(i => i.category).filter(Boolean))] as string[];
      const filterBar = document.getElementById('reg-filter-bar')!;
      filterBar.innerHTML = '';

      // 类型筛选
      const catGroup = document.createElement('div');
      catGroup.className = 'filter-group';

      const catLabel = document.createElement('span');
      catLabel.className = 'filter-label';
      catLabel.textContent = '类型';
      catGroup.appendChild(catLabel);

      const catTags = document.createElement('div');
      catTags.className = 'filter-tags';
      catTags.id = 'category-tags';

      const allBtn = document.createElement('button');
      allBtn.className = 'filter-tag active';
      allBtn.textContent = '全部';
      allBtn.dataset.value = '';
      catTags.appendChild(allBtn);

      for (const cat of categories.sort()) {
        const btn = document.createElement('button');
        btn.className = 'filter-tag';
        btn.textContent = cat;
        btn.dataset.value = cat;
        catTags.appendChild(btn);
      }
      catGroup.appendChild(catTags);
      filterBar.appendChild(catGroup);

      // 地区筛选
      const regGroup = document.createElement('div');
      regGroup.className = 'filter-group';

      const regLabel = document.createElement('span');
      regLabel.className = 'filter-label';
      regLabel.textContent = '地区';
      regGroup.appendChild(regLabel);

      const regTags = document.createElement('div');
      regTags.className = 'filter-tags';
      regTags.id = 'region-tags';

      const provinces = [
        '', 'national', '北京', '天津', '上海', '重庆',
        '河北', '山西', '辽宁', '吉林', '黑龙江',
        '江苏', '浙江', '安徽', '福建', '江西', '山东',
        '河南', '湖北', '湖南', '广东', '海南',
        '四川', '贵州', '云南', '陕西',
        '广西', '甘肃', '青海', '内蒙古', '西藏', '宁夏', '新疆'
      ];
      const labels: Record<string, string> = { '': '全部', 'national': '全国' };

      for (const p of provinces) {
        const btn = document.createElement('button');
        btn.className = 'filter-tag' + (p === '' ? ' active' : '');
        btn.textContent = labels[p] || p;
        btn.dataset.value = p;
        regTags.appendChild(btn);
      }
      regGroup.appendChild(regTags);
      filterBar.appendChild(regGroup);

      // 事件委托 - 类型筛选
      catTags.addEventListener('click', (e: any) => {
        if (!e.target.classList.contains('filter-tag')) return;
        catTags.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        activeCategory = e.target.dataset.value || '';
        applyFilters();
      });

      // 事件委托 - 地区筛选
      regTags.addEventListener('click', (e: any) => {
        if (!e.target.classList.contains('filter-tag')) return;
        regTags.querySelectorAll('.filter-tag').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        activeRegion = e.target.dataset.value || '';
        applyFilters();
      });
    }

    function applyFilters() {
      const q = (document.getElementById('reg-search') as HTMLInputElement).value.trim().toLowerCase();
      filteredItems = allItems.filter(item => {
        if (activeCategory && item.category !== activeCategory) return false;
        if (activeRegion) {
          if (activeRegion === 'national') {
            if (!isNational(item)) return false;
          } else {
            if (isNational(item)) return false;
            const region = extractRegion(item);
            if (region !== activeRegion) return false;
          }
        }
        if (q) {
          const text = `${item.title ?? ''} ${item.source ?? ''} ${item.category ?? ''} ${item.standardNo ?? ''}`.toLowerCase();
          if (!text.includes(q)) return false;
        }
        return true;
      });
      currentPage = 1;
      updateView();
    }

    async function loadItems() {
      try {
        const res = await fetch(`${API}/standards?pagination[pageSize]=200&sort=publishDate:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        filteredItems = [...allItems];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('reg-count')!.textContent = `共 ${total} 项`;
        buildFilters();
        updateView();
      } catch (e) {
        document.getElementById('reg-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    document.getElementById('reg-search')!.addEventListener('input', applyFilters);
    document.getElementById('reg-search-btn')!.addEventListener('click', applyFilters);

    loadItems();
  </script>
</Layout>
