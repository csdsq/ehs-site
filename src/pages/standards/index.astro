---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="国标地标" currentPath="/standards/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">国标地标</h1>

      <!-- ICS分类筛选 + 地区筛选 -->
      <div class="filter-bar" id="reg-filter-bar">
        <!-- 动态生成 -->
      </div>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="reg-search" placeholder="搜索国标地标名称、来源..." />
        <button id="reg-search-btn">搜索</button>
      </div>

      <div id="reg-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="reg-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="reg-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script is:inline>
    const PREVIEW_URL = '/data/standards-preview.json';
    const SUMMARY_FIELDS = ['title','slug','standardNo','source','category','publishDate','effectiveDate','description','regionLevel','summary'];
    var allItems = [];
    var filteredItems = [];
    var currentPage = 1;
    var pageSize = 10;
    var activeCategory = '';
    var activeRegion = '';
    var activeStdType = '';

    // 地方标准编号前缀→省份映射 (DB## = 地方标准)
    var dbCodeProvinceMap = {
      '11': '北京', '12': '天津', '13': '河北', '14': '山西', '15': '内蒙古',
      '21': '辽宁', '22': '吉林', '23': '黑龙江',
      '31': '上海', '32': '江苏', '33': '浙江', '34': '安徽', '35': '福建', '36': '江西', '37': '山东',
      '41': '河南', '42': '湖北', '43': '湖南', '44': '广东', '45': '广西', '46': '海南',
      '50': '重庆', '51': '四川', '52': '贵州', '53': '云南', '54': '西藏',
      '61': '陕西', '62': '甘肃', '63': '青海', '64': '宁夏', '65': '新疆',
    };

    // 直辖市/城市→省份映射
    var cityProvinceMap = {
      '深圳': '广东', '广州': '广东', '珠海': '广东', '佛山': '广东', '东莞': '广东',
      '南京': '江苏', '苏州': '江苏', '无锡': '江苏', '常州': '江苏', '南通': '江苏',
      '成都': '四川', '绵阳': '四川', '德阳': '四川',
      '杭州': '浙江', '宁波': '浙江', '温州': '浙江',
      '济南': '山东', '青岛': '山东', '烟台': '山东',
    };

    // 判断标准级别类型
    function getStdType(item) {
      var no = (item.standardNo || '').toUpperCase().trim();
      if (/^GB/.test(no)) return 'gb';
      if (/^DB/.test(no)) return 'local';
      return 'industry';
    }

    function getStdTypeLabel(type) {
      var map = { gb: '国标', industry: '行标', local: '地标' };
      return map[type] || '行标';
    }

    function isNational(item) {
      return getStdType(item) !== 'local';
    }

    function extractRegion(item) {
      var no = (item.standardNo || '').toUpperCase().trim();
      var dbMatch = no.match(/^DB(\d{2})/);
      if (dbMatch && dbCodeProvinceMap[dbMatch[1]]) return dbCodeProvinceMap[dbMatch[1]];
      var title = item.title || '';
      for (var city in cityProvinceMap) {
        if (title.indexOf(city) >= 0) return cityProvinceMap[city];
      }
      var provinces = ['北京','天津','上海','重庆','河北','山西','辽宁','吉林','黑龙江',
        '江苏','浙江','安徽','福建','江西','山东','河南','湖北','湖南','广东','海南',
        '四川','贵州','云南','陕西','内蒙古','广西','西藏','宁夏','新疆','甘肃','青海'];
      for (var i = 0; i < provinces.length; i++) {
        if (title.indexOf(provinces[i]) >= 0) return provinces[i];
      }
      return '';
    }

    function getRegionLabel(item) {
      var stdType = getStdType(item);
      if (stdType === 'local') {
        var region = extractRegion(item);
        return region ? ('地标·' + region) : '地标';
      }
      return getStdTypeLabel(stdType);
    }

    function getDetailLink(item) {
      return '/standards/' + item.slug;
    }

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function renderItems(items) {
      var el = document.getElementById('reg-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      var html = '';
      for (var i = 0; i < items.length; i++) {
        var item = items[i];
        var regLabel = getRegionLabel(item);
        var stdType = getStdType(item);
        var tagParts = [];
        tagParts.push('<span class="std-tag std-tag-type-' + stdType + '">' + getStdTypeLabel(stdType) + '</span>');
        if (item.category) {
          var catMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
          tagParts.push('<span class="std-tag std-tag-category">' + (catMap[item.category] || item.category) + '</span>');
        }
        if (stdType === 'local') tagParts.push('<span class="std-tag std-tag-region">' + regLabel + '</span>');
        var metaHtml = tagParts.join('');
        if (item.publishDate) metaHtml += '<span>发布：' + item.publishDate + '</span>';
        if (item.effectiveDate) metaHtml += '<span>实施：' + item.effectiveDate + '</span>';
        var noHtml = item.standardNo ? (' <span class="list-item-no">' + item.standardNo + '</span>') : '';
        html += '<a href="' + getDetailLink(item) + '" class="list-item">'
          + '<div class="list-item-body">'
          + '<div class="list-item-title">' + item.title + noHtml + '</div>'
          + '<div class="list-item-meta-row">' + metaHtml + '</div>'
          + '</div>'
          + '<div class="list-item-arrow">&rarr;</div>'
          + '</a>';
      }
      el.innerHTML = html;
    }

    function renderPagination() {
      var el = document.getElementById('reg-pagination');
      var total = filteredItems.length;
      var totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      var start = (currentPage - 1) * pageSize + 1;
      var end = Math.min(currentPage * pageSize, total);

      var pagesHtml = '';
      var range = [];
      if (totalPages <= 7) {
        for (var i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        var s = Math.max(2, currentPage - 2);
        var e = Math.min(totalPages - 1, currentPage + 2);
        for (var j = s; j <= e; j++) range.push(j);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (var k = 0; k < range.length; k++) {
        var p = range[k];
        if (p < 0) {
          pagesHtml += '<span class="page-ellipsis">…</span>';
        } else {
          pagesHtml += '<button class="' + (p === currentPage ? 'active' : '') + '" data-page="' + p + '">' + p + '</button>';
        }
      }

      el.innerHTML =
        '<div class="pagination-info">显示 ' + start + '-' + end + '，共 ' + total + ' 项</div>'
        + '<div class="pagination-controls">'
        + '<button data-action="prev"' + (currentPage === 1 ? ' disabled' : '') + '>上一页</button>'
        + pagesHtml
        + '<button data-action="next"' + (currentPage === totalPages ? ' disabled' : '') + '>下一页</button>'
        + '</div>'
        + '<div class="page-size-select">每页'
        + '<select id="reg-page-size">'
        + '<option value="10"' + (pageSize===10?' selected':'') + '>10</option>'
        + '<option value="20"' + (pageSize===20?' selected':'') + '>20</option>'
        + '<option value="50"' + (pageSize===50?' selected':'') + '>50</option>'
        + '<option value="100"' + (pageSize===100?' selected':'') + '>100</option>'
        + '</select>条</div>';

      el.querySelector('#reg-page-size').addEventListener('change', function(e) {
        pageSize = parseInt(e.target.value);
        currentPage = 1;
        updateView();
      });
      el.querySelectorAll('[data-page]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          currentPage = parseInt(btn.dataset.page);
          updateView();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
      el.querySelector('[data-action="prev"]').addEventListener('click', function() {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]').addEventListener('click', function() {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }

    function updateView() {
      var start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('reg-count').textContent = '共 ' + filteredItems.length + ' 项'
        + (filteredItems.length !== allItems.length ? '（筛选自 ' + allItems.length + ' 项）' : '');
    }

    function buildFilters() {
      var filterBar = document.getElementById('reg-filter-bar');
      filterBar.innerHTML = '';

      var filterRow = document.createElement('div');
      filterRow.className = 'filter-row';

      var stdTypeGroup = document.createElement('div');
      stdTypeGroup.className = 'filter-group';
      var stdTypeLabel = document.createElement('span');
      stdTypeLabel.className = 'filter-label';
      stdTypeLabel.textContent = '级别';
      stdTypeGroup.appendChild(stdTypeLabel);

      var stdTypeTags = document.createElement('div');
      stdTypeTags.className = 'filter-tags';
      stdTypeTags.id = 'stdtype-tags';

      var stdTypeOptions = [
        { value: '', label: '全部' },
        { value: 'gb', label: '国标' },
        { value: 'industry', label: '行标' },
        { value: 'local', label: '地标' },
      ];
      for (var i = 0; i < stdTypeOptions.length; i++) {
        var opt = stdTypeOptions[i];
        var btn = document.createElement('button');
        btn.className = 'filter-tag' + (opt.value === '' ? ' active' : '');
        btn.textContent = opt.label;
        btn.dataset.value = opt.value;
        stdTypeTags.appendChild(btn);
      }
      stdTypeGroup.appendChild(stdTypeTags);
      filterRow.appendChild(stdTypeGroup);

      // 类型筛选
      var seenCats = {};
      var categories = [];
      for (var ci = 0; ci < allItems.length; ci++) {
        if (allItems[ci].category && !seenCats[allItems[ci].category]) {
          seenCats[allItems[ci].category] = true;
          categories.push(allItems[ci].category);
        }
      }
      categories.sort();

      var catGroup = document.createElement('div');
      catGroup.className = 'filter-group';
      var catLabel = document.createElement('span');
      catLabel.className = 'filter-label';
      catLabel.textContent = '类型';
      catGroup.appendChild(catLabel);

      var catTags = document.createElement('div');
      catTags.className = 'filter-tags';
      catTags.id = 'category-tags';

      var allBtn = document.createElement('button');
      allBtn.className = 'filter-tag active';
      allBtn.textContent = '全部';
      allBtn.dataset.value = '';
      catTags.appendChild(allBtn);

      var catNameMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
      for (var c = 0; c < categories.length; c++) {
        var b = document.createElement('button');
        b.className = 'filter-tag';
        b.textContent = catNameMap[categories[c]] || categories[c];
        b.dataset.value = categories[c];
        catTags.appendChild(b);
      }
      catGroup.appendChild(catTags);
      filterRow.appendChild(catGroup);
      filterBar.appendChild(filterRow);

      // 地区筛选
      var regGroup = document.createElement('div');
      regGroup.className = 'filter-group';
      var regLabel = document.createElement('span');
      regLabel.className = 'filter-label';
      regLabel.textContent = '地区';
      regGroup.appendChild(regLabel);

      var regTags = document.createElement('div');
      regTags.className = 'filter-tags';
      regTags.id = 'region-tags';

      var provinces = [
        '', 'national', '北京', '天津', '上海', '重庆',
        '河北', '山西', '辽宁', '吉林', '黑龙江',
        '江苏', '浙江', '安徽', '福建', '江西', '山东',
        '河南', '湖北', '湖南', '广东', '海南',
        '四川', '贵州', '云南', '陕西',
        '广西', '甘肃', '青海', '内蒙古', '西藏', '宁夏', '新疆'
      ];
      var labels = { '': '全部', 'national': '全国' };

      for (var pi = 0; pi < provinces.length; pi++) {
        var p = provinces[pi];
        var rb = document.createElement('button');
        rb.className = 'filter-tag' + (p === '' ? ' active' : '');
        rb.textContent = labels[p] || p;
        rb.dataset.value = p;
        regTags.appendChild(rb);
      }
      regGroup.appendChild(regTags);
      filterBar.appendChild(regGroup);

      stdTypeTags.addEventListener('click', function(e) {
        if (!e.target.classList.contains('filter-tag')) return;
        stdTypeTags.querySelectorAll('.filter-tag').forEach(function(b) { b.classList.remove('active'); });
        e.target.classList.add('active');
        activeStdType = e.target.dataset.value || '';
        applyFilters();
      });

      catTags.addEventListener('click', function(e) {
        if (!e.target.classList.contains('filter-tag')) return;
        catTags.querySelectorAll('.filter-tag').forEach(function(b) { b.classList.remove('active'); });
        e.target.classList.add('active');
        activeCategory = e.target.dataset.value || '';
        applyFilters();
      });

      regTags.addEventListener('click', function(e) {
        if (!e.target.classList.contains('filter-tag')) return;
        regTags.querySelectorAll('.filter-tag').forEach(function(b) { b.classList.remove('active'); });
        e.target.classList.add('active');
        activeRegion = e.target.dataset.value || '';
        applyFilters();
      });
    }

    function applyFilters() {
      var q = document.getElementById('reg-search').value.trim().toLowerCase();
      filteredItems = [];
      for (var fi = 0; fi < allItems.length; fi++) {
        var item = allItems[fi];
        if (activeStdType && getStdType(item) !== activeStdType) continue;
        if (activeCategory && item.category !== activeCategory) continue;
        if (activeRegion) {
          if (activeRegion === 'national') {
            if (!isNational(item)) continue;
          } else {
            if (isNational(item)) continue;
            var region = extractRegion(item);
            if (region !== activeRegion) continue;
          }
        }
        if (q) {
          var text = ((item.title || '') + ' ' + (item.source || '') + ' ' + (item.category || '') + ' ' + (item.standardNo || '')).toLowerCase();
          if (text.indexOf(q) < 0) continue;
        }
        filteredItems.push(item);
      }
      currentPage = 1;
      updateView();
    }

    // 从构建时生成的预览 JSON 加载数据（已含 YYMM-NNN 新 slug）
    function fetchPreview(url) {
      return fetch(url).then(function(res) { return res.json(); });
    }

    async function loadItems() {
      var listEl = document.getElementById('reg-list');
      try {
        allItems = await fetchPreview(PREVIEW_URL);
        filteredItems = allItems.slice();
        document.getElementById('reg-count').textContent = '共 ' + allItems.length + ' 项';
        buildFilters();
        updateView();
      } catch (e) {
        if (listEl) listEl.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    document.getElementById('reg-search').addEventListener('input', applyFilters);
    document.getElementById('reg-search-btn').addEventListener('click', applyFilters);

    loadItems();
  </script>
</Layout>
