---
import Layout from '../../layouts/Layout.astro';
import PageComment from '../../components/PageComment.astro';
---
<Layout title="关于本站" currentPath="/messages/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">关于本站</h1>
      <p class="page-description">
        EHS 知识库（hser.ren）致力于收集整理安全生产、职业健康、环境保护等领域的公开资料，
        包括事故调查报告、法规文件、国家标准与地方标准等内容，方便 EHS 从业者检索与学习。
        如发现内容有误或链接失效，欢迎通过
        <a href="mailto:admin@hser.ren">admin@hser.ren</a> 反馈。
      </p>

      <PageComment pageUrl={Astro.url.pathname} pageTitle="关于本站" />
    </div>
  </div>

</Layout>
