---
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  try {
    const res = await fetch('http://strapi.hser.ren:1337/api/ai-apps?pagination[pageSize]=100&fields[0]=slug');
    const json = await res.json();
    const items = json.data || [];
    return items.map(item => ({ params: { slug: item.slug || String(item.id) } }));
  } catch (e) { return []; }
}

const { slug } = Astro.params;
---
<Layout title="AI应用详情" currentPath="/ai-apps/">
  <div class="detail-header">
    <div class="container">
      <div class="detail-breadcrumb">
        <a href="/">首页</a> / <a href="/ai-apps/">AI应用</a> / 详情
      </div>
      <h1 class="detail-title" id="detail-title">加载中...</h1>
      <div class="detail-meta" id="detail-meta"></div>
    </div>
  </div>
  <div class="container">
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
  </div>

  <script define:vars={{ slug }}>
    const API = '/api';
    async function loadDetail() {
      try {
        let res = await fetch(`${API}/ai-apps?filters[slug][$eq]=${slug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/ai-apps/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          document.getElementById('detail-title').textContent = item.title || '';
          document.getElementById('detail-meta').innerHTML = [
            item.category ? `<span>${item.category}</span>` : '',
          ].filter(Boolean).join('');

          document.getElementById('detail-body').innerHTML = `
            <!-- 主要功能说明 -->
            <section class="detail-section">
              <h2 class="detail-section-title">主要功能说明</h2>
              <div class="detail-section-content">
                ${item.features || item.description
                  ? `<p>${item.features || item.description}</p>`
                  : '<p class="detail-empty">暂无功能说明</p>'}
              </div>
            </section>

            <!-- 应用演示 -->
            <section class="detail-section">
              <h2 class="detail-section-title">应用演示</h2>
              <div class="detail-section-content">
                ${item.demoUrl
                  ? `<div class="detail-iframe-wrap">
                       <iframe src="${item.demoUrl}" allowfullscreen style="width:100%;height:480px;border:none;border-radius:12px;"></iframe>
                     </div>`
                  : item.demoContent
                    ? `<div style="background:var(--bg);border-radius:12px;padding:24px;text-align:center;">${item.demoContent}</div>`
                    : '<p class="detail-empty">暂无演示内容</p>'}
              </div>
            </section>

            <!-- 应用使用链接 -->
            <section class="detail-section">
              <h2 class="detail-section-title">应用使用链接</h2>
              <div class="detail-section-content">
                ${item.appUrl || item.url
                  ? `<a href="${item.appUrl || item.url}" target="_blank" rel="noopener" class="detail-action-btn">立即使用 &rarr;</a>`
                  : '<p class="detail-empty">暂未开放使用</p>'}
              </div>
            </section>
          `;
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该应用</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    loadDetail();
  </script>
</Layout>
