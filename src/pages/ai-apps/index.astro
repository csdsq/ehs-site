---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="AI应用" currentPath="/ai-apps/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">AI应用</h1>
      <p class="page-subtitle">展示 EHS 领域 AI 工具与应用案例</p>

      <div id="ai-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="ai-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="ai-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script>
    import { fetchAllSummaries, fetchPreview } from '../../lib/strapi-client';
    const PREVIEW_URL = '/data/ai-apps-preview.json';
    const SUMMARY_FIELDS = ['title','slug','category','description','features','appUrl'];

    let allItems: any[] = [];
    let filteredItems: any[] = [];
    let currentPage = 1;
    let pageSize = 12;
    let searchQuery = '';

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function renderItems(items: any[]) {
      const el = document.getElementById('ai-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => {
        const desc = item.features || item.description || '';
        const shortDesc = desc.length > 120 ? desc.substring(0, 120) + '...' : desc;
        const category = item.category ? `<span class="std-tag std-tag-type-gb">${item.category}</span>` : '';
        return `
          <a href="/ai-apps/${item.slug}" class="list-item ai-card">
            <div class="list-item-body">
              <div class="list-item-title">${item.title} ${category}</div>
              ${shortDesc ? `<div style="font-size:13px;color:var(--text-light);margin-top:4px;line-height:1.5;">${shortDesc}</div>` : ''}
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }).join('');
    }

    function renderPagination() {
      const el = document.getElementById('ai-pagination')!;
      const total = filteredItems.length;
      const totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      let html = `<span>共 ${total} 条</span><div class="pagination-controls">`;
      html += `<button ${currentPage <= 1 ? 'disabled' : ''} data-page="${currentPage - 1}">&laquo;</button>`;

      const maxVisible = 5;
      let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
      let endPage = Math.min(totalPages, startPage + maxVisible - 1);
      if (endPage - startPage + 1 < maxVisible) startPage = Math.max(1, endPage - maxVisible + 1);

      if (startPage > 1) { html += `<button data-page="1">1</button>`; if (startPage > 2) html += `<span class="page-ellipsis">...</span>`; }
      for (let i = startPage; i <= endPage; i++) { html += `<button class="${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`; }
      if (endPage < totalPages) { if (endPage < totalPages - 1) html += `<span class="page-ellipsis">...</span>`; html += `<button data-page="${totalPages}">${totalPages}</button>`; }
      html += `<button ${currentPage >= totalPages ? 'disabled' : ''} data-page="${currentPage + 1}">&raquo;</button>`;
      html += '</div>';
      el.innerHTML = html;
    }

    function applyFilters() {
      filteredItems = [...allItems];
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        filteredItems = filteredItems.filter(item =>
          (item.title || '').toLowerCase().includes(q) ||
          (item.description || '').toLowerCase().includes(q) ||
          (item.features || '').toLowerCase().includes(q)
        );
      }
      currentPage = 1;
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('ai-count')!.textContent = `共 ${filteredItems.length} 个应用`;
    }

    function goToPage(page: number) {
      currentPage = Math.max(1, Math.min(page, getTotalPages()));
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
    }

    document.getElementById('ai-pagination')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (btn && !btn.disabled) goToPage(Number(btn.dataset.page));
    });

    async function load() {
      try {
        // ai-apps collection 被 Strapi 公开 API 阻止，直接用构建时生成的 preview JSON
        allItems = await fetchPreview(PREVIEW_URL);
        applyFilters();
      } catch (e) {
        document.getElementById('ai-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    load();
  </script>
</Layout>

<style>
  .page-layout { padding: 32px 0 60px; }
  .page-title { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
  .page-subtitle { font-size: 15px; color: var(--text-light); margin-bottom: 24px; }
  .ai-card { display: flex; flex-direction: column; }
  @media (max-width: 768px) {
    .page-title { font-size: 22px; }
  }
</style>
