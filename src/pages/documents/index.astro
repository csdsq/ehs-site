---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="资料文档" currentPath="/documents/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">资料文档</h1>
      <p class="page-subtitle">EHS 相关资料、课件、模板下载</p>

      <!-- 搜索区 -->
      <div class="search-box" style="margin-bottom: 24px; max-width: 100%;">
        <input type="text" id="doc-search" placeholder="搜索资料名称、分类..." />
        <button id="doc-search-btn">搜索</button>
      </div>

      <div id="doc-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="doc-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="doc-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script>
    import { fetchPreview } from '../../lib/strapi-client';
    const PREVIEW_URL = '/data/documents-preview.json';
    const SUMMARY_FIELDS = ['title','slug','category','fileType','fileSize','publishDate','description'];

    let allItems: any[] = [];
    let filteredItems: any[] = [];
    let currentPage = 1;
    let pageSize = 10;
    let searchQuery = '';

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function renderItems(items: any[]) {
      const el = document.getElementById('doc-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => {
        const metaItems: string[] = [];
        if (item.category) metaItems.push(`<span class="std-tag std-tag-type-industry">${item.category}</span>`);
        const ft = (item.fileType || '').toUpperCase();
        const fileSize = item.fileSize ? ` · ${item.fileSize}` : '';
        if (ft) metaItems.push(`<span class="std-tag std-tag-type-gb">${ft}${fileSize}</span>`);
        if (item.publishDate) metaItems.push(`<span>${item.publishDate}</span>`);
        return `
          <a href="/documents/${item.slug || item.id}" class="list-item">
            <div class="list-item-body">
              <div class="list-item-title">${item.title}</div>
              <div class="list-item-meta-row">
                ${metaItems.join('')}
              </div>
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }).join('');
    }

    function renderPagination() {
      const el = document.getElementById('doc-pagination')!;
      const total = filteredItems.length;
      const totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      let html = `<span>共 ${total} 条</span><div class="pagination-controls">`;
      html += `<button ${currentPage <= 1 ? 'disabled' : ''} data-page="${currentPage - 1}">&laquo;</button>`;

      const maxVisible = 5;
      let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
      let endPage = Math.min(totalPages, startPage + maxVisible - 1);
      if (endPage - startPage + 1 < maxVisible) startPage = Math.max(1, endPage - maxVisible + 1);

      if (startPage > 1) { html += `<button data-page="1">1</button>`; if (startPage > 2) html += `<span class="page-ellipsis">...</span>`; }
      for (let i = startPage; i <= endPage; i++) { html += `<button class="${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`; }
      if (endPage < totalPages) { if (endPage < totalPages - 1) html += `<span class="page-ellipsis">...</span>`; html += `<button data-page="${totalPages}">${totalPages}</button>`; }
      html += `<button ${currentPage >= totalPages ? 'disabled' : ''} data-page="${currentPage + 1}">&raquo;</button>`;
      html += '</div>';
      el.innerHTML = html;
    }

    function applyFilters() {
      filteredItems = [...allItems];
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        filteredItems = filteredItems.filter(item =>
          (item.title || '').toLowerCase().includes(q) ||
          (item.category || '').toLowerCase().includes(q) ||
          (item.description || '').toLowerCase().includes(q)
        );
      }
      currentPage = 1;
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('doc-count')!.textContent = `共 ${filteredItems.length} 条资料`;
    }

    function goToPage(page: number) {
      currentPage = Math.max(1, Math.min(page, getTotalPages()));
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
    }

    document.getElementById('doc-pagination')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (btn && !btn.disabled) goToPage(Number(btn.dataset.page));
    });

    const searchBtn = document.getElementById('doc-search-btn');
    const searchInput = document.getElementById('doc-search');
    if (searchBtn && searchInput) {
      searchBtn.addEventListener('click', () => { searchQuery = searchInput.value.trim(); applyFilters(); });
      searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { searchQuery = searchInput.value.trim(); applyFilters(); } });
    }

    async function load() {
      try {
        // documents collection 被 Strapi 公开 API 阻止，直接用构建时生成的 preview JSON
        allItems = await fetchPreview(PREVIEW_URL);
        applyFilters();
      } catch (e) {
        document.getElementById('doc-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    load();
  </script>
</Layout>

<style>
  .page-layout { padding: 32px 0 60px; }
  .page-title { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
  .page-subtitle { font-size: 15px; color: var(--text-light); margin-bottom: 24px; }
  @media (max-width: 768px) {
    .page-title { font-size: 22px; }
  }
</style>
