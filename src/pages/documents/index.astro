---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="资料文档" currentPath="/documents/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">资料文档</h1>
      <p class="page-description">PPT、PDF、Word模板、检查表等EHS实用资料，即下即用。</p>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="doc-search" placeholder="搜索资料名称..." />
        <button id="doc-search-btn">搜索</button>
      </div>

      <div id="doc-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="doc-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </div>

  <script>
    const API = 'https://api.hser.ren';
    let allItems: any[] = [];

    async function loadItems() {
      try {
        const res = await fetch(`${API}/documents?pagination[pageSize]=100&sort=createdAt:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('doc-count')!.textContent = `共 ${total} 份资料`;
        renderItems(allItems);
      } catch (e) {
        document.getElementById('doc-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('doc-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无资料</div>'; return; }
      el.innerHTML = items.map(item => {
        const fileType = item.fileType ? item.fileType.toUpperCase() : '';
        const fileSize = item.fileSize || '';
        const typeSizeTag = (fileType || fileSize) ? ` <span class="list-item-no">(${[fileType, fileSize].filter(Boolean).join('，')})</span>` : '';
        const category = item.category || '';
        return `
        <a href="/documents/${item.slug || item.id}" class="list-item">
          <div class="list-item-body">
            <div class="list-item-title">${item.title}${typeSizeTag}</div>
            <div class="list-item-meta-row">
              ${category ? `<span>分类：${category}</span>` : ''}
              ${item.publishDate ? `<span>${item.publishDate}</span>` : ''}
            </div>
          </div>
          <div class="list-item-arrow">&rarr;</div>
        </a>`;
      }).join('');
    }

    function doSearch() {
      const q = (document.getElementById('doc-search') as HTMLInputElement).value.trim().toLowerCase();
      if (!q) { renderItems(allItems); return; }
      renderItems(allItems.filter(item =>
        (item.title ?? '').toLowerCase().includes(q) ||
        (item.category ?? '').toLowerCase().includes(q) ||
        (item.fileType ?? '').toLowerCase().includes(q)
      ));
    }

    document.getElementById('doc-search')!.addEventListener('input', doSearch);
    document.getElementById('doc-search-btn')!.addEventListener('click', doSearch);

    loadItems();
  </script>
</Layout>
