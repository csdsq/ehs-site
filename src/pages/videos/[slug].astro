---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PageComment from '../../components/PageComment.astro';


const { slug } = Astro.params;
---
<Layout title="视频详情" currentPath="/videos/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/videos/">视频课堂</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    <PageComment pageUrl={`/videos/${slug}`} />
  </div>

  <script define:vars={{ slug }}>
    const API = '/sapi';

    function proxyFileUrl(url) {
      if (!url) return '';
      return url.replace('https://api.hser.ren/uploads/', '/suploads/');
    }

    function getBilibiliEmbed(url) {
      const bvMatch = url.match(/BV[a-zA-Z0-9]+/);
      if (bvMatch) return `https://player.bilibili.com/player.html?bvid=${bvMatch[0]}&autoplay=0&high_quality=1`;
      return null;
    }

    function getBilibiliPage(url) {
      const bvMatch = url.match(/BV[a-zA-Z0-9]+/);
      if (bvMatch) return `https://www.bilibili.com/video/${bvMatch[0]}/`;
      return url;
    }

    async function loadDetail() {
      try {
        let res = await fetch(`${API}/videos?filters[slug][$eq]=${slug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/videos/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          document.getElementById('detail-title').textContent = item.title || '';

          const videoUrl = item.videoUrl || item.url || '';
          const isBilibili = videoUrl.includes('bilibili.com');
          const embedUrl = isBilibili ? getBilibiliEmbed(videoUrl) : null;
          const pageUrl = isBilibili ? getBilibiliPage(videoUrl) : videoUrl;

          // 视频播放区
          let playerHtml = '';
          if (embedUrl) {
            // Bilibili embed
            playerHtml = `
              <div class="detail-video-wrap">
                <iframe src="${embedUrl}" 
                  allowfullscreen="true" 
                  scrolling="no" 
                  frameborder="0"
                  sandbox="allow-top-navigation allow-same-origin allow-forms allow-scripts allow-popups">
                </iframe>
              </div>`;
          } else if (videoUrl) {
            // Generic video URL or other embed
            if (videoUrl.match(/\.(mp4|webm|ogg)(\?|$)/i)) {
              playerHtml = `
                <div class="detail-video-wrap">
                  <video controls preload="metadata" src="${videoUrl}">您的浏览器不支持视频播放</video>
                </div>`;
            } else {
              playerHtml = `
                <div class="detail-video-wrap">
                  <iframe src="${videoUrl}" allowfullscreen style="width:100%;height:480px;border:none;"></iframe>
                </div>`;
            }
          } else {
            playerHtml = '<p class="detail-empty">暂无视频资源</p>';
          }

          document.getElementById('detail-body').innerHTML = `
            <!-- 视频播放 -->
            <section class="detail-section">
              <h2 class="detail-section-title">视频播放</h2>
              <div class="detail-section-content">
                ${playerHtml}
              </div>
            </section>

            <!-- 内容描述 -->
            ${item.description ? `
            <section class="detail-section">
              <h2 class="detail-section-title">内容介绍</h2>
              <div class="detail-section-content">
                <div class="detail-text">${item.description.replace(/\n/g, '<br>')}</div>
              </div>
            </section>` : ''}

            <!-- 下载/查看原视频 -->
            <section class="detail-section">
              <h2 class="detail-section-title">查看原视频</h2>
              <div class="detail-section-content">
                ${item.downloadUrl
                  ? `<a href="${proxyFileUrl(item.downloadUrl)}" target="_blank" rel="noopener" class="detail-action-btn btn-download">下载视频 &darr;</a>`
                  : pageUrl
                    ? `<a href="${pageUrl}" target="_blank" rel="noopener" class="detail-action-btn">前往原始页面 &rarr;</a>`
                    : '<p class="detail-empty">暂无来源链接</p>'}
              </div>
            </section>
          `;
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该视频</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    loadDetail();
  </script>
</Layout>
