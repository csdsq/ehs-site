---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="视频课堂" currentPath="/videos/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">视频课堂</h1>
      <p class="page-description">安全培训、应急处置、事故案例分析等视频资源，助力安全意识与技能提升。</p>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="vid-search" placeholder="搜索视频名称..." />
        <button id="vid-search-btn">搜索</button>
      </div>

      <div id="vid-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="video-grid video-grid-3col" id="vid-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </div>

  <script>
    const API = 'https://api.hser.ren';
    let allItems: any[] = [];

    function renderVideoCard(item: any) {
      const title = item.title || '';
      const desc = item.description || '';
      const videoUrl = item.videoUrl || item.url || '';
      const duration = item.duration || '';
      const category = item.category || '';
      
      let thumbSrc = '';
      if (videoUrl.includes('bilibili.com/video/')) {
        const bv = videoUrl.match(/BV[a-zA-Z0-9]+/);
        thumbSrc = bv ? `https://i0.hdslb.com/bfs/archive/${bv[0]}s.jpg` : '';
      } else if (videoUrl.includes('youtube.com/watch')) {
        const vid = new URL(videoUrl).searchParams.get('v');
        thumbSrc = vid ? `https://img.youtube.com/vi/${vid}/mqdefault.jpg` : '';
      }

      return `
        <a href="/videos/${item.slug || item.id}" class="video-card">
          <div class="video-card-thumb">
            ${thumbSrc 
              ? `<img src="${thumbSrc}" alt="${title}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                 <div class="video-card-placeholder" style="display:none"><svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>`
              : `<div class="video-card-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>`
            }
            ${duration ? `<span class="video-card-duration">${duration}</span>` : ''}
            <div class="video-card-play">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="video-card-info">
            <div class="video-card-title">${title}</div>
            ${category ? `<span class="card-tag tag-video">${category}</span>` : ''}
            ${desc ? `<div class="video-card-desc">${desc.length > 80 ? desc.slice(0,80) + '...' : desc}</div>` : ''}
          </div>
        </a>`;
    }

    async function loadItems() {
      try {
        const res = await fetch(`${API}/videos?pagination[pageSize]=100&sort=createdAt:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('vid-count')!.textContent = `共 ${total} 个视频`;
        renderItems(allItems);
      } catch (e) {
        document.getElementById('vid-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('vid-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无视频</div>'; return; }
      el.innerHTML = items.map(item => renderVideoCard(item)).join('');
    }

    function doSearch() {
      const q = (document.getElementById('vid-search') as HTMLInputElement).value.trim().toLowerCase();
      if (!q) { renderItems(allItems); return; }
      renderItems(allItems.filter(item =>
        (item.title ?? '').toLowerCase().includes(q) ||
        (item.category ?? '').toLowerCase().includes(q)
      ));
    }

    document.getElementById('vid-search')!.addEventListener('input', doSearch);
    document.getElementById('vid-search-btn')!.addEventListener('click', doSearch);

    loadItems();
  </script>
</Layout>
