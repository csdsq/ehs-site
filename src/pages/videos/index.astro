---
import Layout from '../../layouts/Layout.astro';
import { getVideos } from '../../lib/strapi';
const items = await getVideos();
---
<Layout title="视频课堂">
  <h1 style="margin-bottom:24px;color:#1a5276;">🎬 视频课堂</h1>
  {items.length === 0
    ? <div class="card empty">暂无数据，请在 Strapi 后台录入内容</div>
    : <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;">
        {items.map(item => (
          <div class="card">
            <div style="font-weight:600;font-size:1.05em;margin-bottom:6px;">{item.attributes.title}</div>
            <div style="font-size:.85em;color:#888;margin-bottom:8px;">
              {item.attributes.publishDate} · {item.attributes.category}
              {item.attributes.duration && <span> · {item.attributes.duration}</span>}
            </div>
            {item.attributes.description && <p style="color:#555;font-size:.9em;">{item.attributes.description}</p>}
            {item.attributes.videoUrl && (
              <a href={item.attributes.videoUrl} target="_blank" style="display:inline-block;margin-top:10px;color:#1a5276;font-size:.9em;">▶ 观看视频</a>
            )}
          </div>
        ))}
      </div>
  }
</Layout>
