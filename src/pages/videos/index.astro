---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="视频课堂" currentPath="/videos/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">视频课堂</h1>
      <p class="page-description">安全培训、应急处置、事故案例分析等视频资源，助力安全意识与技能提升。</p>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="vid-search" placeholder="搜索视频名称..." />
        <button id="vid-search-btn">搜索</button>
      </div>

      <div id="vid-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="video-grid video-grid-3col" id="vid-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="vid-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script>
    const API = '';
    let allItems: any[] = [];
    let filteredItems: any[] = [];
    let currentPage = 1;
    let pageSize = 10;

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function renderVideoCard(item: any) {
      const title = item.title || '';
      const desc = item.description || '';
      const videoUrl = item.videoUrl || item.url || '';
      const duration = item.duration || '';
      const category = item.category || '';
      
      let thumbSrc = '';
      if (videoUrl.includes('bilibili.com/video/')) {
        const bv = videoUrl.match(/BV[a-zA-Z0-9]+/);
        thumbSrc = bv ? `https://i0.hdslb.com/bfs/archive/${bv[0]}s.jpg` : '';
      } else if (videoUrl.includes('youtube.com/watch')) {
        const vid = new URL(videoUrl).searchParams.get('v');
        thumbSrc = vid ? `https://img.youtube.com/vi/${vid}/mqdefault.jpg` : '';
      }

      return `
        <a href="/videos/${item.slug || item.id}" class="video-card">
          <div class="video-card-thumb">
            ${thumbSrc 
              ? `<img src="${thumbSrc}" alt="${title}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                 <div class="video-card-placeholder" style="display:none"><svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>`
              : `<div class="video-card-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>`
            }
            ${duration ? `<span class="video-card-duration">${duration}</span>` : ''}
            <div class="video-card-play">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="video-card-info">
            <div class="video-card-title">${title}</div>
            ${category ? `<span class="card-tag tag-video">${category}</span>` : ''}
            ${desc ? `<div class="video-card-desc">${desc.length > 80 ? desc.slice(0,80) + '...' : desc}</div>` : ''}
          </div>
        </a>`;
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('vid-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无视频</div>'; return; }
      el.innerHTML = items.map(item => renderVideoCard(item)).join('');
    }

    function renderPagination() {
      const el = document.getElementById('vid-pagination')!;
      const total = filteredItems.length;
      const totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      const start = (currentPage - 1) * pageSize + 1;
      const end = Math.min(currentPage * pageSize, total);

      let pagesHtml = '';
      const range: number[] = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        const s = Math.max(2, currentPage - 2);
        const e = Math.min(totalPages - 1, currentPage + 2);
        for (let i = s; i <= e; i++) range.push(i);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (const p of range) {
        if (p < 0) { pagesHtml += `<span class="page-ellipsis">…</span>`; }
        else { pagesHtml += `<button class="${p === currentPage ? 'active' : ''}" data-page="${p}">${p}</button>`; }
      }

      el.innerHTML = `
        <div class="pagination-info">显示 ${start}-${end}，共 ${total} 个视频</div>
        <div class="pagination-controls">
          <button data-action="prev" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>
          ${pagesHtml}
          <button data-action="next" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>
        </div>
        <div class="page-size-select">
          每页
          <select id="vid-page-size">
            <option value="10" ${pageSize===10?'selected':''}>10</option>
            <option value="20" ${pageSize===20?'selected':''}>20</option>
            <option value="50" ${pageSize===50?'selected':''}>50</option>
            <option value="100" ${pageSize===100?'selected':''}>100</option>
          </select>
          条
        </div>`;

      el.querySelector('#vid-page-size')!.addEventListener('change', (e: any) => {
        pageSize = parseInt(e.target.value); currentPage = 1; updateView();
      });
      el.querySelectorAll('[data-page]').forEach(btn => {
        btn.addEventListener('click', () => { currentPage = parseInt((btn as HTMLElement).dataset.page!); updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
      });
      el.querySelector('[data-action="prev"]')!.addEventListener('click', () => {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]')!.addEventListener('click', () => {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }

    function updateView() {
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
    }

    async function loadItems() {
      try {
        const res = await fetch(`${API}/videos?pagination[pageSize]=200&sort=createdAt:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        filteredItems = [...allItems];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('vid-count')!.textContent = `共 ${total} 个视频`;
        updateView();
      } catch (e) {
        document.getElementById('vid-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function doSearch() {
      const q = (document.getElementById('vid-search') as HTMLInputElement).value.trim().toLowerCase();
      if (!q) { filteredItems = [...allItems]; } else {
        filteredItems = allItems.filter(item =>
          (item.title ?? '').toLowerCase().includes(q) ||
          (item.category ?? '').toLowerCase().includes(q)
        );
      }
      currentPage = 1;
      updateView();
    }

    document.getElementById('vid-search')!.addEventListener('input', doSearch);
    document.getElementById('vid-search-btn')!.addEventListener('click', doSearch);

    loadItems();
  </script>
</Layout>
