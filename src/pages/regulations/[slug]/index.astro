---
import Layout from '../../../layouts/Layout.astro';
import PageComment from '../../../components/PageComment.astro';

export async function getStaticPaths() {
  try {
    const res = await fetch('https://api.hser.ren/regulations?pagination[pageSize]=100&fields[0]=slug');
    const json = await res.json();
    const items = json.data || [];
    return items.map(item => ({ params: { slug: item.slug || String(item.id) } }));
  } catch (e) { return []; }
}

const { slug } = Astro.params;
---
<Layout title="法规文件详情" currentPath="/regulations/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/regulations/">法规文件</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div id="detail-tags" style="margin-bottom: 16px;"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    <PageComment pageUrl={`/regulations/${slug}`} />
  </div>

  <script define:vars={{ slug }}>
    const API = 'https://api.hser.ren';
    async function loadDetail() {
      try {
        let res = await fetch(`${API}/regulations?filters[slug][$eq]=${slug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/regulations/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          // 类别+级别标签映射
          const categoryMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
          const regionMap = { national: '国家', provincial: '省', municipal: '市' };
          const catLabel = categoryMap[item.category] || '';
          const regLabel = regionMap[item.regionLevel] || '';
          const tagHtml = [
            catLabel ? `<span class="std-tag std-tag-${item.category}">${catLabel}</span>` : '',
            regLabel ? `<span class="std-tag std-tag-region">${regLabel}</span>` : '',
          ].filter(Boolean).join(' ');

          document.getElementById('detail-title').textContent = item.title || '';
          document.getElementById('detail-tags').innerHTML = tagHtml;

          // 基本信息：发文机构、发文号、实施日期（没有实施日期就写发文日期）
          const infoRows = [
            ['类别', catLabel || '-'],
            ['级别', regLabel || '-'],
            ['发文机构', item.source],
            ['发文号', item.standardNo],
            item.effectiveDate
              ? ['实施日期', item.effectiveDate]
              : item.publishDate
                ? ['发文日期', item.publishDate]
                : null,
          ].filter(Boolean).filter(([,v]) => v && v !== '-');

          document.getElementById('detail-body').innerHTML = `
            <!-- 基本信息 -->
            <section class="detail-section">
              <h2 class="detail-section-title">基本信息</h2>
              <div class="detail-section-content">
                ${infoRows.length > 0
                  ? `<table class="detail-info-table">
                       ${infoRows.map(([k,v]) => `<tr><td class="info-label">${k}</td><td class="info-value">${v}</td></tr>`).join('')}
                     </table>`
                  : '<p class="detail-empty">暂无基本信息</p>'}
              </div>
            </section>

            <!-- 文本全文 -->
            <section class="detail-section">
              <h2 class="detail-section-title">文本全文</h2>
              <div class="detail-section-content">
                ${item.content
                  ? `<div class="detail-text">${item.content}</div>`
                  : '<p class="detail-empty">暂无全文内容</p>'}
              </div>
            </section>

            <!-- 查看原文 -->
            <section class="detail-section">
              <h2 class="detail-section-title">查看原文</h2>
              <div class="detail-section-content">
                ${item.sourceUrl || item.downloadUrl
                  ? `<a href="${item.sourceUrl || item.downloadUrl}" target="_blank" rel="noopener" class="detail-action-btn">查看原文 &rarr;</a>`
                  : '<p class="detail-empty">暂无原文链接</p>'}
              </div>
            </section>
          `;
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该规范</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    loadDetail();
  </script>
</Layout>
