---
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  try {
    const res = await fetch('http://strapi.hser.ren:1337/api/regulations?pagination[pageSize]=100&fields[0]=slug');
    const json = await res.json();
    const items = json.data || [];
    return items.map(item => ({
      params: { slug: item.slug || String(item.id) }
    }));
  } catch (e) {
    return [];
  }
}

const { slug } = Astro.params;
---
<Layout title="法律法规详情" currentPath="/regulations/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/regulations/">法律法规</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div class="detail-meta-flat" id="detail-meta"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
  </div>

  <script define:vars={{ slug }}>
    const API = '/api';
    async function loadDetail() {
      try {
        let res = await fetch(`${API}/regulations?filters[slug][$eq]=${slug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/regulations/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          document.getElementById('detail-title').textContent = item.title || '';
          document.getElementById('detail-meta').innerHTML = [
            item.standardNo ? `<span>${item.standardNo}</span>` : '',
          ].filter(Boolean).join(' ');

          // 解析 content 中的结构化数据
          let extraInfo = {};
          try {
            if (item.content && item.content.trim().startsWith('{')) {
              extraInfo = JSON.parse(item.content);
            }
          } catch(e) {}

          // 标准简介
          const intro = item.description || extraInfo.intro || '';

          // 法规信息表
          const infoRows = [
            ['英文名称', extraInfo.englishName],
            ['标准编号', item.standardNo],
            ['替代情况', extraInfo.replacement],
            ['中标分类', extraInfo.ccs],
            ['ICS分类', extraInfo.ics],
            ['发布部门', item.source || extraInfo.publisher],
            ['发布日期', item.publishDate],
            ['实施日期', item.effectiveDate],
            ['提出单位', extraInfo.proposingOrg],
            ['归口单位', extraInfo.managingOrg],
            ['页数', extraInfo.pages],
            ['出版社', extraInfo.publishingHouse],
          ].filter(([,v]) => v);

          // 从 hcno 构建真实的预览/下载链接
          const hcno = extraInfo.hcno || '';
          const previewUrl = hcno ? `https://c.gb688.cn/bzgk/gb/showGb?type=online&hcno=${hcno}` : (extraInfo.previewUrl || '');
          const downloadUrl = hcno ? `https://c.gb688.cn/bzgk/gb/showGb?type=download&hcno=${hcno}` : (extraInfo.downloadUrl || item.downloadUrl || '');

          document.getElementById('detail-body').innerHTML = `
            <!-- 标准简介 -->
            ${intro ? `
            <section class="detail-section">
              <h2 class="detail-section-title">标准简介</h2>
              <div class="detail-section-content">
                <div class="detail-text">${intro.replace(/\n/g, '<br>')}</div>
              </div>
            </section>` : ''}

            <!-- 法规信息 -->
            <section class="detail-section">
              <h2 class="detail-section-title">法规信息</h2>
              <div class="detail-section-content">
                ${infoRows.length > 0
                  ? `<table class="detail-info-table">
                       ${infoRows.map(([k,v]) => `<tr><td class="info-label">${k}</td><td class="info-value">${v}</td></tr>`).join('')}
                     </table>`
                  : '<p class="detail-empty">暂无法规信息</p>'}
              </div>
            </section>

            <!-- 全文内容 -->
            ${(item.content && !item.content.trim().startsWith('{')) ? `
            <section class="detail-section">
              <h2 class="detail-section-title">法规全文</h2>
              <div class="detail-section-content">
                <div class="detail-text">${item.content}</div>
              </div>
            </section>` : ''}

            <!-- 在线预览和下载 -->
            ${(previewUrl || downloadUrl) ? `
            <section class="detail-section">
              <h2 class="detail-section-title">标准查阅</h2>
              <div class="detail-section-content">
                <div class="detail-actions">
                  ${previewUrl ? `<a href="${previewUrl}" target="_blank" rel="noopener" class="detail-action-btn btn-preview">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    在线预览
                  </a>` : ''}
                  ${downloadUrl ? `<a href="${downloadUrl}" target="_blank" rel="noopener" class="detail-action-btn btn-download">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    下载标准
                  </a>` : ''}
                </div>
              </div>
            </section>` : ''}
          `;
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该法规</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    loadDetail();
  </script>
</Layout>
