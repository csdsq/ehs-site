---
import Layout from '../../../layouts/Layout.astro';
import PageComment from '../../../components/PageComment.astro';

export async function getStaticPaths() {
  try {
    const res = await fetch('https://api.hser.ren/regulations?pagination[pageSize]=100&fields[0]=slug');
    const json = await res.json();
    const items = json.data || [];
    return items.map(item => ({ params: { slug: item.slug || String(item.id) } }));
  } catch (e) { return []; }
}

const { slug } = Astro.params;
---
<Layout title="法规文件详情" currentPath="/regulations/">
  <div class="container">
    <div class="detail-breadcrumb-flat">
      <a href="/">首页</a> / <a href="/regulations/">法规文件</a> / 详情
    </div>
    <h1 class="detail-title-flat" id="detail-title">加载中...</h1>
    <div id="detail-tags" style="margin-bottom: 16px;"></div>
    <div class="detail-body" id="detail-body">
      <div class="loading">加载中...</div>
    </div>
    <PageComment pageUrl={`/regulations/${slug}`} />
  </div>

  <script define:vars={{ slug }}>
    const API = 'https://api.hser.ren';
    async function loadDetail() {
      try {
        let res = await fetch(`${API}/regulations?filters[slug][$eq]=${slug}&pagination[pageSize]=1`);
        let json = await res.json();
        let item = json.data?.[0];
        if (!item) {
          res = await fetch(`${API}/regulations/${slug}`);
          json = await res.json();
          item = json.data;
        }
        if (item) {
          // 类别+级别标签映射
          const categoryMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
          const regionMap = { national: '国家', provincial: '省', municipal: '市' };
          const catLabel = categoryMap[item.category] || '';
          const regLabel = regionMap[item.regionLevel] || '';
          const tagHtml = [
            catLabel ? `<span class="std-tag std-tag-${item.category}">${catLabel}</span>` : '',
            regLabel ? `<span class="std-tag std-tag-region">${regLabel}</span>` : '',
          ].filter(Boolean).join(' ');

          document.getElementById('detail-title').textContent = item.title || '';
          document.getElementById('detail-tags').innerHTML = tagHtml;

          // 解析 content：支持 JSON / HTML表格 / 纯文本
          let contentInfoRows = [];
          let contentText = '';
          const content = (item.content || '').trim();

          if (content.startsWith('{')) {
            try {
              const extraInfo = JSON.parse(content);
              contentInfoRows = [
                ['英文名称', extraInfo.englishName],
                ['替代情况', extraInfo.replacement],
                ['中标分类', extraInfo.ccs],
                ['ICS分类', extraInfo.ics],
                ['提出单位', extraInfo.proposingOrg],
                ['归口单位', extraInfo.managingOrg],
                ['页数', extraInfo.pages],
                ['出版社', extraInfo.publishingHouse],
              ].filter(([,v]) => v);
              if (extraInfo.intro) contentText = extraInfo.intro;
            } catch(e) {}
          } else if (content.includes('<table')) {
            // HTML 表格格式：解析 th/td 提取键值对
            const parser = new DOMParser();
            const doc = parser.parseFromString(content, 'text/html');
            const rows = doc.querySelectorAll('tr');
            rows.forEach(row => {
              const th = row.querySelector('th');
              const td = row.querySelector('td');
              if (th && td) {
                const key = th.textContent.trim();
                let val = td.textContent.trim();
                val = val.replace(/\s*即将实施.*$/, '').replace(/\s*现行.*$/, '').replace(/\s*废止.*$/, '').trim();
                if (key === '标准状态') return;
                if (key && val) contentInfoRows.push([key, val]);
              }
            });
          } else if (content) {
            contentText = content;
          }

          // 合并基本信息和 content 信息为一个"标准信息"区
          const allInfoRows = [
            ['类别', catLabel],
            ['级别', regLabel],
            ['发文机构', item.source],
            ['发文号', item.standardNo],
            item.publishDate ? ['发布日期', item.publishDate] : null,
            item.effectiveDate ? ['实施日期', item.effectiveDate] : null,
            ...contentInfoRows,
          ].filter(Boolean).filter(([,v]) => v && v !== '-');

          document.getElementById('detail-body').innerHTML = `
            <!-- 标准信息 -->
            <section class="detail-section">
              <h2 class="detail-section-title">标准信息</h2>
              <div class="detail-section-content">
                ${allInfoRows.length > 0
                  ? `<div class="info-card-list">
                       ${allInfoRows.map(([k,v]) => `
                         <div class="info-card-item">
                           <span class="info-card-label">${k}</span>
                           <span class="info-card-value">${v}</span>
                         </div>`).join('')}
                     </div>`
                  : '<p class="detail-empty">暂无标准信息</p>'}
              </div>
            </section>

            ${contentText ? `
            <!-- 简介/全文 -->
            <section class="detail-section">
              <h2 class="detail-section-title">${content.startsWith('{') ? '标准简介' : '文本全文'}</h2>
              <div class="detail-section-content">
                <div class="detail-text">${contentText.replace(/\n/g, '<br>')}</div>
              </div>
            </section>` : ''}

            <!-- 查看原文 -->
            <section class="detail-section">
              <h2 class="detail-section-title">查看原文</h2>
              <div class="detail-section-content">
                <div class="detail-actions">
                  ${item.sourceUrl || item.downloadUrl
                    ? `<a href="${item.sourceUrl || item.downloadUrl}" target="_blank" rel="noopener" class="detail-action-btn btn-preview">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        查看原文
                      </a>`
                    : '<p class="detail-empty">暂无原文链接</p>'}
                </div>
              </div>
            </section>
          `;
        } else {
          document.getElementById('detail-body').innerHTML = '<div class="empty">未找到该规范</div>';
        }
      } catch (e) {
        document.getElementById('detail-body').innerHTML = '<div class="empty">加载失败</div>';
      }
    }
    loadDetail();
  </script>
</Layout>
