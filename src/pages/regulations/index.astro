---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="法规文件" currentPath="/regulations/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">法规文件</h1>

      <!-- 筛选标签区 -->
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label">类别</span>
          <div class="filter-tags" id="category-filters">
            <button class="filter-tag active" data-value="">全部</button>
            <button class="filter-tag" data-value="safety">安全</button>
            <button class="filter-tag" data-value="environment">环保</button>
            <button class="filter-tag" data-value="occupational_health">职业健康</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">地区</span>
          <div class="filter-tags" id="region-filters">
            <button class="filter-tag active" data-value="">全部</button>
            <button class="filter-tag" data-value="national">全国</button>
            <button class="filter-tag" data-value="北京">北京</button>
            <button class="filter-tag" data-value="天津">天津</button>
            <button class="filter-tag" data-value="上海">上海</button>
            <button class="filter-tag" data-value="重庆">重庆</button>
            <button class="filter-tag" data-value="河北">河北</button>
            <button class="filter-tag" data-value="山西">山西</button>
            <button class="filter-tag" data-value="辽宁">辽宁</button>
            <button class="filter-tag" data-value="吉林">吉林</button>
            <button class="filter-tag" data-value="黑龙江">黑龙江</button>
            <button class="filter-tag" data-value="江苏">江苏</button>
            <button class="filter-tag" data-value="浙江">浙江</button>
            <button class="filter-tag" data-value="安徽">安徽</button>
            <button class="filter-tag" data-value="福建">福建</button>
            <button class="filter-tag" data-value="江西">江西</button>
            <button class="filter-tag" data-value="山东">山东</button>
            <button class="filter-tag" data-value="河南">河南</button>
            <button class="filter-tag" data-value="湖北">湖北</button>
            <button class="filter-tag" data-value="湖南">湖南</button>
            <button class="filter-tag" data-value="广东">广东</button>
            <button class="filter-tag" data-value="海南">海南</button>
            <button class="filter-tag" data-value="四川">四川</button>
            <button class="filter-tag" data-value="贵州">贵州</button>
            <button class="filter-tag" data-value="云南">云南</button>
            <button class="filter-tag" data-value="陕西">陕西</button>
            <button class="filter-tag" data-value="广西">广西</button>
            <button class="filter-tag" data-value="甘肃">甘肃</button>
            <button class="filter-tag" data-value="青海">青海</button>
            <button class="filter-tag" data-value="内蒙古">内蒙古</button>
            <button class="filter-tag" data-value="西藏">西藏</button>
            <button class="filter-tag" data-value="宁夏">宁夏</button>
            <button class="filter-tag" data-value="新疆">新疆</button>
          </div>
        </div>
      </div>

      <div class="search-box" style="margin-bottom: 24px; max-width: 100%;">
        <input type="text" id="std-search" placeholder="搜索规范名称、标准号..." />
        <button id="std-search-btn">搜索</button>
      </div>

      <div id="std-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="std-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="std-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script>
    const API = 'https://api.hser.ren';
    const categoryMap: Record<string,string> = { safety: '安全', environment: '环保', occupational_health: '职业健康' };

    // 直辖市映射：标题中可能出现"深圳市""广州市"等，需归到对应省/直辖市
    const cityProvinceMap: Record<string,string> = {
      '深圳': '广东', '广州': '广东', '珠海': '广东', '佛山': '广东', '东莞': '广东',
      '南京': '江苏', '苏州': '江苏', '无锡': '江苏', '常州': '江苏', '南通': '江苏',
      '成都': '四川', '绵阳': '四川', '德阳': '四川',
      '杭州': '浙江', '宁波': '浙江', '温州': '浙江',
      '济南': '山东', '青岛': '山东', '烟台': '山东',
    };

    // 归入"其他"的省份/地区
    const otherRegions = ['甘肃','青海','内蒙古','西藏','宁夏','新疆'];

    function extractRegion(title: string): string {
      if (!title) return '';
      for (const [city, prov] of Object.entries(cityProvinceMap)) {
        if (title.includes(city)) return prov;
      }
      const provinces = ['北京','天津','上海','重庆','河北','山西','辽宁','吉林','黑龙江',
        '江苏','浙江','安徽','福建','江西','山东','河南','湖北','湖南','广东','海南',
        '四川','贵州','云南','陕西','内蒙古','广西','西藏','宁夏','新疆','甘肃','青海'];
      for (const p of provinces) {
        if (title.includes(p)) return p;
      }
      return '';
    }

    let allItems: any[] = [];
    let filteredItems: any[] = [];
    let currentPage = 1;
    let pageSize = 10;
    let activeCategory = '';
    let activeRegion = '';

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function getRegionLabel(item: any): string {
      if (item.regionLevel === 'national') return '全国';
      const region = extractRegion(item.title);
      return region || '地方';
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('std-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => {
        const metaParts = [];
        const catLabel = categoryMap[item.category] || '';
        const regLabel = getRegionLabel(item);
        const tagParts = [];
        if (catLabel) tagParts.push(`<span class="std-tag std-tag-${item.category}">${catLabel}</span>`);
        if (regLabel) tagParts.push(`<span class="std-tag std-tag-region">${regLabel}</span>`);

        if (item.source) metaParts.push(`<span>发文机构：${item.source}</span>`);
        if (item.standardNo) metaParts.push(`<span>发文号：${item.standardNo}</span>`);
        const dateLabel = item.effectiveDate ? '实施日期' : '发文日期';
        const dateValue = item.effectiveDate || item.publishDate;
        if (dateValue) metaParts.push(`<span>${dateLabel}：${dateValue}</span>`);
        return `
          <a href="/regulations/${item.slug || item.id}" class="list-item">
            <div class="list-item-body">
              <div class="list-item-title">${item.title}</div>
              <div class="list-item-meta-row">
                ${tagParts.length > 0 ? tagParts.join('') : ''}
                ${metaParts.join('')}
              </div>
            </div>
            <div class="list-item-arrow">&rarr;</div>
          </a>`;
      }).join('');
    }

    function renderPagination() {
      const el = document.getElementById('std-pagination')!;
      const total = filteredItems.length;
      const totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      const start = (currentPage - 1) * pageSize + 1;
      const end = Math.min(currentPage * pageSize, total);

      let pagesHtml = '';
      const range: number[] = [];
      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        const s = Math.max(2, currentPage - 2);
        const e = Math.min(totalPages - 1, currentPage + 2);
        for (let i = s; i <= e; i++) range.push(i);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (const p of range) {
        if (p < 0) { pagesHtml += `<span class="page-ellipsis">…</span>`; }
        else { pagesHtml += `<button class="${p === currentPage ? 'active' : ''}" data-page="${p}">${p}</button>`; }
      }

      el.innerHTML = `
        <div class="pagination-info">显示 ${start}-${end}，共 ${total} 项</div>
        <div class="pagination-controls">
          <button data-action="prev" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>
          ${pagesHtml}
          <button data-action="next" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>
        </div>
        <div class="page-size-select">
          每页
          <select id="std-page-size">
            <option value="10" ${pageSize===10?'selected':''}>10</option>
            <option value="20" ${pageSize===20?'selected':''}>20</option>
            <option value="50" ${pageSize===50?'selected':''}>50</option>
            <option value="100" ${pageSize===100?'selected':''}>100</option>
          </select>
          条
        </div>`;

      el.querySelector('#std-page-size')!.addEventListener('change', (e: any) => {
        pageSize = parseInt(e.target.value); currentPage = 1; updateView();
      });
      el.querySelectorAll('[data-page]').forEach(btn => {
        btn.addEventListener('click', () => { currentPage = parseInt((btn as HTMLElement).dataset.page!); updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); });
      });
      el.querySelector('[data-action="prev"]')!.addEventListener('click', () => {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]')!.addEventListener('click', () => {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }

    function applyFilters() {
      const q = (document.getElementById('std-search') as HTMLInputElement).value.trim().toLowerCase();
      filteredItems = allItems.filter(item => {
        if (activeCategory && item.category !== activeCategory) return false;
        if (activeRegion) {
          if (activeRegion === 'national') {
            if (item.regionLevel !== 'national') return false;
          } else {
            const region = extractRegion(item.title);
            if (region !== activeRegion) return false;
          }
        }
        if (q) {
          const text = `${item.title ?? ''} ${item.standardNo ?? ''} ${item.category ?? ''} ${item.source ?? ''}`.toLowerCase();
          if (!text.includes(q)) return false;
        }
        return true;
      });
      currentPage = 1;
      updateView();
    }

    function updateView() {
      const start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('std-count')!.textContent = `共 ${filteredItems.length} 项${filteredItems.length !== allItems.length ? `（筛选自 ${allItems.length} 项）` : ''}`;
    }

    async function loadItems() {
      try {
        // 分页获取全部法规数据（每次最多100条，翻页取完）
        let allData: any[] = [];
        let page = 1;
        let totalPages = 1;
        while (page <= totalPages) {
          const res = await fetch(`${API}/regulations?pagination[pageSize]=100&pagination[page]=${page}&sort=publishDate:desc`);
          const json = await res.json();
          if (json.data) allData = allData.concat(json.data);
          const meta = json.meta?.pagination;
          if (meta) {
            totalPages = meta.pageCount;
          } else {
            break;
          }
          page++;
        }
        allItems = allData;
        filteredItems = [...allItems];
        document.getElementById('std-count')!.textContent = `共 ${allItems.length} 项`;
        updateView();
      } catch (e) {
        document.getElementById('std-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    // 筛选标签事件
    document.getElementById('category-filters')!.addEventListener('click', (e: any) => {
      if (!e.target.classList.contains('filter-tag')) return;
      document.querySelectorAll('#category-filters .filter-tag').forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');
      activeCategory = e.target.dataset.value || '';
      applyFilters();
    });
    document.getElementById('region-filters')!.addEventListener('click', (e: any) => {
      if (!e.target.classList.contains('filter-tag')) return;
      document.querySelectorAll('#region-filters .filter-tag').forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');
      activeRegion = e.target.dataset.value || '';
      applyFilters();
    });

    document.getElementById('std-search')!.addEventListener('input', applyFilters);
    document.getElementById('std-search-btn')!.addEventListener('click', applyFilters);

    loadItems();
  </script>
</Layout>
