---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="法律法规" currentPath="/regulations/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">⚖️ 法律法规</h1>
      <p class="page-description">收录国家及地方法律、行政法规，覆盖消防安全、职业健康、环境保护等EHS核心领域。</p>

      <div class="search-box" style="margin-bottom: 32px; max-width: 100%;">
        <input type="text" id="reg-search" placeholder="搜索法律法规名称、来源..." />
        <button id="reg-search-btn">搜索</button>
      </div>

      <div id="reg-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="reg-list">
        <div class="empty">加载中...</div>
      </div>
    </div>
  </div>

  <script>
    const API = '/api';
    let allItems: any[] = [];

    async function loadItems() {
      try {
        const res = await fetch(`${API}/regulations?pagination[pageSize]=100&sort=publishDate:desc`);
        const json = await res.json();
        allItems = json.data ?? [];
        const total = json.meta?.pagination?.total ?? 0;
        document.getElementById('reg-count')!.textContent = `共 ${total} 项`;
        renderItems(allItems);
      } catch (e) {
        document.getElementById('reg-list')!.innerHTML = '<div class="empty">加载失败</div>';
      }
    }

    function renderItems(items: any[]) {
      const el = document.getElementById('reg-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      el.innerHTML = items.map(item => `
        <a href="/regulations/${item.slug || item.id}" class="list-item">
          <div class="list-item-icon icon-law">${item.icon || '⚖️'}</div>
          <div class="list-item-body">
            <div class="list-item-title">${item.title}</div>
            <div class="list-item-desc">${item.description || item.source || item.category || ''}</div>
          </div>
          <div class="list-item-arrow">&rarr;</div>
        </a>`).join('');
    }

    function doSearch() {
      const q = (document.getElementById('reg-search') as HTMLInputElement).value.trim().toLowerCase();
      if (!q) { renderItems(allItems); return; }
      renderItems(allItems.filter(item =>
        (item.title ?? '').toLowerCase().includes(q) ||
        (item.source ?? '').toLowerCase().includes(q) ||
        (item.category ?? '').toLowerCase().includes(q)
      ));
    }

    document.getElementById('reg-search')!.addEventListener('input', doSearch);
    document.getElementById('reg-search-btn')!.addEventListener('click', doSearch);

    loadItems();
  </script>
</Layout>
