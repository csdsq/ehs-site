---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
---
<Layout title="法规文件" currentPath="/regulations/">

  <div class="page-layout">
    <div class="container">
      <h1 class="page-title">法规文件</h1>

      <!-- 筛选标签区 -->
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label">类别</span>
          <div class="filter-tags" id="category-filters">
            <button class="filter-tag active" data-value="">全部</button>
            <button class="filter-tag" data-value="safety">安全</button>
            <button class="filter-tag" data-value="environment">环保</button>
            <button class="filter-tag" data-value="occupational_health">职业健康</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">地区</span>
          <div class="filter-tags" id="region-filters">
            <button class="filter-tag active" data-value="">全部</button>
            <button class="filter-tag" data-value="national">全国</button>
            <button class="filter-tag" data-value="北京">北京</button>
            <button class="filter-tag" data-value="天津">天津</button>
            <button class="filter-tag" data-value="上海">上海</button>
            <button class="filter-tag" data-value="重庆">重庆</button>
            <button class="filter-tag" data-value="河北">河北</button>
            <button class="filter-tag" data-value="山西">山西</button>
            <button class="filter-tag" data-value="辽宁">辽宁</button>
            <button class="filter-tag" data-value="吉林">吉林</button>
            <button class="filter-tag" data-value="黑龙江">黑龙江</button>
            <button class="filter-tag" data-value="江苏">江苏</button>
            <button class="filter-tag" data-value="浙江">浙江</button>
            <button class="filter-tag" data-value="安徽">安徽</button>
            <button class="filter-tag" data-value="福建">福建</button>
            <button class="filter-tag" data-value="江西">江西</button>
            <button class="filter-tag" data-value="山东">山东</button>
            <button class="filter-tag" data-value="河南">河南</button>
            <button class="filter-tag" data-value="湖北">湖北</button>
            <button class="filter-tag" data-value="湖南">湖南</button>
            <button class="filter-tag" data-value="广东">广东</button>
            <button class="filter-tag" data-value="海南">海南</button>
            <button class="filter-tag" data-value="四川">四川</button>
            <button class="filter-tag" data-value="贵州">贵州</button>
            <button class="filter-tag" data-value="云南">云南</button>
            <button class="filter-tag" data-value="陕西">陕西</button>
            <button class="filter-tag" data-value="广西">广西</button>
            <button class="filter-tag" data-value="甘肃">甘肃</button>
            <button class="filter-tag" data-value="青海">青海</button>
            <button class="filter-tag" data-value="内蒙古">内蒙古</button>
            <button class="filter-tag" data-value="西藏">西藏</button>
            <button class="filter-tag" data-value="宁夏">宁夏</button>
            <button class="filter-tag" data-value="新疆">新疆</button>
          </div>
        </div>
      </div>

      <div class="search-box" style="margin-bottom: 24px; max-width: 100%;">
        <input type="text" id="std-search" placeholder="搜索规范名称、标准号..." />
        <button id="std-search-btn">搜索</button>
      </div>

      <div id="std-count" style="font-size: 13px; color: var(--text-light); margin-bottom: 16px;"></div>
      <div class="list-grid" id="std-list">
        <div class="empty">加载中...</div>
      </div>
      <div id="std-pagination" class="pagination-bar" style="display:none;"></div>
    </div>
  </div>

  <script is:inline>
    var PREVIEW_URL = '/data/regulations-preview.json';
    var SUMMARY_FIELDS = ['title','slug','category','source','standardNo','effectiveDate','publishDate','downloadUrl'];
    var categoryMap = { safety: '安全', environment: '环保', occupational_health: '职业健康' };
    var allItems = [];
    var filteredItems = [];
    var currentPage = 1;
    var pageSize = 10;
    var activeCategory = '';
    var activeRegion = '';

    var cityProvinceMap = {
      '深圳': '广东', '广州': '广东', '珠海': '广东', '佛山': '广东', '东莞': '广东',
      '南京': '江苏', '苏州': '江苏', '无锡': '江苏', '常州': '江苏', '南通': '江苏',
      '成都': '四川', '绵阳': '四川', '德阳': '四川',
      '杭州': '浙江', '宁波': '浙江', '温州': '浙江',
      '济南': '山东', '青岛': '山东', '烟台': '山东',
    };

    var otherRegions = ['甘肃','青海','内蒙古','西藏','宁夏','新疆'];

    var nationalSourceKeywords = [
      '国务院', '国务院办公厅', '全国人大', '全国人民代表大会', '全国人大常委会', '中共中央',
      '应急管理部', '生态环境部', '国家市场监督管理总局', '国家标准委',
      '国家标准化管理委员会', '国家矿山安全监察局', '国家卫生健康委员会',
      '国家卫健委', '人力资源和社会保障部', '住房和城乡建设部',
      '国家发展和改革委员会', '国家发改委', '商务部', '工业和信息化部', '工信部',
      '交通运输部', '自然资源部', '农业农村部', '司法部', '公安部',
      '国家消防救援局', '国家能源局', '中国气象局', '国家林业和草原局',
      '中华全国总工会', '国家国防科技工业局', '财政部', '教育部',
      '科学技术部', '民政部', '水利部', '文化和旅游部', '审计署',
      '国家广播电视总局', '国家体育总局', '国家统计局', '国家医疗保障局',
      '国家金融监督管理总局', '国家原子能机构'
    ];

    function isNationalBySource(item) {
      if (item.regionLevel === 'national') return true;
      if (!item.source) return false;
      for (var i = 0; i < nationalSourceKeywords.length; i++) {
        if (item.source.indexOf(nationalSourceKeywords[i]) >= 0) return true;
      }
      return false;
    }

    function extractRegion(title) {
      if (!title) return '';
      for (var city in cityProvinceMap) {
        if (title.indexOf(city) >= 0) return cityProvinceMap[city];
      }
      var provinces = ['北京','天津','上海','重庆','河北','山西','辽宁','吉林','黑龙江',
        '江苏','浙江','安徽','福建','江西','山东','河南','湖北','湖南','广东','海南',
        '四川','贵州','云南','陕西','内蒙古','广西','西藏','宁夏','新疆','甘肃','青海'];
      for (var i = 0; i < provinces.length; i++) {
        if (title.indexOf(provinces[i]) >= 0) return provinces[i];
      }
      return '';
    }

    function getTotalPages() { return Math.max(1, Math.ceil(filteredItems.length / pageSize)); }

    function getRegionLabel(item) {
      if (isNationalBySource(item)) return '全国';
      var region = extractRegion(item.title);
      return region || '地方';
    }

    function getDetailLink(item) {
      return '/regulations/' + item.slug;
    }

    function renderItems(items) {
      var el = document.getElementById('std-list');
      if (!el) return;
      if (items.length === 0) { el.innerHTML = '<div class="empty">暂无数据</div>'; return; }
      var html = '';
      for (var i = 0; i < items.length; i++) {
        var item = items[i];
        var catLabel = categoryMap[item.category] || '';
        var regLabel = getRegionLabel(item);
        var tagParts = [];
        if (catLabel) tagParts.push('<span class="std-tag std-tag-' + item.category + '">' + catLabel + '</span>');
        if (regLabel) tagParts.push('<span class="std-tag std-tag-region">' + regLabel + '</span>');

        var metaParts = [];
        if (item.source) metaParts.push('<span>发文机构：' + item.source + '</span>');
        if (item.standardNo) metaParts.push('<span>发文号：' + item.standardNo + '</span>');
        var dateLabel = item.effectiveDate ? '实施日期' : '发文日期';
        var dateValue = item.effectiveDate || item.publishDate;
        if (dateValue) metaParts.push('<span>' + dateLabel + '：' + dateValue + '</span>');

        var metaHtml = metaParts.join('');
        var tagHtml = tagParts.length > 0 ? tagParts.join('') : '';
        var detailUrl = getDetailLink(item);

        html += '<a href="' + detailUrl + '" class="list-item">'
          + '<div class="list-item-body">'
          + '<div class="list-item-title">' + (item.title || '') + '</div>'
          + '<div class="list-item-meta-row">' + tagHtml + metaHtml + '</div>'
          + '</div>'
          + '<div class="list-item-arrow">&rarr;</div>'
          + '</a>';
      }
      el.innerHTML = html;
    }

    function renderPagination() {
      var el = document.getElementById('std-pagination');
      var total = filteredItems.length;
      var totalPages = getTotalPages();
      if (total <= pageSize) { el.style.display = 'none'; return; }
      el.style.display = 'flex';

      var start = (currentPage - 1) * pageSize + 1;
      var end = Math.min(currentPage * pageSize, total);

      var pagesHtml = '';
      var range = [];
      if (totalPages <= 7) {
        for (var i = 1; i <= totalPages; i++) range.push(i);
      } else {
        range.push(1);
        if (currentPage > 4) range.push(-1);
        var s = Math.max(2, currentPage - 2);
        var e = Math.min(totalPages - 1, currentPage + 2);
        for (var j = s; j <= e; j++) range.push(j);
        if (currentPage < totalPages - 3) range.push(-2);
        range.push(totalPages);
      }
      for (var k = 0; k < range.length; k++) {
        var p = range[k];
        if (p < 0) { pagesHtml += '<span class="page-ellipsis">…</span>'; }
        else { pagesHtml += '<button class="' + (p === currentPage ? 'active' : '') + '" data-page="' + p + '">' + p + '</button>'; }
      }

      el.innerHTML =
        '<div class="pagination-info">显示 ' + start + '-' + end + '，共 ' + total + ' 项</div>'
        + '<div class="pagination-controls">'
        + '<button data-action="prev"' + (currentPage === 1 ? ' disabled' : '') + '>上一页</button>'
        + pagesHtml
        + '<button data-action="next"' + (currentPage === totalPages ? ' disabled' : '') + '>下一页</button>'
        + '</div>'
        + '<div class="page-size-select">每页'
        + '<select id="std-page-size">'
        + '<option value="10"' + (pageSize===10?' selected':'') + '>10</option>'
        + '<option value="20"' + (pageSize===20?' selected':'') + '>20</option>'
        + '<option value="50"' + (pageSize===50?' selected':'') + '>50</option>'
        + '<option value="100"' + (pageSize===100?' selected':'') + '>100</option>'
        + '</select>条</div>';

      el.querySelector('#std-page-size').addEventListener('change', function(e) {
        pageSize = parseInt(e.target.value); currentPage = 1; updateView();
      });
      el.querySelectorAll('[data-page]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          currentPage = parseInt(btn.dataset.page);
          updateView();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
      el.querySelector('[data-action="prev"]').addEventListener('click', function() {
        if (currentPage > 1) { currentPage--; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
      el.querySelector('[data-action="next"]').addEventListener('click', function() {
        if (currentPage < getTotalPages()) { currentPage++; updateView(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      });
    }

    function applyFilters() {
      var q = document.getElementById('std-search').value.trim().toLowerCase();
      filteredItems = [];
      for (var fi = 0; fi < allItems.length; fi++) {
        var item = allItems[fi];
        if (activeCategory && item.category !== activeCategory) continue;
        if (activeRegion) {
          if (activeRegion === 'national') {
            if (!isNationalBySource(item)) continue;
          } else {
            var region = extractRegion(item.title);
            if (region !== activeRegion) continue;
          }
        }
        if (q) {
          var text = ((item.title || '') + ' ' + (item.standardNo || '') + ' ' + (item.category || '') + ' ' + (item.source || '')).toLowerCase();
          if (text.indexOf(q) < 0) continue;
        }
        filteredItems.push(item);
      }
      currentPage = 1;
      updateView();
    }

    function updateView() {
      var start = (currentPage - 1) * pageSize;
      renderItems(filteredItems.slice(start, start + pageSize));
      renderPagination();
      document.getElementById('std-count').textContent = '共 ' + filteredItems.length + ' 项'
        + (filteredItems.length !== allItems.length ? '（筛选自 ' + allItems.length + ' 项）' : '');
    }

    function fetchAllSummaries(collection, fields, sort) {
      var params = 'pagination[page]=1&pagination[pageSize]=100';
      if (sort) params += '&sort=' + encodeURIComponent(sort);
      for (var fi = 0; fi < fields.length; fi++) {
        params += '&fields[' + fi + ']=' + encodeURIComponent(fields[fi]);
      }
      var url = '/sapi/' + collection + '?' + params;
      var controller = new AbortController();
      var timer = setTimeout(function() { controller.abort(); }, 3000);
      return fetch(url, { signal: controller.signal }).then(function(res) {
        clearTimeout(timer);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      }).then(function(data) {
        var items = [];
        if (data && data.data) {
          for (var i = 0; i < data.data.length; i++) {
            var d = data.data[i];
            var attrs = d.attributes || d;
            attrs.id = d.id;
            attrs.documentId = d.documentId;
            items.push(attrs);
          }
        }
        return items;
      });
    }

    function fetchPreview(url) {
      return fetch(url).then(function(res) { return res.json(); });
    }

    async function loadItems() {
      var listEl = document.getElementById('std-list');
      try {
        allItems = await fetchAllSummaries('regulations', SUMMARY_FIELDS, 'publishDate:desc');
        filteredItems = allItems.slice();
        document.getElementById('std-count').textContent = '共 ' + allItems.length + ' 项';
        updateView();
      } catch (e) {
        try {
          allItems = await fetchPreview(PREVIEW_URL);
          filteredItems = allItems.slice();
          document.getElementById('std-count').textContent = '共 ' + allItems.length + ' 项（离线缓存）';
          updateView();
        } catch (e2) {
          if (listEl) listEl.innerHTML = '<div class="empty">加载失败</div>';
        }
      }
    }

    document.getElementById('category-filters').addEventListener('click', function(e) {
      if (!e.target.classList.contains('filter-tag')) return;
      document.querySelectorAll('#category-filters .filter-tag').forEach(function(b) { b.classList.remove('active'); });
      e.target.classList.add('active');
      activeCategory = e.target.dataset.value || '';
      applyFilters();
    });
    document.getElementById('region-filters').addEventListener('click', function(e) {
      if (!e.target.classList.contains('filter-tag')) return;
      document.querySelectorAll('#region-filters .filter-tag').forEach(function(b) { b.classList.remove('active'); });
      e.target.classList.add('active');
      activeRegion = e.target.dataset.value || '';
      applyFilters();
    });

    document.getElementById('std-search').addEventListener('input', applyFilters);
    document.getElementById('std-search-btn').addEventListener('click', applyFilters);

    loadItems();
  </script>
</Layout>
